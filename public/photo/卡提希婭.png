			<script type="application/json" data-sveltekit-fetched data-url="https://static.nanoka.cc/ww/3.5.3/weapon.json" data-ttl="25">{"status":200,"statusText":"OK","headers":{},"body":"{\n  \"21010011\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010011_UI.T_IconWeapon21010011_UI\",\n    \"rank\": 1,\n    \"type\": 1,\n    \"en\": \"Training Broadblade\",\n    \"desc\": \"This broadblade is designed specifically for training and teaching, offering only the basic features.\",\n    \"atk\": 250,\n    \"sub\": \"ATK\",\n    \"ko\": \"견습용 대검\",\n    \"zh\": \"教学长刃\",\n    \"ja\": \"稽古用長刃\"\n  },\n  \"21010012\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010012_UI.T_IconWeapon21010012_UI\",\n    \"rank\": 2,\n    \"type\": 1,\n    \"en\": \"Tyro Broadblade\",\n    \"desc\": \"The onset of pinnacle pursuit. A broadblade designed for novice Resonators. Contains a power not to be underestimated under its simple outlook.\",\n    \"atk\": 275,\n    \"sub\": \"ATK\",\n    \"ko\": \"태초의 대검\",\n    \"zh\": \"原初长刃·朴石\",\n    \"ja\": \"原初の長刃・岩塊\"\n  },\n  \"21010013\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010013_UI.T_IconWeapon21010013_UI\",\n    \"rank\": 3,\n    \"type\": 1,\n    \"en\": \"Broadblade of Night\",\n    \"desc\": \"May victory prevail the lasting night. In addition to the sworn oath of protection, this broadblade also carries the resolution of those fighting souls.\",\n    \"atk\": 325,\n    \"sub\": \"ATK\",\n    \"ko\": \"흑야의 대검 · 현명\",\n    \"zh\": \"暗夜长刃·玄明\",\n    \"ja\": \"暗夜の長刃・玄明\"\n  },\n  \"21010015\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010015_UI.T_IconWeapon21010015_UI\",\n    \"rank\": 5,\n    \"type\": 1,\n    \"en\": \"Lustrous Razor\",\n    \"desc\": \"Gaze upon this Broadblade, its sharp edges gleaming in the frigid air. Wield it to feel power coursing through you like a raging river.\",\n    \"atk\": 588,\n    \"sub\": \"ATK\",\n    \"ko\": \"푸른물결의 빛\",\n    \"zh\": \"浩境粼光\",\n    \"ja\": \"仙境の湖光\"\n  },\n  \"21010016\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010016_UI.T_IconWeapon21010016_UI\",\n    \"rank\": 5,\n    \"type\": 1,\n    \"en\": \"Verdant Summit\",\n    \"desc\": \"The ancient mountain stands tall, its peak reaching towards the sky. A river flows for thousands of years, forming the blade of a powerful weapon. As it is unsheathed, a powerful dragon's roar echoes through the heavens and earth, causing the sea to churn. This awe-inspiring weapon strikes fear in all who witness its might.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. DMG\",\n    \"ko\": \"청룡의 천장\",\n    \"zh\": \"苍鳞千嶂\",\n    \"ja\": \"蒼鱗連峰\"\n  },\n  \"21010023\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010023_UI.T_IconWeapon21010023_UI\",\n    \"rank\": 3,\n    \"type\": 1,\n    \"en\": \"Originite: Type I\",\n    \"desc\": \"To create new Tacetite weapons, the Huaxu Academy designed this test Broadblade for technical verification. Its main feature is healing through attacks, improving the physical abilities of Resonators while exhibiting impressive weapon performance.\",\n    \"atk\": 300,\n    \"sub\": \"DEF\",\n    \"ko\": \"원능의 대검 · 견습I\",\n    \"zh\": \"源能长刃·测壹\",\n    \"ja\": \"本源長刃・試作壱\"\n  },\n  \"21010024\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010024_UI.T_IconWeapon21010024_UI\",\n    \"rank\": 4,\n    \"type\": 1,\n    \"en\": \"Discord\",\n    \"desc\": \"A descending adagio. This broadblade dominates the battlefield with the power of discordance. The curtain never falls on a masterpiece.\",\n    \"atk\": 338,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"기묘한 울림\",\n    \"zh\": \"异响空灵\",\n    \"ja\": \"霊感ディスコード\"\n  },\n  \"21010026\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010026_UI.T_IconWeapon21010026_UI\",\n    \"rank\": 5,\n    \"type\": 1,\n    \"en\": \"Ages of Harvest\",\n    \"desc\": \"Each swing of the blade reveals the flow of time and the change of the stars. The sword embodies all things, uniting them into one. Its gentle aura seems capable of dissolving the indestructible, whether it's millennia-old ice or the stagnation of time.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"태평성대\",\n    \"zh\": \"时和岁稔\",\n    \"ja\": \"歳華調和\"\n  },\n  \"21010034\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010034_UI.T_IconWeapon21010034_UI\",\n    \"rank\": 4,\n    \"type\": 1,\n    \"en\": \"Broadblade#41\",\n    \"desc\": \"An improved version of a mass-produced broadblade model developed in Huanglong. With its formidable performance and innovative technologies, this broadblade carries a weight only to be wielded by seasoned warriors.\",\n    \"atk\": 412,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"41형 대검 · 무거운 책임\",\n    \"zh\": \"重破刃-41型\",\n    \"ja\": \"重破刃＃41\"\n  },\n  \"21010036\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010036_UI.T_IconWeapon21010036_UI\",\n    \"rank\": 5,\n    \"type\": 1,\n    \"en\": \"Wildfire Mark\",\n    \"desc\": \"The young wolf races through the wilds, shedding every shadow that once held her back.\\nThe lone wolf strides into the arena, cutting down each obstacle in her path.\\nShe seizes victory. She claims glory. She raises everything she has high above. She belongs to the arena, but even more, she belongs to herself.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. DMG\",\n    \"ko\": \"불길\",\n    \"zh\": \"焰痕\",\n    \"ja\": \"闘炎の爪痕\"\n  },\n  \"21010043\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010043_UI.T_IconWeapon21010043_UI\",\n    \"rank\": 3,\n    \"type\": 1,\n    \"en\": \"Broadblade of Voyager\",\n    \"desc\": \"The Broadblade provided by the Pioneer Association for the explorers is brightly colored, not easy to lose, hard in texture, and can cope with various extreme environments for a long time, and is very popular among the explorers.\",\n    \"atk\": 300,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"수행자의 대검 · 벽로\",\n    \"zh\": \"远行者长刃·辟路\",\n    \"ja\": \"探索者長刃・開拓\"\n  },\n  \"21010044\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010044_UI.T_IconWeapon21010044_UI\",\n    \"rank\": 4,\n    \"type\": 1,\n    \"en\": \"Dauntless Evernight\",\n    \"desc\": \"A weapon designed to commemorate the Midnight Rangers' preparedness. \\\"Autumn fades in endless nights, ready blades gleam with silent might.\\\"\",\n    \"atk\": 338,\n    \"sub\": \"DEF\",\n    \"ko\": \"장야의 불빛\",\n    \"zh\": \"永夜长明\",\n    \"ja\": \"長夜の灯火\"\n  },\n  \"21010045\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon_21010045_UI.T_IconWeapon_21010045_UI\",\n    \"rank\": 5,\n    \"type\": 1,\n    \"en\": \"Radiance Cleaver\",\n    \"desc\": \"Spacetrek Collective \\\"Synth Armament\\\" Series\\nModel: SCSA-LHRi-BB325042\\n\\nForged from compound technology that fuses Exostrider biomorphic components with Tacetite, this weapon offers two core features: frequency auto-adaptation and user binding. Its power scales directly with the wielder's Forte, growing sharper through dedicated Forte training.\\n\\nThe light patterns along the blade shift in response to the wielder's frequency fluctuations. It crystallizes reason into a concentrated force—a tool to cut through obstacles as well as a measure for charting the unknown. Ideal for the edge breakers who carve their path forward with unwavering resolve.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. DMG\",\n    \"ko\": \"에너지 절단\",\n    \"zh\": \"源能机锋\",\n    \"ja\": \"ラディアンスの切っ先\"\n  },\n  \"21010046\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010046_UI.T_IconWeapon21010046_UI\",\n    \"rank\": 5,\n    \"type\": 1,\n    \"en\": \"Thunderflare Dominion\",\n    \"desc\": \"Thunder shall purge her pain and weakness. From the crucible of blood and sand, the Sun rises. Not dimmed by dust, but ablaze in her full radiance.\",\n    \"atk\": 675,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"천둥벼락을 다스리는 권능\",\n    \"zh\": \"驭冕铸雷之权\",\n    \"ja\": \"雷霆を統べし王剣\"\n  },\n  \"21010053\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010053_UI.T_IconWeapon21010053_UI\",\n    \"rank\": 3,\n    \"type\": 1,\n    \"en\": \"Guardian Broadblade\",\n    \"desc\": \"The first Jinzhou Magistrate, in memory of the mysterious person who helped defend the border and build the city, created the Guardian series under his guidance. Today, it has become an indispensable cornerstone in the development of new weapons.\",\n    \"atk\": 325,\n    \"sub\": \"ATK\",\n    \"ko\": \"수호자의 대검 · 근성\",\n    \"zh\": \"戍关长刃·定军\",\n    \"ja\": \"辺守長刃・統率\"\n  },\n  \"21010056\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010056_UI.T_IconWeapon21010056_UI\",\n    \"rank\": 5,\n    \"type\": 1,\n    \"en\": \"Kumokiri\",\n    \"desc\": \"A crimson thread emerges in the void, as if binding the structures of all things onto a single thread.\\n\\nAt her fingertips, the endless season is drawn taut, snipped, and rewoven, until the scattered path at last converges once more upon this timeline.\",\n    \"atk\": 500,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"쿠모키리(曇斬)\",\n    \"zh\": \"昙切\",\n    \"ja\": \"曇斬\"\n  },\n  \"21010063\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010063_UI.T_IconWeapon21010063_UI\",\n    \"rank\": 3,\n    \"type\": 1,\n    \"en\": \"Beguiling Melody\",\n    \"desc\": \"Forged from the scale of Jué, this weapon resembles a musical instrument more than a tool of destruction.\",\n    \"atk\": 300,\n    \"sub\": \"ATK\",\n    \"ko\": \"천상의 음률\",\n    \"zh\": \"钧天正音\",\n    \"ja\": \"天上の仙楽\"\n  },\n  \"21010064\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010064_UI.T_IconWeapon21010064_UI\",\n    \"rank\": 4,\n    \"type\": 1,\n    \"en\": \"Helios Cleaver\",\n    \"desc\": \"The Broadblade born from the aerial phenomenon. The blacksmith incorporates the feelings of witnessing the alien star into the weapon, making it look hollow and light, but it can exert the invincible gravity of the starfall.\",\n    \"atk\": 412,\n    \"sub\": \"ATK\",\n    \"ko\": \"저무는 동녘\",\n    \"zh\": \"东落\",\n    \"ja\": \"逆行の星\"\n  },\n  \"21010066\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010066_UI.T_IconWeapon21010066_UI\",\n    \"rank\": 5,\n    \"type\": 1,\n    \"en\": \"Starfield Calibrator\",\n    \"desc\": \"Every pattern can be observed. Every phenomenon can be understood.\\nThe ideal may lie light-years away, yet the path toward it rests within her own hands.\",\n    \"atk\": 412,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"별하늘 연산 측정기\",\n    \"zh\": \"宙算仪轨\",\n    \"ja\": \"スターキャリブレーター\"\n  },\n  \"21010074\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010074_UI.T_IconWeapon21010074_UI\",\n    \"rank\": 4,\n    \"type\": 1,\n    \"en\": \"Autumntrace\",\n    \"desc\": \"This Broadblade is a ceremonial weapon used in Huanglong's Magistrate Inauguration Ceremonies. The golden ginkgo leaf pattern symbolizes Huanglong's resilience, thriving in a world that has left it behind.\",\n    \"atk\": 412,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"가을의 무늬\",\n    \"zh\": \"纹秋\",\n    \"ja\": \"秋の名残\"\n  },\n  \"21010084\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010084_UI.T_IconWeapon21010084_UI\",\n    \"rank\": 4,\n    \"type\": 1,\n    \"en\": \"Waning Redshift\",\n    \"desc\": \"A prototype weapon designed by the Black Shores for elite combatants. This broadblade takes its name from the fate of a blazar—a galactic nucleus whose blinding radiance pierces the cosmos, shining unmistakably across billions of light years.\",\n    \"atk\": 462,\n    \"sub\": \"ATK\",\n    \"ko\": \"멸망의 주파수\",\n    \"zh\": \"凋亡频移\",\n    \"ja\": \"破滅に迫る赤方偏移\"\n  },\n  \"21010094\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010094_UI.T_IconWeapon21010094_UI\",\n    \"rank\": 4,\n    \"type\": 1,\n    \"en\": \"Meditations on Mercy\",\n    \"desc\": \"This weapon draws its design inspiration from the play—Meditations on Mercy.\\nIn the brief pauses between each swing, a warrior wrestles with an inner conflict: to bring down righteous punishment or extend a hand of redemption? Behind every clash of steel is the struggle between wrath and mercy.\",\n    \"atk\": 462,\n    \"sub\": \"ATK\",\n    \"ko\": \"용서의 명상록\",\n    \"zh\": \"容赦的沉思录\",\n    \"ja\": \"寛恕のタ・エイス・ヘアウトン\"\n  },\n  \"21010104\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010104_UI.T_IconWeapon21010104_UI\",\n    \"rank\": 4,\n    \"type\": 1,\n    \"en\": \"Aureate Zenith\",\n    \"desc\": \"A Broadblade awarded to Gladiators of exceptional merit. Its engravings draw inspiration from Griffrexes—natural-born hunters and the first allies Septimontians found in this land. Their bond needs no words, radiant and pure, like the blazing sun that watches over all.\",\n    \"atk\": 412,\n    \"sub\": \"Crit. DMG\",\n    \"ko\": \"금빛 하늘\",\n    \"zh\": \"金穹\",\n    \"ja\": \"金の天穹\"\n  },\n  \"21020011\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020011_UI.T_IconWeapon21020011_UI\",\n    \"rank\": 1,\n    \"type\": 2,\n    \"en\": \"Training Sword\",\n    \"desc\": \"This sword is designed specifically for training and teaching, offering only the basic features.\",\n    \"atk\": 250,\n    \"sub\": \"ATK\",\n    \"ko\": \"견습용 직검\",\n    \"zh\": \"教学迅刀\",\n    \"ja\": \"稽古用迅刀\"\n  },\n  \"21020012\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020012_UI.T_IconWeapon21020012_UI\",\n    \"rank\": 2,\n    \"type\": 2,\n    \"en\": \"Tyro Sword\",\n    \"desc\": \"The birth of revolutionary tides. A sword designed for novice Resonators. Contains a power not to be underestimated under its simple outlook.\",\n    \"atk\": 275,\n    \"sub\": \"ATK\",\n    \"ko\": \"태초의 직검\",\n    \"zh\": \"原初迅刀·鸣雨\",\n    \"ja\": \"原初の迅刀・雨鳴\"\n  },\n  \"21020013\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020013_UI.T_IconWeapon21020013_UI\",\n    \"rank\": 3,\n    \"type\": 2,\n    \"en\": \"Sword of Night\",\n    \"desc\": \"May victory prevail the lasting night. In addition to the sworn oath of protection, this sword also represents the ambition of those brave souls.\",\n    \"atk\": 325,\n    \"sub\": \"ATK\",\n    \"ko\": \"흑야의 직검 · 흑뢰\",\n    \"zh\": \"暗夜迅刀·黑闪\",\n    \"ja\": \"暗夜の迅刀・黒閃\"\n  },\n  \"21020015\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020015_UI.T_IconWeapon21020015_UI\",\n    \"rank\": 5,\n    \"type\": 2,\n    \"en\": \"Emerald of Genesis\",\n    \"desc\": \"Pay heed: the frigid blade reveals an icy current, amalgamating into a whirlpool of thoughts. Use this powerful sequence to effortlessly crush your enemies with the Sword.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"천년의 회류\",\n    \"zh\": \"千古洑流\",\n    \"ja\": \"千古の湖水\"\n  },\n  \"21020016\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020016_UI.T_IconWeapon21020016_UI\",\n    \"rank\": 5,\n    \"type\": 2,\n    \"en\": \"Blazing Brilliance\",\n    \"desc\": \"Forged from the very essence and feathers of a legendary bird, this weapon blazes with an intensity that bathes the world in its luminous glow. With each fiery surge, it consumes all in its path, leaving nothing but ashes in its wake.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. DMG\",\n    \"ko\": \"솟아오르는 화염\",\n    \"zh\": \"赫奕流明\",\n    \"ja\": \"赫く燃ゆる流光\"\n  },\n  \"21020017\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020019_UI.T_IconWeapon21020019_UI\",\n    \"rank\": 4,\n    \"type\": 2,\n    \"en\": \"Somnoire Anchor\",\n    \"desc\": \"An anchor once used by Ivory Gatekeeper to stabilize the Somnoire.\\nHowever, it now looks different ever since Ivory Gatekeeper transformed into a white cat...\",\n    \"atk\": 462,\n    \"sub\": \"ATK\",\n    \"ko\": \"마음의 닻\",\n    \"zh\": \"心之锚\",\n    \"ja\": \"心の錨\"\n  },\n  \"21020023\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020023_UI.T_IconWeapon21020023_UI\",\n    \"rank\": 3,\n    \"type\": 2,\n    \"en\": \"Originite: Type II\",\n    \"desc\": \"To create new Tacetite weapons, the Huaxu Academy designed this test Sword for technical verification. Its main feature is healing through attacks, improving the physical abilities of Resonators while exhibiting impressive weapon performance.\",\n    \"atk\": 325,\n    \"sub\": \"ATK\",\n    \"ko\": \"원능의 직검 · 견습II\",\n    \"zh\": \"源能迅刀·测贰\",\n    \"ja\": \"本源迅刀・試作弐\"\n  },\n  \"21020024\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020024_UI.T_IconWeapon21020024_UI\",\n    \"rank\": 4,\n    \"type\": 2,\n    \"en\": \"Overture\",\n    \"desc\": \"An ascending crescendo. This enchanting sword effortlessly cuts through anything in its way, like a glorious prelude.\",\n    \"atk\": 338,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"행진의 서곡\",\n    \"zh\": \"行进序曲\",\n    \"ja\": \"行進オーバーチュア\"\n  },\n  \"21020026\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020017_UI.T_IconWeapon21020017_UI\",\n    \"rank\": 5,\n    \"type\": 2,\n    \"en\": \"Red Spring\",\n    \"desc\": \"A camellia bud silently unfurls. As promised, she holds this infinite world in bloom in her palms, where fine crimson vines twine around her fingertips.\\nThe dull ache, like sand scratching against the heart, is proof of your fateful encounter.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"날카로운 봄\",\n    \"zh\": \"裁春\",\n    \"ja\": \"春裁ち\"\n  },\n  \"21020034\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020034_UI.T_IconWeapon21020034_UI\",\n    \"rank\": 4,\n    \"type\": 2,\n    \"en\": \"Sword#18\",\n    \"desc\": \"An improved version of a mass-produced sword model developed in Huanglong. With its sleek blade and minimalist design, this sword is exclusively crafted for the skilled hands of seasoned warriors.\",\n    \"atk\": 388,\n    \"sub\": \"ATK\",\n    \"ko\": \"18형 직검 · 순간의 칼빛\",\n    \"zh\": \"瞬斩刀-18型\",\n    \"ja\": \"瞬斬刀＃18\"\n  },\n  \"21020036\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020025_UI.T_IconWeapon21020025_UI\",\n    \"rank\": 5,\n    \"type\": 2,\n    \"en\": \"Unflickering Valor\",\n    \"desc\": \"Blistering winds and crashing waves, the sea devours all. Only a lonely boat lamp stands alight!\\nOnwards! Towards the edge of the world you shall sail!\",\n    \"atk\": 412,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"흔들리지 않는 용기\",\n    \"zh\": \"不灭航路\",\n    \"ja\": \"エンドレスボヤージュ\"\n  },\n  \"21020043\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020043_UI.T_IconWeapon21020043_UI\",\n    \"rank\": 3,\n    \"type\": 2,\n    \"en\": \"Sword of Voyager\",\n    \"desc\": \"The Sword provided by the Pioneer Association for the voyagers is bright in color, not easy to lose, hard in texture, and can cope with various extreme environments for a long time, and is very popular among the group of explorers.\",\n    \"atk\": 300,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"수행자의 직검 · 행적\",\n    \"zh\": \"远行者迅刀·旅迹\",\n    \"ja\": \"探索者迅刀・旅路\"\n  },\n  \"21020044\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020044_UI.T_IconWeapon21020044_UI\",\n    \"rank\": 4,\n    \"type\": 2,\n    \"en\": \"Commando of Conviction\",\n    \"desc\": \"A weapon designed to commemorate the Midnight Rangers' courage. \\\"A thousand echoes carry the war's tale, as spirits unite in resounding gorges of valor.”\",\n    \"atk\": 412,\n    \"sub\": \"ATK\",\n    \"ko\": \"야귀의 신념\",\n    \"zh\": \"不归孤军\",\n    \"ja\": \"決死の一人戦\"\n  },\n  \"21020045\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon_21020045_UI.T_IconWeapon_21020045_UI\",\n    \"rank\": 5,\n    \"type\": 2,\n    \"en\": \"Laser Shearer\",\n    \"desc\": \"Spacetrek Collective \\\"Synth Armament\\\" Series\\nModel: SCSA-LHRi-SWD201052\\n\\nForged from compound technology that fuses Exostrider biomorphic components with Tacetite, this weapon offers two core features: frequency auto-adaptation and user binding. Its power scales directly with the wielder's Forte, growing sharper through dedicated Forte training.\\n\\nThe light patterns along the blade shift in response to the wielder's frequency fluctuations. Each strike expresses a refined intuition, a \\\"razor\\\" that cuts away unnecessary possibilities. Ideal for the signal catchers who discern the greater picture from the smallest details and make sound judgments.\",\n    \"atk\": 588,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"레이저 변형\",\n    \"zh\": \"镭射切变\",\n    \"ja\": \"レーザーの鋭剣\"\n  },\n  \"21020046\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020026_UI.T_IconWeapon21020026_UI\",\n    \"rank\": 5,\n    \"type\": 2,\n    \"en\": \"Bloodpact's Pledge\",\n    \"desc\": \"This weapon is a testament to the unbreakable blood pact: One shall never betray, never surrender, and fight until the last drop of blood is shed.\",\n    \"atk\": 588,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"혈맹의 약속\",\n    \"zh\": \"血誓盟约\",\n    \"ja\": \"血の盟約\"\n  },\n  \"21020053\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020053_UI.T_IconWeapon21020053_UI\",\n    \"rank\": 3,\n    \"type\": 2,\n    \"en\": \"Guardian Sword\",\n    \"desc\": \"The first Jinzhou Magistrate, in memory of the mysterious person who helped defend the border and build the city, created the Guardian series under his guidance. Today, it has become an indispensable cornerstone for the development of new weapons.\",\n    \"atk\": 300,\n    \"sub\": \"HP\",\n    \"ko\": \"수호자의 직검 · 기민\",\n    \"zh\": \"戍关迅刀·镇海\",\n    \"ja\": \"辺守迅刀・鎮護\"\n  },\n  \"21020056\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020056_UI.T_IconWeapon21020056_UI\",\n    \"rank\": 5,\n    \"type\": 2,\n    \"en\": \"Defier's Thorn\",\n    \"desc\": \"The surging tides force the crown of thorns upon the knight, out of which the knight forges this sword.\\nUnburdened by the crown, the knight waded through the roaring waves unwaveringly.\",\n    \"atk\": 412,\n    \"sub\": \"HP\",\n    \"ko\": \"숙명에 맞서는 관\",\n    \"zh\": \"不屈命定之冠\",\n    \"ja\": \"定めを覆す荊冠\"\n  },\n  \"21020064\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020064_UI.T_IconWeapon21020064_UI\",\n    \"rank\": 4,\n    \"type\": 2,\n    \"en\": \"Lunar Cutter\",\n    \"desc\": \"The Sword born from the aerial phenomenon. The forger integrates the feelings of witnessing the alien star into the weapon, making it look light and sharp, but it can exert the energy of breaking the sky and cutting iron like mud.\",\n    \"atk\": 412,\n    \"sub\": \"ATK\",\n    \"ko\": \"상승의 서녘\",\n    \"zh\": \"西升\",\n    \"ja\": \"倒錯の星\"\n  },\n  \"21020066\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020066_UI.T_IconWeapon21020066_UI\",\n    \"rank\": 5,\n    \"type\": 2,\n    \"en\": \"Emerald Sentence\",\n    \"desc\": \"Bamboo, hollow yet full; People, whole yet seldom true.\\nBamboo speaks without deceit, acts without conceit, seeks no vanity. Few ever measure up thus.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"푸른 의지\",\n    \"zh\": \"裁竹\",\n    \"ja\": \"破敵の鋭竹\"\n  },\n  \"21020074\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020074_UI.T_IconWeapon21020074_UI\",\n    \"rank\": 4,\n    \"type\": 2,\n    \"en\": \"Lumingloss\",\n    \"desc\": \"This Sword is a ceremonial weapon used in Huanglong's Magistrate Inauguration Ceremonies. The golden ginkgo leaf pattern symbolizes Huanglong's resilience, thriving in a world that has left it behind.\",\n    \"atk\": 388,\n    \"sub\": \"ATK\",\n    \"ko\": \"천공의 광경\",\n    \"zh\": \"飞景\",\n    \"ja\": \"万象変遷\"\n  },\n  \"21020076\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020076_UI.T_IconWeapon21020076_UI\",\n    \"rank\": 5,\n    \"type\": 2,\n    \"en\": \"Everbright Polestar\",\n    \"desc\": \"As you drift across the hushed sea of stars, stardust scatters beside you as time crumbles in your wake. All that remains is the unyielding loneliness, warped, diluted, and remade into the plumes of your wings.\\nThe universe sends you on a tribulation of silence, yet you travel on, repaying in radiance.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"영원한 샛별\",\n    \"zh\": \"永远的启明星\",\n    \"ja\": \"とこしえの明星\"\n  },\n  \"21020084\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020084_UI.T_IconWeapon21020084_UI\",\n    \"rank\": 4,\n    \"type\": 2,\n    \"en\": \"Endless Collapse\",\n    \"desc\": \"A prototype weapon designed by the Black Shores for elite combatants. This sword takes its name from the heart of a blazar—a galactic nucleus whose blinding radiance pierces the cosmos, shining unmistakably across billions of light years.\",\n    \"atk\": 462,\n    \"sub\": \"ATK\",\n    \"ko\": \"영원의 붕괴\",\n    \"zh\": \"永续坍缩\",\n    \"ja\": \"永遠を砕く重力崩壊\"\n  },\n  \"21020086\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020086_UI.T_IconWeapon21020086_UI\",\n    \"rank\": 5,\n    \"type\": 2,\n    \"en\": \"Frostburn\",\n    \"desc\": \"How keen a blade it takes to impale this unrelenting night?\\nShe presses ever forward for the answer, those unbound wishes roaring in her veins.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"서린 불꽃\",\n    \"zh\": \"灼霜\",\n    \"ja\": \"灼霜\"\n  },\n  \"21020094\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020094_UI.T_IconWeapon21020094_UI\",\n    \"rank\": 4,\n    \"type\": 2,\n    \"en\": \"Fables of Wisdom\",\n    \"desc\": \"This weapon draws its design inspiration from the play—Fables of Wisdom.\\nA wayfarer once carried this sword, who spun fables of wisdom, passing on insights in the form of witty jests. Keen ears listened to the stories for the truth, while shallow minds heard only amusing punchlines.\",\n    \"atk\": 462,\n    \"sub\": \"ATK\",\n    \"ko\": \"풍류의 우화시\",\n    \"zh\": \"风流的寓言诗\",\n    \"ja\": \"風刺のファブリオー\"\n  },\n  \"21020096\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020096_UI.T_IconWeapon21020096_UI\",\n    \"rank\": 5,\n    \"type\": 2,\n    \"en\": \"Azure of Heaven\",\n    \"desc\": \"Stay tuned\",\n    \"atk\": 588,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"아득히 푸른 하늘\",\n    \"zh\": \"天之苍苍\",\n    \"ja\": \"天つ蒼淵\"\n  },\n  \"21020104\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020104_UI.T_IconWeapon21020104_UI\",\n    \"rank\": 4,\n    \"type\": 2,\n    \"en\": \"Feather Edge\",\n    \"desc\": \"A Sword awarded to Gladiators of exceptional merit. Its engravings draw inspiration from Griffrexes—natural-born hunters and the first allies Septimontians found in this land. Their bond needs no words, radiant and pure, like the blazing sun that watches over all.\",\n    \"atk\": 412,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"예리한 날개깃\",\n    \"zh\": \"翼锋\",\n    \"ja\": \"鋭利な翼\"\n  },\n  \"21030011\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030011_UI.T_IconWeapon21030011_UI\",\n    \"rank\": 1,\n    \"type\": 3,\n    \"en\": \"Training Pistols\",\n    \"desc\": \"These pistols are designed specifically for training and teaching, offering only the basic features.\",\n    \"atk\": 250,\n    \"sub\": \"ATK\",\n    \"ko\": \"견습용 권총\",\n    \"zh\": \"教学佩枪\",\n    \"ja\": \"稽古用拳銃\"\n  },\n  \"21030012\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030012_UI.T_IconWeapon21030012_UI\",\n    \"rank\": 2,\n    \"type\": 3,\n    \"en\": \"Tyro Pistols\",\n    \"desc\": \"The inception of valiant venture. A pair of pistols designed for novice Resonators. Contains a power not to be underestimated under its simple outlook.\",\n    \"atk\": 275,\n    \"sub\": \"ATK\",\n    \"ko\": \"태초의 권총\",\n    \"zh\": \"原初佩枪·穿林\",\n    \"ja\": \"原初の拳銃・深森\"\n  },\n  \"21030013\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030013_UI.T_IconWeapon21030013_UI\",\n    \"rank\": 3,\n    \"type\": 3,\n    \"en\": \"Pistols of Night\",\n    \"desc\": \"May victory prevail the lasting night. This type of pistols not only carries the oath of protection but also contains the hope of rejuvenation.\",\n    \"atk\": 325,\n    \"sub\": \"ATK\",\n    \"ko\": \"흑야의 권총 · 흑성\",\n    \"zh\": \"暗夜佩枪·暗星\",\n    \"ja\": \"暗夜の拳銃・闇星\"\n  },\n  \"21030015\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030015_UI.T_IconWeapon21030015_UI\",\n    \"rank\": 5,\n    \"type\": 3,\n    \"en\": \"Static Mist\",\n    \"desc\": \"Grip the sleek frame and feel its cool surface as you aim down the sight. With a pull of the trigger, unleash a thick smoke barrage onto the battlefield with these powerful Pistols in your hands.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"부동의 안개\",\n    \"zh\": \"停驻之烟\",\n    \"ja\": \"不変の湖煙\"\n  },\n  \"21030016\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030017_UI.T_IconWeapon21030017_UI\",\n    \"rank\": 5,\n    \"type\": 3,\n    \"en\": \"The Last Dance\",\n    \"desc\": \"The radiant crystals, ever shattering and reshaping, beckon you into a treacherous dance, a gamble where life is the wager. Cortado, cortado... relentlessly draw each other in until all we can hear are our quivers. When the crimson finale arrives, remember, death comes for all.\",\n    \"atk\": 500,\n    \"sub\": \"Crit. DMG\",\n    \"ko\": \"죽음과 춤\",\n    \"zh\": \"死与舞\",\n    \"ja\": \"ラストダンス\"\n  },\n  \"21030023\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030023_UI.T_IconWeapon21030023_UI\",\n    \"rank\": 3,\n    \"type\": 3,\n    \"en\": \"Originite: Type III\",\n    \"desc\": \"To create new Tacetite weapons, the Huaxu Academy designed these test Pistols for technical verification. Their main feature is healing through attacks, improving the physical abilities of Resonators while exhibiting impressive weapon performance.\",\n    \"atk\": 325,\n    \"sub\": \"ATK\",\n    \"ko\": \"원능의 권총 · 견습III\",\n    \"zh\": \"源能佩枪·测叁\",\n    \"ja\": \"本源拳銃・試作参\"\n  },\n  \"21030024\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030024_UI.T_IconWeapon21030024_UI\",\n    \"rank\": 4,\n    \"type\": 3,\n    \"en\": \"Cadenza\",\n    \"desc\": \"An ascending crescendo. These pistols unleash bullets with the force of thunder, tearing through the heavens like a symphony of destruction.\",\n    \"atk\": 338,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"화려한 악곡\",\n    \"zh\": \"华彩乐段\",\n    \"ja\": \"華麗カテンツァ\"\n  },\n  \"21030026\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030026_UI.T_IconWeapon21030026_UI\",\n    \"rank\": 5,\n    \"type\": 3,\n    \"en\": \"Woodland Aria\",\n    \"desc\": \"All things exist within the lines of poetry. Every sound has its meters and rhymes.\\nThe forest's melodies ascend in spirals toward the moon's silvered grace, harmonized by the nightingales' chorus. When the final note falls and vanishes into the silent earth, a flawless chord echoes endlessly in the depths of this boundless realm.\",\n    \"atk\": 500,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"숲속의 아리아\",\n    \"zh\": \"林间的咏叹调\",\n    \"ja\": \"森のアリア\"\n  },\n  \"21030034\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030034_UI.T_IconWeapon21030034_UI\",\n    \"rank\": 4,\n    \"type\": 3,\n    \"en\": \"Pistols#26\",\n    \"desc\": \"The Huaxu Academy has developed practical, high-performance pistols based on previous source energy weapons, showcasing their meticulous research and aiming for excellence.\",\n    \"atk\": 388,\n    \"sub\": \"ATK\",\n    \"ko\": \"26형 권총 · 맹렬한 돌격\",\n    \"zh\": \"穿击枪-26型\",\n    \"ja\": \"穿撃銃＃26\"\n  },\n  \"21030036\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030036_UI.T_IconWeapon21030036_UI\",\n    \"rank\": 5,\n    \"type\": 3,\n    \"en\": \"Lux & Umbra\",\n    \"desc\": \"From darkness she seizes power, layering sins upon herself. To hunt. To kill. To deliver a relentless and fatal blow to all evil.\\nFrom the light she falls, with her vows etched in her mind. For the deceased. For the living. For her pistols' true targets.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. DMG\",\n    \"ko\": \"얽혀진 빛과 그림자\",\n    \"zh\": \"光影双生\",\n    \"ja\": \"ルクス＆アンブラ\"\n  },\n  \"21030043\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030043_UI.T_IconWeapon21030043_UI\",\n    \"rank\": 3,\n    \"type\": 3,\n    \"en\": \"Pistols of Voyager\",\n    \"desc\": \"The Pistols provided by the Pioneer Association for the far walkers, with bright colors, not easy to lose, hard texture, can cope with various extreme environments for a long time, and is very popular among the explorer group.\",\n    \"atk\": 300,\n    \"sub\": \"ATK\",\n    \"ko\": \"수행자의 권총 · 통찰\",\n    \"zh\": \"远行者佩枪·洞察\",\n    \"ja\": \"探索者拳銃・洞察\"\n  },\n  \"21030044\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030044_UI.T_IconWeapon21030044_UI\",\n    \"rank\": 4,\n    \"type\": 3,\n    \"en\": \"Undying Flame\",\n    \"desc\": \"A weapon designed to commemorate the Midnight Rangers' dedication. \\\"Let my body ablaze, flames dance to banish all evil's haze.\\\"\",\n    \"atk\": 412,\n    \"sub\": \"ATK\",\n    \"ko\": \"불멸의 성화\",\n    \"zh\": \"无眠烈火\",\n    \"ja\": \"燃え尽きぬ焔\"\n  },\n  \"21030045\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon_21030045_UI.T_IconWeapon_21030045_UI\",\n    \"rank\": 5,\n    \"type\": 3,\n    \"en\": \"Phasic Homogenizer\",\n    \"desc\": \"Spacetrek Collective \\\"Synth Armament\\\" Series\\nModel: SCSA-LHRi-PSTL325052\\n\\nForged from compound technology that fuses Exostrider biomorphic components with Tacetite, this weapon offers two core features: frequency auto-adaptation and user binding. Its power scales directly with the wielder's Forte, growing sharper through dedicated Forte training.\\n\\nProjectile and rifling are spectrally tuned to unleash a potent frequency disturbance on impact, exposing and shattering a target's weak points. It serves as both a benchmark of precision and a weapon that pierces with unwavering focus. Ideal for insight bearers who act with deliberate caution and perceive what others overlook.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. DMG\",\n    \"ko\": \"위상의 파동\",\n    \"zh\": \"相位涟漪\",\n    \"ja\": \"フェーズのさざ波\"\n  },\n  \"21030046\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030046_UI.T_IconWeapon21030046_UI\",\n    \"rank\": 5,\n    \"type\": 3,\n    \"en\": \"Spectrum Blaster\",\n    \"desc\": \"Prismatic light dances at her fingertips, arcs of color carving radiant trails.\\nEvery rushing hue converges upon her aim, and at last, she reaches a sky where nothing lies beyond her sight.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"스펙트럼 블래스터\",\n    \"zh\": \"溢彩荧辉\",\n    \"ja\": \"スペクトル・ブラスター\"\n  },\n  \"21030053\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030053_UI.T_IconWeapon21030053_UI\",\n    \"rank\": 3,\n    \"type\": 3,\n    \"en\": \"Guardian Pistols\",\n    \"desc\": \"The first Jinzhou Magistrate, in memory of the mysterious person who helped defend the border and build the city, created the Guardian series under his guidance. Now, it has become the cornerstone of the development of new weapons.\",\n    \"atk\": 300,\n    \"sub\": \"ATK\",\n    \"ko\": \"수호자의 권총 · 용맹\",\n    \"zh\": \"戍关佩枪·平云\",\n    \"ja\": \"辺守拳銃・平定\"\n  },\n  \"21030056\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030056_UI.T_IconWeapon21030056_UI\",\n    \"rank\": 5,\n    \"type\": 3,\n    \"en\": \"Spectral Trigger\",\n    \"desc\": \"A neon glow gilds this cage of memory, same as always. \\nI wander along old city streets, spilling unspoken words to shadows long gone.\\nI wanna stay lost here, but the dream is fraying. I must wake up.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. DMG\",\n    \"ko\": \"스펙트럴 트리거\",\n    \"zh\": \"蜃影\",\n    \"ja\": \"スペクトラル・トリガー\"\n  },\n  \"21030064\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030064_UI.T_IconWeapon21030064_UI\",\n    \"rank\": 4,\n    \"type\": 3,\n    \"en\": \"Novaburst\",\n    \"desc\": \"Pistols born from the strange phenomena in the sky. The forger infused the weapon with the feelings from witnessing the strange star, making it look hollow and light, yet extremely stable, with the power of thunder when it fires.\",\n    \"atk\": 412,\n    \"sub\": \"ATK\",\n    \"ko\": \"천공의 순간\",\n    \"zh\": \"飞逝\",\n    \"ja\": \"疾走の星\"\n  },\n  \"21030066\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030066_UI.T_IconWeapon21030066_UI\",\n    \"rank\": 5,\n    \"type\": 3,\n    \"en\": \"Skull Thrasher\",\n    \"desc\": \"Because death is a reality that cannot be undone, there's no reason to hesitate.\\nShe pulls the trigger, shattering this haunting reverie.\",\n    \"atk\": 500,\n    \"sub\": \"Crit. DMG\",\n    \"ko\": \"스컬 스래셔\",\n    \"zh\": \"碎骨\",\n    \"ja\": \"スカル・ポッパー\"\n  },\n  \"21030074\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030074_UI.T_IconWeapon21030074_UI\",\n    \"rank\": 4,\n    \"type\": 3,\n    \"en\": \"Thunderbolt\",\n    \"desc\": \"These Pistols are ceremonial weapons used in Huanglong's Magistrate Inauguration Ceremonies. The golden ginkgo leaf pattern symbolizes Huanglong's resilience, thriving in a world that has left it behind.\",\n    \"atk\": 388,\n    \"sub\": \"ATK\",\n    \"ko\": \"뇌전\",\n    \"zh\": \"奔雷\",\n    \"ja\": \"迸る雷霆\"\n  },\n  \"21030084\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030084_UI.T_IconWeapon21030084_UI\",\n    \"rank\": 4,\n    \"type\": 3,\n    \"en\": \"Relativistic Jet\",\n    \"desc\": \"A prototype weapon designed by the Black Shores for elite combatants. These pistols take their name from the incessant course of destruction of a blazar—a galactic nucleus whose blinding radiance pierces the cosmos, shining unmistakably across billions of light years.\",\n    \"atk\": 462,\n    \"sub\": \"ATK\",\n    \"ko\": \"역설의 격류\",\n    \"zh\": \"悖论喷流\",\n    \"ja\": \"悖理を説く宇宙ジェット\"\n  },\n  \"21030094\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030094_UI.T_IconWeapon21030094_UI\",\n    \"rank\": 4,\n    \"type\": 3,\n    \"en\": \"Romance in Farewell\",\n    \"desc\": \"This weapon draws its design inspiration from the play—Romance in Farewell.\\nThis pistol was once the symbol of the aspiration for repute, the weight of unrequited love, and the tremors of unspoken words. When the trigger is pulled, and the curtain drops, it turns into a long farewell and a sign of lingering sorrow in the heart of the bereaved.\",\n    \"atk\": 462,\n    \"sub\": \"ATK\",\n    \"ko\": \"작별의 로맨스\",\n    \"zh\": \"叙别的罗曼史\",\n    \"ja\": \"別れのメロス\"\n  },\n  \"21030104\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030104_UI.T_IconWeapon21030104_UI\",\n    \"rank\": 4,\n    \"type\": 3,\n    \"en\": \"Solar Flame\",\n    \"desc\": \"A pair of Pistols awarded to Gladiators of exceptional merit. Its engravings draw inspiration from Griffrexes—natural-born hunters and the first allies Septimontians found in this land. Their bond needs no words, radiant and pure, like the blazing sun that watches over all.\",\n    \"atk\": 412,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"태양 불꽃\",\n    \"zh\": \"阳焰\",\n    \"ja\": \"紅炎\"\n  },\n  \"21040011\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040011_UI.T_IconWeapon21040011_UI\",\n    \"rank\": 1,\n    \"type\": 4,\n    \"en\": \"Training Gauntlets\",\n    \"desc\": \"These gauntlets are designed specifically for training and teaching, offering only the basic features.\",\n    \"atk\": 250,\n    \"sub\": \"ATK\",\n    \"ko\": \"견습용 권갑\",\n    \"zh\": \"教学臂铠\",\n    \"ja\": \"稽古用手甲\"\n  },\n  \"21040012\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040012_UI.T_IconWeapon21040012_UI\",\n    \"rank\": 2,\n    \"type\": 4,\n    \"en\": \"Tyro Gauntlets\",\n    \"desc\": \"The dawn of enduring endeavor. A pair of gauntlets designed for novice Resonators. Contains a power not to be underestimated under its simple outlook.\",\n    \"atk\": 275,\n    \"sub\": \"ATK\",\n    \"ko\": \"태초의 권갑\",\n    \"zh\": \"原初臂铠·磐岩\",\n    \"ja\": \"原初の手甲・磐石\"\n  },\n  \"21040013\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040013_UI.T_IconWeapon21040013_UI\",\n    \"rank\": 3,\n    \"type\": 4,\n    \"en\": \"Gauntlets of Night\",\n    \"desc\": \"May victory prevail the lasting night. In addition to the sworn oath of protection, these gauntlets also commemorate the sacrifices of those brave souls.\",\n    \"atk\": 325,\n    \"sub\": \"ATK\",\n    \"ko\": \"흑야의 권갑 · 흑빛\",\n    \"zh\": \"暗夜臂铠·夜芒\",\n    \"ja\": \"暗夜の手甲・夜灯\"\n  },\n  \"21040015\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040015_UI.T_IconWeapon21040015_UI\",\n    \"rank\": 5,\n    \"type\": 4,\n    \"en\": \"Abyss Surges\",\n    \"desc\": \"The Gauntlets pulsate with an uncontrollable force, emanating unspeakable anger from the depths of the unknown lake. As you don them, unleash your fury on helpless enemies. Feel its power surge through you.\",\n    \"atk\": 588,\n    \"sub\": \"ATK\",\n    \"ko\": \"물결의 파동\",\n    \"zh\": \"擎渊怒涛\",\n    \"ja\": \"怒涛の湖音\"\n  },\n  \"21040016\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040016_UI.T_IconWeapon21040016_UI\",\n    \"rank\": 5,\n    \"type\": 4,\n    \"en\": \"Verity's Handle\",\n    \"desc\": \"Crafted with the lost art from the Court of Savantae, these gauntlets are solid and unbreakable, despite their lightweight materials. They are no tools of violence or aggression, but instruments for unraveling puzzles and pursuing the truth.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"팔방의 천추\",\n    \"zh\": \"诸方玄枢\",\n    \"ja\": \"万端の枢機\"\n  },\n  \"21040023\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040023_UI.T_IconWeapon21040023_UI\",\n    \"rank\": 3,\n    \"type\": 4,\n    \"en\": \"Originite: Type IV\",\n    \"desc\": \"To create new Tacetite weapons, the Huaxu Academy designed these test Gauntlets for technical verification. Their main feature is healing through attacks, improving the physical abilities of Resonators while exhibiting impressive weapon performance.\",\n    \"atk\": 300,\n    \"sub\": \"Crit. DMG\",\n    \"ko\": \"원능의 권갑 · 견습IV\",\n    \"zh\": \"源能臂铠·测肆\",\n    \"ja\": \"本源手甲・試作肆\"\n  },\n  \"21040024\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040024_UI.T_IconWeapon21040024_UI\",\n    \"rank\": 4,\n    \"type\": 4,\n    \"en\": \"Marcato\",\n    \"desc\": \"A descending adagio. These gauntlets pulsate with the power of surging waves, shattering anything in their path like a deadly hymn.\",\n    \"atk\": 338,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"바람의 악센트\",\n    \"zh\": \"呼啸重音\",\n    \"ja\": \"狂乱マルカート\"\n  },\n  \"21040026\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040018_UI.T_IconWeapon21040018_UI\",\n    \"rank\": 5,\n    \"type\": 4,\n    \"en\": \"Tragicomedy\",\n    \"desc\": \"The joys and sorrows of life dance in an endless circle; Pain and tears shift in an instant into a carnival.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"희비극\",\n    \"zh\": \"悲喜剧\",\n    \"ja\": \"トラジコメーディア\"\n  },\n  \"21040034\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040034_UI.T_IconWeapon21040034_UI\",\n    \"rank\": 4,\n    \"type\": 4,\n    \"en\": \"Gauntlets#21D\",\n    \"desc\": \"Huaxu Academy has independently improved and developed the first set of highly practical high-performance Gauntlets based on the previous source energy weapons, representing the care and warmth of the Academy, stable and lasting.\",\n    \"atk\": 388,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"21형 권갑 · 아이언 팬텀\",\n    \"zh\": \"钢影拳-21丁型\",\n    \"ja\": \"鋼影拳＃21・四番\"\n  },\n  \"21040036\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040019_UI.T_IconWeapon21040019_UI\",\n    \"rank\": 5,\n    \"type\": 4,\n    \"en\": \"Blazing Justice\",\n    \"desc\": \"It heralds justice, precise and inexorable as a clock's toll. All sins are cleansed in flame, dissipating like night beneath the dawn's gaze.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. DMG\",\n    \"ko\": \"불빛의 심판\",\n    \"zh\": \"焰光裁定\",\n    \"ja\": \"焔光の裁き\"\n  },\n  \"21040043\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040043_UI.T_IconWeapon21040043_UI\",\n    \"rank\": 3,\n    \"type\": 4,\n    \"en\": \"Gauntlets of Voyager\",\n    \"desc\": \"The Gauntlets provided by the Pioneer Association for the far walkers, with bright colors, not easy to lose, hard texture, can cope with various extreme environments for a long time, and are very popular among the explorer group.\",\n    \"atk\": 325,\n    \"sub\": \"DEF\",\n    \"ko\": \"수행자의 권갑 · 파괴\",\n    \"zh\": \"远行者臂铠·破障\",\n    \"ja\": \"探索者手甲・排除\"\n  },\n  \"21040044\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040044_UI.T_IconWeapon21040044_UI\",\n    \"rank\": 4,\n    \"type\": 4,\n    \"en\": \"Amity Accord\",\n    \"desc\": \"A weapon designed to commemorate the Midnight Rangers' comradeship. \\\"Thin garments yield to icy moons, while armor withstands the chill of stars.\\\"\",\n    \"atk\": 338,\n    \"sub\": \"DEF\",\n    \"ko\": \"전우의 의리\",\n    \"zh\": \"袍泽之固\",\n    \"ja\": \"金鉄の志\"\n  },\n  \"21040045\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon_21040045_UI.T_IconWeapon_21040045_UI\",\n    \"rank\": 5,\n    \"type\": 4,\n    \"en\": \"Pulsation Bracer\",\n    \"desc\": \"Spacetrek Collective \\\"Synth Armament\\\" Series\\nModel: SCSA-LHRi-GNTL522152\\n\\nForged from compound technology that fuses Exostrider biomorphic components with Tacetite, this weapon offers two core features: frequency auto-adaptation and user binding. Its power scales directly with the wielder's Forte, growing sharper through dedicated Forte training.\\n\\nThe armor's spectrum shifts as it restores kinetic energy. The Pulsation Bracer predicts the wearer's stance to amplify the stored reactive torque and release it in a single, instantaneous surge—a decisive force delivered at the critical moment. Ideal for the barrier breachers who advance with steady resolve and stand unshaken under pressure.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"격동의 조력\",\n    \"zh\": \"脉冲协臂\",\n    \"ja\": \"パルスの機腕\"\n  },\n  \"21040046\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040046_UI.T_IconWeapon21040046_UI\",\n    \"rank\": 5,\n    \"type\": 4,\n    \"en\": \"Moongazer's Sigil\",\n    \"desc\": \"By what means do all things endure? By light and heat, by matter and word, by the mechanics of converging chances, by the soft dissolution into silence, by a moment that mimics the eternal... All things rise and fall in endless rhythm, each bearing its meaning. As for hers, it lies here within her grasp.\",\n    \"atk\": 500,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"세상 만물의 진리\",\n    \"zh\": \"万物持存的注释\",\n    \"ja\": \"万物を書き留める月相\"\n  },\n  \"21040053\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040053_UI.T_IconWeapon21040053_UI\",\n    \"rank\": 3,\n    \"type\": 4,\n    \"en\": \"Guardian Gauntlets\",\n    \"desc\": \"The first Jinzhou Magistrate, in memory of the mysterious person who helped defend the border and build the city, created the Guardian series under his guidance. Now, it has become the cornerstone of the development of new weapons.\",\n    \"atk\": 300,\n    \"sub\": \"DEF\",\n    \"ko\": \"수호자의 권갑 · 강력\",\n    \"zh\": \"戍关臂铠·拔山\",\n    \"ja\": \"辺守手甲・造設\"\n  },\n  \"21040056\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon_21040056_UI.T_IconWeapon_21040056_UI\",\n    \"rank\": 5,\n    \"type\": 4,\n    \"en\": \"Daybreaker's Spine\",\n    \"desc\": \"Those are not ridges of the mountains, but the spine of the earth, carrying the night. They protrude from the abdomen of darkness. From the incision spills the light of new life.\\nYour shadow was nailed to the dying night. With the breaking dawn, your flesh shall rise.\\nLet it knock open every door of denial.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"한낮의 의지\",\n    \"zh\": \"白昼之脊\",\n    \"ja\": \"デイブレイカースパイン\"\n  },\n  \"21040064\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040064_UI.T_IconWeapon21040064_UI\",\n    \"rank\": 4,\n    \"type\": 4,\n    \"en\": \"Hollow Mirage\",\n    \"desc\": \"The Gauntlets born from the strange phenomenon in the sky. The blacksmith infused the feelings of witnessing the strange star into the weapon, making it look hollow and light, but it can exert a tremendous momentum while protecting the user.\",\n    \"atk\": 412,\n    \"sub\": \"ATK\",\n    \"ko\": \"천공의 역행\",\n    \"zh\": \"骇行\",\n    \"ja\": \"驚異の星\"\n  },\n  \"21040066\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040066_UI.T_IconWeapon21040066_UI\",\n    \"rank\": 5,\n    \"type\": 4,\n    \"en\": \"Solsworn Ciphers\",\n    \"desc\": \"Sunlight gathers. The answer is made plain.\\nWhat must be done awaits. The Rein is in your hand.\\nStep forward, toward the sunlit end.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. DMG\",\n    \"ko\": \"솔스원의 해석\",\n    \"zh\": \"昭日译注\",\n    \"ja\": \"ソル・スウォーンの注釈\"\n  },\n  \"21040074\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040074_UI.T_IconWeapon21040074_UI\",\n    \"rank\": 4,\n    \"type\": 4,\n    \"en\": \"Stonard\",\n    \"desc\": \"These Gauntlets are ceremonial weapons used in Huanglong's Magistrate Inauguration Ceremonies. The golden ginkgo leaf pattern symbolizes Huanglong's resilience, thriving in a world that has left it behind.\",\n    \"atk\": 412,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"황금 권갑\",\n    \"zh\": \"金掌\",\n    \"ja\": \"黄金の拳\"\n  },\n  \"21040084\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040084_UI.T_IconWeapon21040084_UI\",\n    \"rank\": 4,\n    \"type\": 4,\n    \"en\": \"Celestial Spiral\",\n    \"desc\": \"A prototype weapon designed by the Black Shores for elite combatants. These gauntlets take their name from the tragic demise of a blazar—a galactic nucleus whose blinding radiance pierces the cosmos, shining unmistakably across billions of light years.\",\n    \"atk\": 462,\n    \"sub\": \"ATK\",\n    \"ko\": \"천상의 나선\",\n    \"zh\": \"尘云旋臂\",\n    \"ja\": \"星屑が捩れる渦巻腕\"\n  },\n  \"21040094\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040094_UI.T_IconWeapon21040094_UI\",\n    \"rank\": 4,\n    \"type\": 4,\n    \"en\": \"Legend of Drunken Hero\",\n    \"desc\": \"This weapon draws its design inspiration from the play—Legend of Drunken Hero.\\nFrom the cup flows a liquid that grants courage and strength, empowering the hero to defy fate and turn the tide with his gauntlets. Yet in this intoxicating delight lies peril—dulled senses become the hero's undoing as enemies close in. Thus, in those wine-stained pages, one always read about triumphs followed by defeats.\",\n    \"atk\": 462,\n    \"sub\": \"ATK\",\n    \"ko\": \"만취의 영웅지\",\n    \"zh\": \"酩酊的英雄志\",\n    \"ja\": \"酩酊のエポス\"\n  },\n  \"21040104\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040104_UI.T_IconWeapon21040104_UI\",\n    \"rank\": 4,\n    \"type\": 4,\n    \"en\": \"Aether Strike\",\n    \"desc\": \"A pair of Gauntlets awarded to Gladiators of exceptional merit. Its engravings draw inspiration from Griffrexes—natural-born hunters and the first allies Septimontians found in this land. Their bond needs no words, radiant and pure, like the blazing sun that watches over all.\",\n    \"atk\": 412,\n    \"sub\": \"Crit. DMG\",\n    \"ko\": \"거침없는 비상\",\n    \"zh\": \"凌空\",\n    \"ja\": \"舞い上がる大空\"\n  },\n  \"21050011\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050011_UI.T_IconWeapon21050011_UI\",\n    \"rank\": 1,\n    \"type\": 5,\n    \"en\": \"Training Rectifier\",\n    \"desc\": \"This rectifier is designed specifically for training and teaching, offering only the basic features.\",\n    \"atk\": 250,\n    \"sub\": \"ATK\",\n    \"ko\": \"견습용 증폭기\",\n    \"zh\": \"教学音感仪\",\n    \"ja\": \"稽古用増幅器\"\n  },\n  \"21050012\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050012_UI.T_IconWeapon21050012_UI\",\n    \"rank\": 2,\n    \"type\": 5,\n    \"en\": \"Tyro Rectifier\",\n    \"desc\": \"The origin of universal genesis. A Rectifier designed for novice Resonators. Contains a power not to be underestimated under its simple outlook.\",\n    \"atk\": 275,\n    \"sub\": \"ATK\",\n    \"ko\": \"태초의 증폭기\",\n    \"zh\": \"原初音感仪·听浪\",\n    \"ja\": \"原初の増幅器・波音\"\n  },\n  \"21050013\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050013_UI.T_IconWeapon21050013_UI\",\n    \"rank\": 3,\n    \"type\": 5,\n    \"en\": \"Rectifier of Night\",\n    \"desc\": \"May victory prevail the lasting night. In addition to the sworn oath of protection, this rectifier signifies the confidence of those fighting souls.\",\n    \"atk\": 325,\n    \"sub\": \"ATK\",\n    \"ko\": \"흑야의 증폭기 · 흑광\",\n    \"zh\": \"暗夜矩阵·暝光\",\n    \"ja\": \"暗夜の増幅器・冥光\"\n  },\n  \"21050015\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050015_UI.T_IconWeapon21050015_UI\",\n    \"rank\": 5,\n    \"type\": 5,\n    \"en\": \"Cosmic Ripples\",\n    \"desc\": \"Take hold of the frozen Rectifier, a powerful tool imbued with the energy of the celestial lake. Let it lead you to ultimate knowledge and vanquish all obstacles in your path.\",\n    \"atk\": 500,\n    \"sub\": \"ATK\",\n    \"ko\": \"파도의 기록\",\n    \"zh\": \"漪澜浮录\",\n    \"ja\": \"栄枯の湖岸\"\n  },\n  \"21050016\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050016_UI.T_IconWeapon21050016_UI\",\n    \"rank\": 5,\n    \"type\": 5,\n    \"en\": \"Stringmaster\",\n    \"desc\": \"The puppet's palm unfurls, releasing deadly strings with a menacing hum. The air crackles, immobilizing foes and leaving unhealable scars from rapid electric bolts.\",\n    \"atk\": 500,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"꼭두각시의 손\",\n    \"zh\": \"掣傀之手\",\n    \"ja\": \"糸繰りの奇術\"\n  },\n  \"21050017\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050017_UI.T_IconWeapon21050017_UI\",\n    \"rank\": 4,\n    \"type\": 5,\n    \"en\": \"Call of the Abyss\",\n    \"desc\": \"Held by the keepers of this land, this scepter was once a symbol of dominion over its people and the architectural marvels they achieved.\\nHowever, it has long lost its luster, and its grandeur blends into the ripples of the pipe organ melodies of Rinascita.\",\n    \"atk\": 338,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"심해의 메아리\",\n    \"zh\": \"渊海回声\",\n    \"ja\": \"海淵のリフレイン\"\n  },\n  \"21050023\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050023_UI.T_IconWeapon21050023_UI\",\n    \"rank\": 3,\n    \"type\": 5,\n    \"en\": \"Originite: Type V\",\n    \"desc\": \"To create new Tacetite weapons, the Huaxu Academy designed this test Rectifier for technical verification. Its main feature is healing through attacks, improving the physical abilities of Resonators while exhibiting impressive weapon performance.\",\n    \"atk\": 300,\n    \"sub\": \"HP\",\n    \"ko\": \"원능의 증폭기 · 견습V\",\n    \"zh\": \"源能音感仪·测五\",\n    \"ja\": \"本源増幅器・試作伍\"\n  },\n  \"21050024\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050024_UI.T_IconWeapon21050024_UI\",\n    \"rank\": 4,\n    \"type\": 5,\n    \"en\": \"Variation\",\n    \"desc\": \"A descending adagio. This rectifier opens up an insightful window into the situation, changing the tune of the intense battle concerto.\",\n    \"atk\": 338,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"판타지 변주\",\n    \"zh\": \"奇幻变奏\",\n    \"ja\": \"奇妙バリエーション\"\n  },\n  \"21050026\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050026_UI.T_IconWeapon21050026_UI\",\n    \"rank\": 5,\n    \"type\": 5,\n    \"en\": \"Rime-Draped Sprouts\",\n    \"desc\": \"An artist's seal adorned with rimed sprouts. It is stamped on numerous paintings that capture mountains and ravines in expressive, mesmerizing strokes. The tender sprouts symbolize the perpetual blossoming of artistic marvels.\",\n    \"atk\": 500,\n    \"sub\": \"Crit. DMG\",\n    \"ko\": \"옥수 비단\",\n    \"zh\": \"琼枝冰绡\",\n    \"ja\": \"氷華の雅印\"\n  },\n  \"21050027\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050036_UI.T_IconWeapon21050036_UI\",\n    \"rank\": 4,\n    \"type\": 5,\n    \"en\": \"Ocean's Gift\",\n    \"desc\": \"To fishers, the sea is their field of harvest. Harvest means hope.\",\n    \"atk\": 462,\n    \"sub\": \"ATK\",\n    \"ko\": \"바다의 선물\",\n    \"zh\": \"大海的馈赠\",\n    \"ja\": \"海の恩恵\"\n  },\n  \"21050034\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050034_UI.T_IconWeapon21050034_UI\",\n    \"rank\": 4,\n    \"type\": 5,\n    \"en\": \"Rectifier#25\",\n    \"desc\": \"An improved version of a Rectifier prototype from Huanglong's next-gen weaponry project. This device is characterized by its powerful, purified output and sound that resonates with the decisively strong-willed.\",\n    \"atk\": 338,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"25형 증폭기 · 울림의 멜로디\",\n    \"zh\": \"鸣动仪-25型\",\n    \"ja\": \"鳴動機＃25\"\n  },\n  \"21050036\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050027_UI.T_IconWeapon21050027_UI\",\n    \"rank\": 5,\n    \"type\": 5,\n    \"en\": \"Stellar Symphony\",\n    \"desc\": \"A rectifier bearing an energy core that simulates the lifecycle of stars—an infinite loop that originates from a singularity and ends in explosive demise. The celestial debris collides in thunderous rumbles, heralding the birth of a new star.\",\n    \"atk\": 412,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"뭇별의 교향곡\",\n    \"zh\": \"星序协响\",\n    \"ja\": \"星々のコンチェルト\"\n  },\n  \"21050043\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050043_UI.T_IconWeapon21050043_UI\",\n    \"rank\": 3,\n    \"type\": 5,\n    \"en\": \"Rectifier of Voyager\",\n    \"desc\": \"The Rectifier provided by the Pioneer Association for the explorers, with bright colors, not easy to lose, hard texture, can cope with various extreme environments for a long time, is very popular among the explorers.\",\n    \"atk\": 300,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"수행자의 증폭기 · 탐색\",\n    \"zh\": \"远行者矩阵·探幽\",\n    \"ja\": \"探索者増幅器・発見\"\n  },\n  \"21050044\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050044_UI.T_IconWeapon21050044_UI\",\n    \"rank\": 4,\n    \"type\": 5,\n    \"en\": \"Jinzhou Keeper\",\n    \"desc\": \"A weapon designed to commemorate the Midnight Rangers' vigilant protection of Jinzhou. \\\"Cast your gaze towards the north, where the city's silhouette fades, its gates veiled by the tranquil rain.\\\"\",\n    \"atk\": 388,\n    \"sub\": \"ATK\",\n    \"ko\": \"금주의 수호\",\n    \"zh\": \"今州守望\",\n    \"ja\": \"今州の衛士\"\n  },\n  \"21050045\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon_21050045_UI.T_IconWeapon_21050045_UI\",\n    \"rank\": 5,\n    \"type\": 5,\n    \"en\": \"Boson Astrolabe\",\n    \"desc\": \"Spacetrek Collective \\\"Synth Armament\\\" Series\\nModel: SCSA-LHRi-RCTF325062\\n\\nForged from compound technology that fuses Exostrider biomorphic components with Tacetite, this weapon offers two core features: frequency auto-adaptation and user binding. Its power scales directly with the wielder's Forte, growing sharper through dedicated Forte training.\\n\\nComposed of a spectral ring-lens and layered glass plates, the device captures even the faintest frequency shifts. Like a guiding star that leads the seekers through a sea of tangled thoughts, it maps possibilities before they take shape. Ideal for the path observers who perceive the world a step ahead.\",\n    \"atk\": 525,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"보손 관측기\",\n    \"zh\": \"玻色星仪\",\n    \"ja\": \"ボゾンの観測器\"\n  },\n  \"21050046\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050029_UI.T_IconWeapon21050029_UI\",\n    \"rank\": 5,\n    \"type\": 5,\n    \"en\": \"Luminous Hymn\",\n    \"desc\": \"\\\"The Sentinel's grace, how sweet thou art. Our home was lost, but found at last. With twigs between my beaks, I brave the waves. Bound by love, we're crowned with holy light.\\\"\",\n    \"atk\": 500,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"광휘의 찬송가\",\n    \"zh\": \"和光回唱\",\n    \"ja\": \"光のハルモニア\"\n  },\n  \"21050053\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050053_UI.T_IconWeapon21050053_UI\",\n    \"rank\": 3,\n    \"type\": 5,\n    \"en\": \"Guardian Rectifier\",\n    \"desc\": \"The first Jinzhou Magistrate, in memory of the mysterious person who helped defend the border and build the city, created the Guardian series under his guidance. Now, it has become the cornerstone of the development of new weapons.\",\n    \"atk\": 325,\n    \"sub\": \"ATK\",\n    \"ko\": \"수호자의 증폭기 · 모략\",\n    \"zh\": \"戍关音感仪·留光\",\n    \"ja\": \"辺守増幅器・伝承\"\n  },\n  \"21050056\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050030_UI.T_IconWeapon21050030_UI\",\n    \"rank\": 5,\n    \"type\": 5,\n    \"en\": \"Whispers of Sirens\",\n    \"desc\": \"From the sea, some see stars, some catch the moon, and some hear countless whispers and murmurs.\\n\\nThose murmurs seep into her venom, flowing through every winding river.\\n\\nIn the end, the murmurs envelope, like the bell of a jellyfish, like the sea.\",\n    \"atk\": 500,\n    \"sub\": \"Crit. DMG\",\n    \"ko\": \"바다의 속삭임\",\n    \"zh\": \"海的呢喃\",\n    \"ja\": \"深海の囁き\"\n  },\n  \"21050064\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050064_UI.T_IconWeapon21050064_UI\",\n    \"rank\": 4,\n    \"type\": 5,\n    \"en\": \"Comet Flare\",\n    \"desc\": \"A Rectifier born born from an aerial phenomenon. Capturing the essence of an alien star, its design is delicate and lightweight, yet it remains sturdy and adaptable.\",\n    \"atk\": 412,\n    \"sub\": \"HP\",\n    \"ko\": \"굉음\",\n    \"zh\": \"异度\",\n    \"ja\": \"変化の星\"\n  },\n  \"21050066\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050066_UI.T_IconWeapon21050066_UI\",\n    \"rank\": 5,\n    \"type\": 5,\n    \"en\": \"Lethean Elegy\",\n    \"desc\": \"I am not there. I do not die.\\nI shall be death's companion—with euphoric delights I drown my fear, with the coming days I trade for the past.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"잊혀진 피안의 슬픈 악장\",\n    \"zh\": \"幽冥的忘忧章\",\n    \"ja\": \"幽冥の忘憂曲\"\n  },\n  \"21050074\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050074_UI.T_IconWeapon21050074_UI\",\n    \"rank\": 4,\n    \"type\": 5,\n    \"en\": \"Augment\",\n    \"desc\": \"This Rectifier is a ceremonial weapon used in Huanglong's Magistrate Inauguration Ceremonies. The golden ginkgo leaf pattern symbolizes Huanglong's resilience, thriving in a world that has left it behind.\",\n    \"atk\": 412,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"청음\",\n    \"zh\": \"清音\",\n    \"ja\": \"清らかな音\"\n  },\n  \"21050076\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050076_UI.T_IconWeapon21050076_UI\",\n    \"rank\": 5,\n    \"type\": 5,\n    \"en\": \"Forged Dwarf Star\",\n    \"desc\": \"Dream dissolves like foam, leaving only a silent white dwarf.\\nYet the light that once swept the cosmos remains.\\nShe waits in quiescence until her borrowed light finds its way back to the main sequence star.\",\n    \"atk\": 500,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"위조된 작은별\",\n    \"zh\": \"赝作的矮星\",\n    \"ja\": \"偽物の矮星\"\n  },\n  \"21050084\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050084_UI.T_IconWeapon21050084_UI\",\n    \"rank\": 4,\n    \"type\": 5,\n    \"en\": \"Fusion Accretion\",\n    \"desc\": \"A prototype weapon designed by the Black Shores for elite combatants. This rectifier takes its name from the devastating might of a blazar—a galactic nucleus whose blinding radiance pierces the cosmos, shining unmistakably across billions of light years.\",\n    \"atk\": 462,\n    \"sub\": \"ATK\",\n    \"ko\": \"융합의 원반\",\n    \"zh\": \"核熔星盘\",\n    \"ja\": \"コアが溶融する降着円盤\"\n  },\n  \"21050086\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050086_UI.T_IconWeapon21050086_UI\",\n    \"rank\": 5,\n    \"type\": 5,\n    \"en\": \"Freeze Frame\",\n    \"desc\": \"I remember the sunset spilling down, birds and insects threading their small songs through the greenhouse.\\nI remember the quiet nights, my lone steps echoing the crescent moon's curve.\\nI am my own freeze frame. I am my own afterimage.\",\n    \"atk\": 588,\n    \"sub\": \"Crit. Rate\",\n    \"ko\": \"프리즈 프레임\",\n    \"zh\": \"存帧\",\n    \"ja\": \"フリーズフレーム\"\n  },\n  \"21050094\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050094_UI.T_IconWeapon21050094_UI\",\n    \"rank\": 4,\n    \"type\": 5,\n    \"en\": \"Waltz in Masquerade\",\n    \"desc\": \"This weapon draws its design inspiration from the play—Waltz in Masquerade.\\nA waltz is a dance of spectacle and masquerade, where the grand symphony drowns whispered secrets and swirling dresses conceal the exchange of letters and promises. The dancers speak a silent language, as smooth and precise as the perfect resonance of a rectifier.\",\n    \"atk\": 462,\n    \"sub\": \"ATK\",\n    \"ko\": \"허위의 왈츠\",\n    \"zh\": \"虚饰的华尔兹\",\n    \"ja\": \"虚飾のワルツ\"\n  },\n  \"21050096\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050096_UI.T_IconWeapon21050096_UI\",\n    \"rank\": 5,\n    \"type\": 5,\n    \"en\": \"Dew Imbiber\",\n    \"desc\": \"Stay tuned\",\n    \"atk\": 412,\n    \"sub\": \"Energy Regen\",\n    \"ko\": \"노을에 깃든 이슬\",\n    \"zh\": \"栖霞饮露\",\n    \"ja\": \"夕霞の飲露\"\n  },\n  \"21050104\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050104_UI.T_IconWeapon21050104_UI\",\n    \"rank\": 4,\n    \"type\": 5,\n    \"en\": \"Radiant Dawn\",\n    \"desc\": \"A Rectifier awarded to Gladiators of exceptional merit. Its engravings draw inspiration from Griffrexes—natural-born hunters and the first allies Septimontians found in this land. Their bond needs no words, radiant and pure, like the blazing sun that watches over all.\",\n    \"atk\": 412,\n    \"sub\": \"Crit. DMG\",\n    \"ko\": \"눈부신 빛\",\n    \"zh\": \"曜光\",\n    \"ja\": \"弾む輝き\"\n  },\n  \"80080001\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020019_UI.T_IconWeapon21020019_UI\",\n    \"rank\": 4,\n    \"type\": 2,\n    \"en\": \"Projection: Somnoire Anchor\",\n    \"desc\": \"A projection that reshapes the sword into a cute table knife. \\nIt was once an anchor used by Ivory Gatekeeper to stabilize the Somnoire.\\nHowever, it now looks different ever since Ivory Gatekeeper transformed into a white cat...\",\n    \"ko\": \"투영 · 마음의 닻\",\n    \"zh\": \"投影·心之锚\",\n    \"ja\": \"投影・心の錨\"\n  },\n  \"80080002\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010027_UI.T_IconWeapon21010027_UI\",\n    \"rank\": 3,\n    \"type\": 1,\n    \"en\": \"Projection: Formless Broadblade\",\n    \"desc\": \"A conceptual projection, a transparent broadblade as if it were made of nothing.\\nIn Somnoire, a weapon's form is but a mirage, while its purpose—a tool of war—holds true as ever.\",\n    \"ko\": \"투영 · 심상의 대검\",\n    \"zh\": \"投影·心象长刃\",\n    \"ja\": \"投影・心象長刃\"\n  },\n  \"80080003\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21020018_UI.T_IconWeapon21020018_UI\",\n    \"rank\": 3,\n    \"type\": 2,\n    \"en\": \"Projection: Formless Sword\",\n    \"desc\": \"A conceptual projection, a transparent sword as if it were made of nothing.\\nIn Somnoire, a weapon's form is but a mirage, while its purpose—a tool of war—holds true as ever.\",\n    \"ko\": \"투영 · 심상의 직검\",\n    \"zh\": \"投影·心象迅刀\",\n    \"ja\": \"投影・心象迅刀\"\n  },\n  \"80080004\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21030016_UI.T_IconWeapon21030016_UI\",\n    \"rank\": 3,\n    \"type\": 3,\n    \"en\": \"Projection: Formless Pistol\",\n    \"desc\": \"A conceptual projection, a transparent pistol as if it were made of nothing.\\nIn Somnoire, a weapon's form is but a mirage, while its purpose—a tool of war—holds true as ever.\",\n    \"ko\": \"투영 · 심상의 권총\",\n    \"zh\": \"投影·心象佩枪\",\n    \"ja\": \"投影・心象拳銃\"\n  },\n  \"80080005\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21040017_UI.T_IconWeapon21040017_UI\",\n    \"rank\": 3,\n    \"type\": 4,\n    \"en\": \"Projection: Formless Gauntlets\",\n    \"desc\": \"A conceptual projection, transparent gauntlets as if they were made of nothing.\\nIn Somnoire, a weapon's form is but a mirage, while its purpose—a tool of war—holds true as ever.\",\n    \"ko\": \"투영 · 심상의 권갑\",\n    \"zh\": \"投影·心象臂铠\",\n    \"ja\": \"投影・心象手甲\"\n  },\n  \"80080006\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050028_UI.T_IconWeapon21050028_UI\",\n    \"rank\": 3,\n    \"type\": 5,\n    \"en\": \"Projection: Formless Rectifier\",\n    \"desc\": \"A conceptual projection, a transparent rectifier as if it were made of nothing.\\nIn Somnoire, a weapon's form is but a mirage, while its purpose—a tool of war—holds true as ever.\",\n    \"ko\": \"투영 · 심상의 증폭기\",\n    \"zh\": \"投影·心象音感仪\",\n    \"ja\": \"投影・心象増幅器\"\n  },\n  \"80080007\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21010017_UI.T_IconWeapon21010017_UI\",\n    \"rank\": 5,\n    \"type\": 1,\n    \"en\": \"Projection - Peach Blossom\",\n    \"desc\": \"A projection of Broadblade - Ages of Harvest, as lovely as peach blossoms.\\nWith spring's arrival, the temporal pearl on the hilt turns pink, dyed by petals, like the heart of a girl in bloom.\",\n    \"ko\": \"투영 · 복숭아꽃이 피는 날\",\n    \"zh\": \"投影·桃夭灼灼\",\n    \"ja\": \"投影・桃の夭夭たる\"\n  },\n  \"80080008\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconWeapon/T_IconWeapon21050036_UI.T_IconWeapon21050036_UI\",\n    \"rank\": 4,\n    \"type\": 5,\n    \"en\": \"Projection: Ocean's Gift\",\n    \"desc\": \"To fishers, the sea is their field of harvest. Harvest means hope.\",\n    \"ko\": \"투영 · 바다의 선물\",\n    \"zh\": \"投影·大海的馈赠\",\n    \"ja\": \"投影・海の恩恵\"\n  }\n}"}</script>
			<script type="application/json" data-sveltekit-fetched data-url="https://static.nanoka.cc/ww/3.5.3/en/character/1409.json" data-ttl="120">{"status":200,"statusText":"OK","headers":{},"body":"{\n  \"id\": 1409,\n  \"rarity\": 5,\n  \"weapon\": 2,\n  \"element\": 4,\n  \"tag\": {\n    \"2\": {\n      \"name\": \"Main Damage Dealer\",\n      \"desc\": \"Powerful damage dealer\",\n      \"icon\": \"/Game/Aki/UI/UIResources/Common/Atlas/RoleLabel/SP_RoleLabelA2.SP_RoleLabelA2\",\n      \"color\": \"ff8441\"\n    },\n    \"8\": {\n      \"name\": \"Traction\",\n      \"desc\": \"Pulls targets within range towards a specific position\",\n      \"icon\": \"/Game/Aki/UI/UIResources/Common/Atlas/RoleLabel/SP_RoleLabelC1.SP_RoleLabelC1\",\n      \"color\": \"77adff\"\n    },\n    \"15\": {\n      \"name\": \"Aero DMG Amplification\",\n      \"desc\": \"Provides Aero DMG Amplification for a specific Resonator in the team\",\n      \"icon\": \"/Game/Aki/UI/UIResources/Common/Atlas/RoleLabel/SP_RoleLabelD1.SP_RoleLabelD1\",\n      \"color\": \"ff7777\"\n    },\n    \"24\": {\n      \"name\": \"Aero Erosion\",\n      \"desc\": \"Utilizes Aero Erosion for combat advantage\",\n      \"icon\": \"/Game/Aki/UI/UIResources/Common/Atlas/RoleLabel/SP_RoleLabelE3.SP_RoleLabelE3\",\n      \"color\": \"dd77ff\"\n    }\n  },\n  \"name\": \"Cartethyia\",\n  \"nick_name\": \"Cartethyia\",\n  \"desc\": \"Cartethyia, the wandering knight who travels across \u003Cte href=850096>Rinascita\u003C/te>. Formerly known as the Blessed Maiden, the vessel of Divinity, and the Queen of Gale and Tide, she went by the name Fleurdelys. Now, she is simply a free and unfettered wandering knight.\",\n  \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconRoleHead256/T_IconRoleHead256_40_UI.T_IconRoleHead256_40_UI\",\n  \"background\": \"/Game/Aki/UI/UIResources/Common/Image/IconRolePile/T_IconRole_Pile_katixiya_UI.T_IconRole_Pile_katixiya_UI\",\n  \"background_stand\": \"/Game/Aki/UI/UIResources/UiActivity/Image/RoleHalfBody/T_ActivityRoleOntrialHalfBodyKatixiya.T_ActivityRoleOntrialHalfBodyKatixiya\",\n  \"chara_info\": {\n    \"birth\": \"Unknown\",\n    \"sex\": \"Female\",\n    \"country\": \"Rinascita\",\n    \"influence\": \"Ragunna\",\n    \"info\": \"Cartethyia, the wandering knight who travels across \u003Cte href=850096>Rinascita\u003C/te>. Formerly known as the Blessed Maiden, the vessel of Divinity, and the Queen of Gale and Tide, she went by the name Fleurdelys. Now, she is simply a free and unfettered wandering knight.\",\n    \"talent_name\": \"Feathered Tempest\",\n    \"talent_doc\": \"[Resonance Evaluation Report RA-X006]\\nTime of Awakening unknown. It is speculated that due to the opposing influences exerted by \u003Cte href=850083>Sentinel\u003C/te> \u003Cte href=850105>Imperator\u003C/te> and \u003Cte href=850074>Threnodian\u003C/te> Leviathan, Cartethyia's Spectrum Performance data exceeds standard values by ▇▇▇▇▇▇▇. Calculation of accurate data using existing methods is impossible.\\n\\nAnalysis of test samples has revealed a non-convergent \u003Cte href=850067>Rabelle's Curve\u003C/te> with a pronounced periodic waveform. Therefore, Cartethyia is classified as a \u003Cte href=850068>Congenital Resonator\u003C/te>.\\n\\n\u003Ci>System has classified Cartethyia as a unique subject. Her file has been sealed under a special project group. Access clearance: ▇▇▇\u003C/i>\\n\u003Ci>System will conduct continuous monitoring of Cartethyia.\u003C/i>\",\n    \"talent_certification\": \"Cartethyia's waveform graph shows elliptical fluctuations with a stable Time Domain. Peak values between upper and lower bounds show intermittent upward trends, with peak values not yet exceeding critical threshold. No abnormal fluctuations have been observed.\\n\\nExternal and internal forces within Cartethyia have nearly reached a state of fusion.\\n\\nResonant Criticality: High. Stability is high with minimal risk of \u003Cte href=850073>Overclocking\u003C/te>. However, it is worth noting that Cartethyia's body shows unstable power fluctuations when distant from \u003Cte href=850096>Rinascita\u003C/te>.\\n\\nCartethyia is a rare individual who has undergone a Second Awakening, enabling her to transition freely between two forms. It must be emphasized that this is not a case of Overclocking, but rather the precise invocation of her powers.\\n\\n\u003Ci>Note from a Bloom Bearer: When Miss Cartethyia... No, wait, Fleurdelys, demonstrated her powers, the storm nearly tore the entire simulation apart! My, oh, my. We gotta take extra precautions with our next test!\u003C/i>\",\n    \"cv_name_cn\": \"Yun Hezhui\",\n    \"cv_name_jp\": \"Asakawa Yuu\",\n    \"cv_name_ko\": \"Bae Ha Gyoung\",\n    \"cv_name_en\": \"Amanda Elizabeth Rischel\"\n  },\n  \"stories\": [\n    {\n      \"title\": \"The Knight's Faded Hours\",\n      \"content\": \"A retired dramatist enjoys telling a certain story: Once upon a time, in the countryside of Egla Town, there was a wandering knight. With sword in hand, he journeyed far and wide in search of a legendary giant. A giant who stood as tall as a windmill, with arms long and slender like its blades. Time after time, the wandering knight fought with everything he had against the giant, but the giant never spoke a word, only ever waving its arms, rendering the knight's attacks futile.\\n\\nSome mocked the knight's foolishness, some pitied his delusion. After all, that so-called giant was nothing more than a windmill, and his battles were but a fantasy. But the countryside's most mischievous girl saw it differently.\\n\\nShe found herself a knight's helmet and begged the dramatist for a small wooden sword. \\\"To fight for such a giant,\\\" she said, \\\"he must possess a heart of pure nobility.\\\" And so, she too wished to be like the knight, to seek out the giant who destroyed homes and scattered livestock, and see that the Golden Thiefbats lurking along roads could no longer steal a single treasure from travelers.\\n\\nRiding flamboyantly on a Tumbleyak, she raced through the wheat fields. The world had never felt so vast. This was where the Blessed Maiden's legends began. Through the fields, through the festivities, and into the Inverted Tower.\\n\\nIt would be a grand quest.\"\n    },\n    {\n      \"title\": \"Steadfast in the Final Dance\",\n      \"content\": \"This quest continued for some time.\\n\\nIn those unnoticed moments, the girl visited every field in Whisperwind Haven. Mischievous and free-spirited by nature, she even stole sips of sacramental wine under the watch of guards, danced away on high platforms, and turned a solemn ceremony into complete madness. Even the Order's prison walls became her personal canvas.\\n\\n\\\"She's really the most rambunctious girl in the countryside,\\\" people would say. \\\"A serious fate isn't one she's meant for, and no wall, no matter how strong, could ever keep her from spreading her wings.\\\"\\n\\nYet to everyone's surprise, she was chosen by the Divinity.\\n\\nWhy her? Some questioned. She was only the daughter of an official, a peasant girl lacking discipline! Not a drop of noble blood ran in her veins. How would she ever come to understand the hierarchies of the world?\\n\\n\\\"She is the one!\\\" others exclaimed. \\\"She listens to our sorrows and replaces them with joy! If anyone is worthy of Divinity's crown, it is her.\\\"\\n\\nBut what would the one bearing the name Fleurdelys think of all this? Before the ceremony to receive her holy name, in a dull and stuffy hall, she performed her final dance as Cartethyia.\\n\\nWas she confused by Divinity's whispers? Fearful of an uncertain future? Confident that she could wield the sacred sword?\\n\\nShe simply kept the name \\\"Cartethyia\\\" hidden deep within her heart. Farewell, grain fields swaying in the breeze, and the Tumbleyaks roaming so free. In a world so vast, someone must take up the sword. Someone must bind themselves in thorns. Someone must accept the weight of responsibilities. Someone—\\n\\nMust become Fleurdelys, the guardian of \u003Cte href=850096>Rinascita\u003C/te>.\"\n    },\n    {\n      \"title\": \"Hesitation Amid Gale and Tide\",\n      \"content\": \"As Fleurdelys, she must march to war with a sword in hand.\\n\\nFor this, she learned everything she could. She studied Order scriptures and honed her combat skills. She listened to the voices of the people, devoting herself to fulfilling their wishes. When someone prayed for good health, she arranged for the delivery of valuable medicines. When someone sought peace, she would listen to their confessions, taking in their past sorrows. When a \u003Cte href=850081>Tacet Discord\u003C/te> Outbreak occurred, she drew her sword and crushed it in its infancy. These actions were no different from what she had done back home.\\n\\nThe only difference was that she was no longer facing a small village or familiar faces. Most of those seeking her help were strangers, and she understood that each of them was like a small lamp. The more she helped, the more they would shine in the night sky of \u003Cte href=850096>Rinascita\u003C/te>.\\n\\nYet, the world was so vast, and the Order was far from flawless, as the books had claimed. The nobility were fixated only on their own interests, and self-proclaimed devout Acolytes merely performed their faith, turning a blind eye to the people's cries. She saw nobles who boasted of their good hearts while stuffing their pockets, refusing to hear the pleas of those suffering.\\n\\nAt times like these, all she could do was tighten her grip on her sword.\\n\\nShe experienced doubt, disturbance, and disappointment. And because of this, her grip only tightened as she faced the Dark Tide—She would question the Divinity. She must.\\n\\nNo matter the answer that awaited her, Fleurdelys was ready for it.\\n\\nWith this resolve, she walked into the tower. Alone.\"\n    },\n    {\n      \"title\": \"Yet Within Solitude\",\n      \"content\": \"She seemed to have dreamed for a very long time.\\n\\nIn that dream, hymns and praises poured toward her in endless waves, engulfing her. She raised her sword to cut through the waves again and again, battling the giant sea creature in those waters. She fought with all her might. Even when the waters turned into blades sharp enough to slice flesh, she did not take a single step back.\\n\\nWhen she opened her eyes, she found herself alone in an unfamiliar place.\\n\\nWhere was she? What was her purpose? Who was she? Questions whose answers had slipped beyond memory.\\n\\nShe wandered the tower in search of what was lost. She even tried to find a way into the central tower to seek answers. But after exploring every corner she could reach, she found nothing but herself. There was no \\\"other\\\" existence. She was the only soul there.\\n\\nSo she began to converse with herself. She stitched dolls from scraps. She invented stories.\\n\\nCuriously, the fog of her memories began to lift, little by little, beneath her fingertips.\\n\\nShe made one doll of a sword-wielding girl and another of a sea monster. She muttered a few lines of dialogue between them, then paused. She knew this story. She'd heard it before. The \u003Cano=wandering knight>sword-wielding girl\u003C/ano> had journeyed to confront the terrifying \u003Cano=sea monster>giant\u003C/ano> of legend. Time and time again, she fought it with everything she had. \\n\\nNo matter what the \u003Cano=wandering knight>sword-wielding girl\u003C/ano> was fighting for, she understood one thing—\\n\\nEach time she raised her sword, she did not care about her past. She only cared about what needed to be done at that very moment.\\n\\nAnd if that were true, then losing her memories was no great loss. In a world so vast, she would find herself again.\\n\\nAnd when that time comes, whether she turns out to be the warrior or the monster, it's an answer she would be willing to accept.\"\n    },\n    {\n      \"title\": \"The Wandering Knight Marches To Freedom\",\n      \"content\": \"Inside a small restaurant in Whisperwind Haven, a young girl orders several Laurus Salads. While waiting for her food, she quietly sneaks into the kitchen, following the head chef and carefully observing her culinary techniques.\\n\\n\\\"Hmm. A few more of these Viscum Berries, please. Ah, yes, yes. And another!\\\"\\n\\n\\\"You can add more honey as well... Yes, thank you!\\\"\\n\\n\\\"And where did you come from, little rascal? If you're waiting for your food, you need to wait outside.\\\" The head chef puts down her utensils and looks up, pausing in astonishment. The girl before her seems familiar, but she can't quite place a name.\\n\\n\\\"I-I'm so sorry! I just wanted to pick up some of your cooking skills. I have a long journey ahead of me, and I might not have the fortune to come across a restaurant serving such delicious food again. If my apology isn't enough, I'll chop some firewood for you instead.\\\"\\n\\n\\\"Is this your first time eating at our restaurant? I have a feeling I've seen you before.\\\" The head chef hands the curious girl her food. \\n\\n\\\"Was it from that stained glass window...?\\\"\\n\\n\\\"This isn't my first time, actually! But it's been quite a while since I last visited,\\\" the girl replies, taking the plate. \\\"Allow me to introduce myself. My name is Cartethyia. I'm a wandering knight preparing for a new quest. If you ever need help, do let me know.\\\"\\n\\n\\\"I just had to try this before I begin my journey!\\\" The girl scoops up a spoonful of salad and takes a bite.\\n\\nIn a world so vast, a salad full of Viscum Berries made the beginning of her journey feel just right.\\n\\n\\\"How delicious.\\\" She praises from her heart.\"\n    }\n  ],\n  \"voices\": [\n    {\n      \"type\": 1,\n      \"title\": \"Thoughts: I\",\n      \"content\": \"Here, this is for you. Be careful, it's just been baked and is still hot. But trust me, it tastes best when you tear into it right away. This little trick is just for you, since we're good friends. Coming back home feels different, even though my house has been empty for so long. But the bread from that bakery still tastes the same. The last time I had it was when I won the \u003Cte href=850103>Laurel\u003C/te> as the Blessed Maiden. Back then, the town was covered in posters of me dancing at the \u003Cte href=850102>Carnevale\u003C/te>. That dance... would you like to see it?\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_toplayer01.play_favor_word_katixiya_sys_toplayer01\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Thoughts: II\",\n      \"content\": \"...Back in the tower, I felt uneasy just hearing you mention it... but actually hearing a play about my life was utterly surreal. If you hadn't stopped me, I'd have jumped out of my seat and run away! When I was younger, I used to daydream about being the heroine in one of those adventure stories. But now that it's actually happening, it's nothing like I imagined. The poets of \u003Cte href=850097>Ragunna\u003C/te> have added so many embellishments. If they'd checked my scripture grades from the seminary, they wouldn't have written those extravagant lines about me.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_toplayer02.play_favor_word_katixiya_sys_toplayer02\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Thoughts: III\",\n      \"content\": \"We meet again, Righteous One. Heh... So, how was I? Was I helpful? I'm no longer the lost, confused girl I once was. Now, I stand ready to fight alongside you. This is the promise I made, and to honor it, I will sharpen this sword even further. Though it may never come to pass, if fate wills it... I will defeat you as I vowed... and set you right.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_toplayer03.play_favor_word_katixiya_sys_toplayer03\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Thoughts: IV\",\n      \"content\": \"After merging Fleurdelys, I finally understood why I hesitated when \\\"I\\\" first saw you as I danced on the water's surface. When you first arrived in \u003Cte href=850096>Rinascita\u003C/te>, \\\"I\\\" could feel your presence. A strange joy surged through \\\"me.\\\" Deep within the tower, \\\"I\\\" wondered… what would the one who could both destroy and liberate \\\"me\\\" look like? Would you be a righteous knight, as in the legends, slaying \\\"me\\\" with your sword? I couldn't choose how I was born, but I could choose how I would die. And that, in itself, is a kind of happiness. You gave \\\"me\\\" that chance, \\\"Godkiller.\\\" And the ending of this story is more beautiful than I ever imagined.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_toplayer04.play_favor_word_katixiya_sys_toplayer04\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Thoughts: V\",\n      \"content\": \"The turmoil in \u003Cte href=850096>Rinascita\u003C/te> is far from over. Born of mankind's ill will, Leviathan may yet rise from the raging currents of civilization's soul... I cannot stray too far from this land. Everyone has their limits, often bound by responsibility, and true freedom remains elusive. You and I are no exceptions. But the sword you wield was forged from our shared frequencies. It is a mark of our bond and a manifestation of my power. As long as you carry it, I will be your sword and faithful companion... ever present in the depths of your gaze.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_toplayer05.play_favor_word_katixiya_sys_toplayer05\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Cartethyia's Hobby\",\n      \"content\": \"I love seeing people smile! That’s why I adore the \u003Cte href=850102>Carnevale\u003C/te> and any lively occasion. The cheerful crowds, the joy in the air, the laughter filling every corner... I just love being part of it. Whenever that happens, I want to blend into the crowd, singing, dancing, and spinning hand in hand with everyone...\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_taste.play_favor_word_katixiya_sys_taste\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Cartethyia's Trouble\",\n      \"content\": \"...Whenever I transform into Fleurdelys for battle, I have to constantly remind myself—My manners, my tone... everything has to be composed and solemn... Ah! It's actually really hard, you know? Truly!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_worry.play_favor_word_katixiya_sys_worry\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Favorite Food\",\n      \"content\": \"My favorite dish is Laurus Salad, of course. It's not only delicious, it's also healthy. I'd gladly eat it for three meals straight. Hm? Oh, I wouldn't get tired of it, not at all! The sweet Viscum Berries coated in dressing have the perfect crunch and flavor. It's easy to prepare, and even I can make the dish taste just right.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_foodlike.play_favor_word_katixiya_sys_foodlike\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Disliked Food\",\n      \"content\": \"I'm not really fond of fish. I don't know why, but every time I try to eat it, I just can't, even my fingertips seem to resist. When I was little, my parents used to say I was picky. Living by the sea, there aren't many food choices, especially if you don't like fish. But I've never been able to get over this instinctive aversion.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_foodhate.play_favor_word_katixiya_sys_foodhate\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Ideals\",\n      \"content\": \"My current dream? I want to be a wandering knight, just like the ones in the stories passed down in Egla Town. A knight of righteousness, always ready to draw my sword in the face of injustice, then riding off in the most heroic way! Before the Order chose me to be the Blessed Maiden, that was my deepest wish. But now... that title no longer belongs to me, and it never will again. I must step away from the adoring gazes and become a nameless guardian. To that end, I've been revisiting the survival skills I once learned during my days roaming the hills. Oh, do you think you could help me come up with a new knight's name?\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_dream.play_favor_word_katixiya_sys_dream\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Chat: I\",\n      \"content\": \"Haultir is my sword and my very first companion. In the stories passed down in Egla Town, every true knight always has a sword they hold dear, so when I got mine, I was overwhelmed with joy. Though I've wielded many swords since, Haultir remains the most precious. Every time I grip the hilt, I can feel… that my heart hasn't changed. Even if it was a heart born from lies, I know that, when given the choice, I will always choose \\\"to save.\\\"\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_story_obj.play_favor_word_katixiya_sys_story_obj\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Chat: II\",\n      \"content\": \"I was born from the \u003Cte href=850074>Threnodian\u003C/te>'s curse and malice. It made me wear the crown, bathe in the glory of the Blessed Maiden, surrounded by the reverence of countless faithfuls. I fought against Its false faith, day after day, until I was finally overwhelmed by the tides... In that long slumber, those familiar prayers no longer felt warm, but cold and sorrowful. At one point, I thought I'd never want to hear them again. But after you saved me from the tower, I secretly visited \u003Cte href=850097>Ragunna\u003C/te> City… Oh, then I knew, I've never resented the prayers of those longing for happiness. And to ensure these pure voices aren't twisted, there's still much I need to do, and can do.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_story_exp.play_favor_word_katixiya_sys_story_exp\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"About Cantarella\",\n      \"content\": \"I… took away the brilliant future she was meant to have. The future of being the \u003Cte href=850083>Sentinel\u003C/te>'s true Blessed Maiden. All the goodwill and hopes placed upon me, and the power I now possess… all of it should have belonged to Cantarella. Yet, she never seemed bothered by it. Someone as mature as her must have already found her own path within the \u003Cte href=850094>Fisalia\u003C/te> family. But still, I'll always remember that I owe her so much… so much.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_about_kanteleila.play_favor_word_katixiya_sys_about_kanteleila\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"About Phoebe\",\n      \"content\": \"That girl has a kind and gentle heart. Duties aside, she always does her best to be there for others. Honestly, when it comes to knowledge of the Order's doctrines, I'm nowhere near as good as Phoebe. It's because of so many true and faithful believers like her, I find it difficult to reveal the truth to the people of \u003Cte href=850097>Ragunna\u003C/te>. People turn to faith for many reasons, not just out of devotion to the \u003Cte href=850083>Sentinel\u003C/te>. To unveil such unsettling truths would bring forth countless difficult choices and challenges...\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_about_feibi.play_favor_word_katixiya_sys_about_feibi\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"About Carlotta\",\n      \"content\": \"As the daughter of \u003Cte href=850101>Montelli\u003C/te>, she has really brought fresh ideas to the city. If this island were to stay isolated, the air would grow stifling. The people of \u003Cte href=850097>Ragunna\u003C/te> need new ships, new horizons, and new discoveries. I'm not very skilled in business matters, though. My nanny in the Order always said I didn't even know how to haggle... If I ever get the chance, I'd love to learn a few tricks from Miss Carlotta!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_about_kelaita.play_favor_word_katixiya_sys_about_kelaita\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"About Ciaccona\",\n      \"content\": \"When I was a child, I used to beg the bards passing through town to sing me stories of knights. After I was freed from the tower, I wandered through a field one day, and the wind carried a piece of beautiful music to me. I stood beneath a tree in the distance, listening as Ciaccona sang a new poem, one with the melody of Egla Town's folk songs… In the blink of an eye, noon had already given way to dusk.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_about_xiakong.play_favor_word_katixiya_sys_about_xiakong\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"About Lupa\",\n      \"content\": \"The nature of the \u003Cte href=850074>Threnodian\u003C/te>'s power to converge often makes me appear dangerous and unsettling after battle, but Lupa has never once recoiled. She never treats me as more or less than I am, and she has never distanced herself. She is honest, tenacious, and unwavering in her care of her friends. Even though I'm shorter than her when not in my Fleurdelys form, I still feel that I should take on the role of the \\\"older sister\\\" in our friendship.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_about_lupa.play_favor_word_katixiya_sys_about_lupa\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Birthday Wishes\",\n      \"content\": \"Happy Birthday, {PlayerName}! You're probably wondering why I brought you here. Just look at the clouds, the soaring birds, the Inverted Tower, and the golden glow of the morning sun... As long as you hold my hand, I can guide you to float above the sea like this. It's fascinating, isn't it? Later, when the sun sinks into the ocean, the view will be even more mesmerizing. I used to stare at this every day from the tower, and I grew weary of it. But now, everything feels different, all because of you. I'm not the true Maiden. I don't have the power to grant blessings, but I still want to offer you my best wishes. May your heart's deepest desire come true.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_birthcele.play_favor_word_katixiya_sys_birthcele\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Idle: I\",\n      \"content\": \"Today's story is... the great battle between a righteous knight and the wicked \u003Cte href=850074>Threnodian\u003C/te>! The victor is—Cartethyia the Knight!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_idle_idle01.play_favor_word_katixiya_idle_idle01\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Idle: II\",\n      \"content\": \"Smells so good...\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_idle_idle02.play_favor_word_katixiya_idle_idle02\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Idle: III\",\n      \"content\": \"Time for a little nap... It's... It's just a dream...\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_idle_idle03.play_favor_word_katixiya_idle_idle03\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Self-Introduction\",\n      \"content\": \"Cartethyia, now a wandering knight. The \u003Cte href=850074>Threnodian\u003C/te>'s malicious creation, the Order's unsuspecting \u003Cte href=850103>Laureate\u003C/te>, the defier lost in the tides of fate... These titles, once portrayed in poems and books, have long since slipped from my grasp. As for what lies ahead... let’s explore it together,  \\\"Swordbearer.\\\"\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_introduction.play_favor_word_katixiya_sys_introduction\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Greeting\",\n      \"content\": \"The crown of winds... has been engulfed by the sea. Tell me, are you the one who summoned this blade?\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_gacha.play_favor_word_katixiya_sys_gacha\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Join Team: I\",\n      \"content\": \"Now begins the knight's story!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_jointeam_01.play_favor_word_katixiya_sys_jointeam_01\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Join Team: II\",\n      \"content\": \"This sword shall follow your will.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_jointeam_02.play_favor_word_katixiya_sys_jointeam_02\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Join Team: III\",\n      \"content\": \"Ready to venture forth together?\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_jointeam_03.play_favor_word_katixiya_sys_jointeam_03\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Ascension: I\",\n      \"content\": \"My swordsmanship has reached new heights!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_rankup01.play_favor_word_katixiya_sys_rankup01\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Ascension: II\",\n      \"content\": \"Can you feel it? The frequency of the wind... it's resonating between us.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_rankup02.play_favor_word_katixiya_sys_rankup02\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Ascension: III\",\n      \"content\": \"During my studies at the seminary, I knew that to uphold justice, I would need to work harder and sacrifice more than others to overcome the shadows that sought to destroy it.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_rankup03.play_favor_word_katixiya_sys_rankup03\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Ascension: IV\",\n      \"content\": \"The power within me once terrified me. I wondered how monstrous I'd become if it consumed me... But such terrors have started to fade, with you by my side.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_rankup04.play_favor_word_katixiya_sys_rankup04\"\n    },\n    {\n      \"type\": 1,\n      \"title\": \"Ascension: V\",\n      \"content\": \"The currents of fate pull everything into their depths. At times, as I drift in its grasp, I sometimes feel resistance. Everything I once achieved, every ounce of trust I earned, was consumed by the \u003Cte href=850074>Threnodian\u003C/te>. How ironic that the power I gained to protect others once served to sustain my nemesis. But I know I cannot let this fear hold me back. The \u003Cte href=850083>Sentinel\u003C/te> granted me life, and I must honor that blessing by guarding all that remains in Their stead.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_sys_rankup05.play_favor_word_katixiya_sys_rankup05\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Basic Attack: I\",\n      \"content\": \"Exonerate\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_atk_atk04_pro_01.play_favor_word_fuludelisi_atk_atk04_pro_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Basic Attack: II\",\n      \"content\": \"Salvation.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_atk_atk04_pro_02.play_favor_word_fuludelisi_atk_atk04_pro_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Basic Attack: III\",\n      \"content\": \"Atonement.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_atk_atk04_pro_03.play_favor_word_fuludelisi_atk_atk04_pro_03\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Basic Attack: IV\",\n      \"content\": \"Till the denouement.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_atk_atk05_pro_01.play_favor_word_fuludelisi_atk_atk05_pro_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Basic Attack: V\",\n      \"content\": \"Ruin is imminent.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_atk_atk05_pro_02.play_favor_word_fuludelisi_atk_atk05_pro_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Basic Attack: VI\",\n      \"content\": \"Face your destruction!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_atk_atk05_pro_03.play_favor_word_fuludelisi_atk_atk05_pro_03\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Heavy Attack: I\",\n      \"content\": \"You won't escape!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_atk_heavyatk01_02.play_favor_word_katixiya_atk_heavyatk01_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Heavy Attack: II\",\n      \"content\": \"Quietus.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_atk_heavyatk01_02.play_favor_word_fuludelisi_atk_heavyatk01_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Heavy Attack: III\",\n      \"content\": \"Finality.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_atk_heavyatk01_01.play_favor_word_fuludelisi_atk_heavyatk01_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Heavy Attack: IV\",\n      \"content\": \"March on!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_atk_heavyatk02_01.play_favor_word_fuludelisi_atk_heavyatk02_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Heavy Attack: V\",\n      \"content\": \"Betide!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_atk_heavyatk02_02.play_favor_word_fuludelisi_atk_heavyatk02_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Heavy Attack: VI\",\n      \"content\": \"Into the depths.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_atk_heavyatk01_pro_01.play_favor_word_fuludelisi_atk_heavyatk01_pro_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Heavy Attack: VII\",\n      \"content\": \"Engulfing currents.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_atk_heavyatk01_pro_02.play_favor_word_fuludelisi_atk_heavyatk01_pro_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Aerial Attack: I\",\n      \"content\": \"Cleave!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_atk_fallingatk_end04_01.play_favor_word_katixiya_atk_fallingatk_end04_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Aerial Attack: II\",\n      \"content\": \"Fall!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_atk_fallingatk_end04_02.play_favor_word_katixiya_atk_fallingatk_end04_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Aerial Attack: III\",\n      \"content\": \"Destroy!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_atk_fallingatk_end04_03.play_favor_word_katixiya_atk_fallingatk_end04_03\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Resonance Skill: I\",\n      \"content\": \"Purge the impure.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_skill_skill01_01.play_favor_word_katixiya_skill_skill01_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Resonance Skill: II\",\n      \"content\": \"Begone, wicked souls!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_skill_skill01_02.play_favor_word_katixiya_skill_skill01_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Resonance Skill: III\",\n      \"content\": \"Heavens descend.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_skill_skill01_03.play_favor_word_katixiya_skill_skill01_03\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Resonance Skill: IV\",\n      \"content\": \"Gales, purify!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_skill_skill01_01.play_favor_word_fuludelisi_skill_skill01_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Resonance Skill: V\",\n      \"content\": \"Sentence, befall!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_skill_skill01_02.play_favor_word_fuludelisi_skill_skill01_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Resonance Skill: VI\",\n      \"content\": \"Torrents, rage on!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_skill_skill01_03.play_favor_word_fuludelisi_skill_skill01_03\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Resonance Skill: VII\",\n      \"content\": \"Sounding the death knell.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_skill_skill02_01.play_favor_word_fuludelisi_skill_skill02_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Resonance Skill: VIII\",\n      \"content\": \"Tides, rise and crash.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_skill_skill02_02.play_favor_word_fuludelisi_skill_skill02_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Resonance Liberation: I\",\n      \"content\": \"Oceans, bow before me.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_burst_burst01_01.play_favor_word_katixiya_burst_burst01_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Resonance Liberation: II\",\n      \"content\": \"True form, revealed at last.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_burst_burst01_02.play_favor_word_katixiya_burst_burst01_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Resonance Liberation: III\",\n      \"content\": \"Repent, for silence beckons.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_burst_burst01_03.play_favor_word_katixiya_burst_burst01_03\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Resonance Liberation: IV\",\n      \"content\": \"Windstorm, sweep all away!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_burst_burst01_01.play_favor_word_fuludelisi_burst_burst01_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Resonance Liberation: V\",\n      \"content\": \"My blade, purge all evil!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_burst_burst01_02.play_favor_word_fuludelisi_burst_burst01_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Resonance Liberation: VI\",\n      \"content\": \"Furious tides, split the heavens!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_burst_burst01_03.play_favor_word_fuludelisi_burst_burst01_03\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Resonance Liberation: VII\",\n      \"content\": \"The fallen, embrace your end.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_burst_burst02_01.play_favor_word_fuludelisi_burst_burst02_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Resonance Liberation: VIII\",\n      \"content\": \"Heretic, face your reckoning.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_burst_burst02_02.play_favor_word_fuludelisi_burst_burst02_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Resonance Liberation: IX\",\n      \"content\": \"Transgressor, laud your demise.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_burst_burst02_03.play_favor_word_fuludelisi_burst_burst02_03\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Intro Skill: I\",\n      \"content\": \"Crumble!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_skill_qte_01.play_favor_word_katixiya_skill_qte_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Intro Skill: II\",\n      \"content\": \"Collapse!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_skill_qte_02.play_favor_word_katixiya_skill_qte_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Intro Skill: III\",\n      \"content\": \"Perish!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_skill_qte_03.play_favor_word_katixiya_skill_qte_03\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Intro Skill: IV\",\n      \"content\": \"Flood!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_skill_qte_01.play_favor_word_fuludelisi_skill_qte_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Intro Skill: V\",\n      \"content\": \"Disperse!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_skill_qte_02.play_favor_word_fuludelisi_skill_qte_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Intro Skill: VI\",\n      \"content\": \"Vanish!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_skill_qte_03.play_favor_word_fuludelisi_skill_qte_03\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Hit: I\",\n      \"content\": \"Too reckless!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_com_behitfly_01.play_favor_word_katixiya_com_behitfly_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Hit: II\",\n      \"content\": \"If it's a duel you want...\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_com_behitfly_02.play_favor_word_katixiya_com_behitfly_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Hit: III\",\n      \"content\": \"Worthless.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_com_behitfly_01.play_favor_word_fuludelisi_com_behitfly_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Hit: IV\",\n      \"content\": \"Impudent!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_com_behitfly_02.play_favor_word_fuludelisi_com_behitfly_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Injured: I\",\n      \"content\": \"The trial isn't over yet.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_com_hpdown01.play_favor_word_katixiya_com_hpdown01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Injured: II\",\n      \"content\": \"I won't back down.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_com_hpdown02.play_favor_word_katixiya_com_hpdown02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Injured: III\",\n      \"content\": \"This sword... shall not be shattered!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_com_hpdown03.play_favor_word_katixiya_com_hpdown03\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Injured: IV\",\n      \"content\": \"A mere scratch upon my blade.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_com_hpdown01.play_favor_word_fuludelisi_com_hpdown01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Injured: V\",\n      \"content\": \"Vexing malice.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_com_hpdown02.play_favor_word_fuludelisi_com_hpdown02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Injured: VI\",\n      \"content\": \"The haunting whispers return…\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_com_hpdown03.play_favor_word_fuludelisi_com_hpdown03\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Fallen: I\",\n      \"content\": \"I'm… sorry…\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_com_die_01.play_favor_word_katixiya_com_die_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Fallen: II\",\n      \"content\": \"My quest... ends here...\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_com_die_02.play_favor_word_katixiya_com_die_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Fallen: III\",\n      \"content\": \"Yet another long, dark dream.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_com_die_01.play_favor_word_fuludelisi_com_die_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Fallen: IV\",\n      \"content\": \"Echoes of turbulent waves…\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_com_die_02.play_favor_word_fuludelisi_com_die_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Fallen: V\",\n      \"content\": \"This sword… lies broken.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_com_die_03.play_favor_word_fuludelisi_com_die_03\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Echo Summon: I\",\n      \"content\": \"Such is Their blessing.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_skill_hxsummon.play_favor_word_katixiya_skill_hxsummon\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Echo Summon: II\",\n      \"content\": \"Charge forth with me.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_skill_hxsummon.play_favor_word_fuludelisi_skill_hxsummon\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Echo Transform: I\",\n      \"content\": \"A \\\"divine envoy\\\" then?\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_skill_hxchange.play_favor_word_katixiya_skill_hxchange\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Echo Transform: II\",\n      \"content\": \"What form do you look for?\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_skill_hxchange.play_favor_word_fuludelisi_skill_hxchange\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Enemies Near: I\",\n      \"content\": \"The knight's challenge has arrived!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_com_engage.play_favor_word_katixiya_com_engage\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Enemies Near: II\",\n      \"content\": \"Shadows must be purged.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_com_engage.play_favor_word_fuludelisi_com_engage\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Glider\",\n      \"content\": \"I can fly too.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_com_fly_01.play_favor_word_katixiya_com_fly_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Sensor\",\n      \"content\": \"My knightly instinct says... this way!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_com_scan.play_favor_word_katixiya_com_scan\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Supply Chest: I\",\n      \"content\": \"Just like the treasure chests from the stories!\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_com_openbox_01.play_favor_word_katixiya_com_openbox_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Supply Chest: II\",\n      \"content\": \"This should afford us more provisions.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_com_openbox_02.play_favor_word_katixiya_com_openbox_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Supply Chest: III\",\n      \"content\": \"Let's call it... A Knight's Great Harvest.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_katixiya_com_openbox_03.play_favor_word_katixiya_com_openbox_03\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Supply Chest: IV\",\n      \"content\": \"What is it you wish for?\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_com_openbox_01.play_favor_word_fuludelisi_com_openbox_01\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Supply Chest: V\",\n      \"content\": \"Fortune is on your side.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_com_openbox_02.play_favor_word_fuludelisi_com_openbox_02\"\n    },\n    {\n      \"type\": 2,\n      \"title\": \"Supply Chest: VI\",\n      \"content\": \"Your wish for wealth is granted.\",\n      \"voice\": \"/Game/Aki/WwiseAudio/Events/play_favor_word_fuludelisi_com_openbox_03.play_favor_word_fuludelisi_com_openbox_03\"\n    }\n  ],\n  \"goods\": [\n    {\n      \"title\": \"Worn Wooden Sword\",\n      \"content\": \"A small wooden stage prop sword. Even the quiet countryside of Egla Town wasn't untouched by \u003Cte href=850096>Rinascita\u003C/te>'s popular stage plays. Spinning windmills and brilliant knightly legends shaped Cartethyia's childhood. This wooden sword was a gift from a retired dramatist. Each day after her lessons, she would patrol the village with bright eyes and high spirits, brandishing it as she dealt with every \\\"injustice\\\" she encountered.\\n\\nThis should have been the start of her journey to becoming a wandering knight.\\n\\nFate is full of what should have been, but it never unfolds as we imagine.\",\n      \"icon\": \"/Game/Aki/UI/UIResources/UiRole/Image/Treasure/T_Treasure102_UI.T_Treasure102_UI\"\n    },\n    {\n      \"title\": \"Golden Laurel\",\n      \"content\": \"A small golden \u003Cte href=850103>Laurel\u003C/te>.\\n\\nWhen the golden crown was placed upon her head, the Divinity's whispers reached her ears for the first time.\\nFrom that moment on, she was no longer Cartethyia. She would become \u003Cte href=850096>Rinascita\u003C/te>'s Blessed Maiden, the \\\"Fleurdelys\\\" spoken of by all.\\n\\nFate can be too kind at first, only to become a rain that never stops falling.\",\n      \"icon\": \"/Game/Aki/UI/UIResources/UiRole/Image/Treasure/T_Treasure101_UI.T_Treasure101_UI\"\n    },\n    {\n      \"title\": \"Hand Puppets\",\n      \"content\": \"Hand puppets locked in a scuffle.\\n\\nShe had searched the tower for what felt like forever, yet found no trace of another soul. So she made puppets, staging play after play, just to keep from forgetting how to speak, and to fill the silence of being alone.\\n\\nShe missed the plays she had seen in the world of the living, missed the wheat fields of the countryside, missed sweet drinks and the sounds of people laughing.\\n\\nFate can fill us with nostalgia, even as it sends us onward alone.\",\n      \"icon\": \"/Game/Aki/UI/UIResources/UiRole/Image/Treasure/T_Treasure106_UI.T_Treasure106_UI\"\n    }\n  ],\n  \"special_cook\": {\n    \"id\": 80001047,\n    \"name\": \"Knight-Errant's Essentials\",\n    \"desc\": \"Grants 34% Healing Bonus to all Resonators in the team for 30m. Only effective on your own Resonators in Co-op Mode.\",\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconCook/T_IconCook_077_UI.T_IconCook_077_UI\",\n    \"rarity\": 4\n  },\n  \"stats\": {\n    \"0\": {\n      \"1\": {\n        \"life\": 1184.0,\n        \"atk\": 25.0,\n        \"def\": 50.0\n      },\n      \"2\": {\n        \"life\": 1283.6928,\n        \"atk\": 27.105,\n        \"def\": 54.115\n      },\n      \"3\": {\n        \"life\": 1383.504,\n        \"atk\": 29.2125,\n        \"def\": 58.235\n      },\n      \"4\": {\n        \"life\": 1483.3152,\n        \"atk\": 31.32,\n        \"def\": 62.355\n      },\n      \"5\": {\n        \"life\": 1583.008,\n        \"atk\": 33.425,\n        \"def\": 66.475\n      },\n      \"6\": {\n        \"life\": 1682.8192,\n        \"atk\": 35.5325,\n        \"def\": 70.595\n      },\n      \"7\": {\n        \"life\": 1782.6304,\n        \"atk\": 37.64,\n        \"def\": 74.715\n      },\n      \"8\": {\n        \"life\": 1882.3232,\n    