n          \"value\": 3\n        },\n        {\n          \"key\": 41100054,\n          \"value\": 3\n        },\n        {\n          \"key\": 41400204,\n          \"value\": 1\n        },\n        {\n          \"key\": 2,\n          \"value\": 100000\n        }\n      ],\n      \"skill\": {\n        \"name\": \"Crit. Rate Up\",\n        \"desc\": \"Crit. Rate increased by {0}.\",\n        \"param\": [\n          \"2.80%\"\n        ],\n        \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconAttribute/T_Iconpropertyredbaoji_UI.T_Iconpropertyredbaoji_UI\"\n      }\n    },\n    \"14\": {\n      \"parent_nodes\": [\n        10\n      ],\n      \"node_type\": 4,\n      \"coordinate\": 2,\n      \"un_lock_condition\": 500007,\n      \"skill_branch_ids\": [],\n      \"consume\": [\n        {\n          \"key\": 43020014,\n          \"value\": 3\n        },\n        {\n          \"key\": 41100054,\n          \"value\": 3\n        },\n        {\n          \"key\": 41400204,\n          \"value\": 1\n        },\n        {\n          \"key\": 2,\n          \"value\": 100000\n        }\n      ],\n      \"skill\": {\n        \"name\": \"HP Up\",\n        \"desc\": \"HP increased by {0}.\",\n        \"param\": [\n          \"4.20%\"\n        ],\n        \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconAttribute/T_Iconpropertygreenlife_UI.T_Iconpropertygreenlife_UI\"\n      }\n    },\n    \"15\": {\n      \"parent_nodes\": [\n        11\n      ],\n      \"node_type\": 4,\n      \"coordinate\": 2,\n      \"un_lock_condition\": 500007,\n      \"skill_branch_ids\": [],\n      \"consume\": [\n        {\n          \"key\": 43020014,\n          \"value\": 3\n        },\n        {\n          \"key\": 41100054,\n          \"value\": 3\n        },\n        {\n          \"key\": 41400204,\n          \"value\": 1\n        },\n        {\n          \"key\": 2,\n          \"value\": 100000\n        }\n      ],\n      \"skill\": {\n        \"name\": \"HP Up\",\n        \"desc\": \"HP increased by {0}.\",\n        \"param\": [\n          \"4.20%\"\n        ],\n        \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconAttribute/T_Iconpropertygreenlife_UI.T_Iconpropertygreenlife_UI\"\n      }\n    },\n    \"16\": {\n      \"parent_nodes\": [\n        12\n      ],\n      \"node_type\": 4,\n      \"coordinate\": 2,\n      \"un_lock_condition\": 500008,\n      \"skill_branch_ids\": [],\n      \"consume\": [\n        {\n          \"key\": 43020014,\n          \"value\": 3\n        },\n        {\n          \"key\": 41100054,\n          \"value\": 3\n        },\n        {\n          \"key\": 41400204,\n          \"value\": 1\n        },\n        {\n          \"key\": 2,\n          \"value\": 100000\n        }\n      ],\n      \"skill\": {\n        \"name\": \"Crit. Rate Up\",\n        \"desc\": \"Crit. Rate increased by {0}.\",\n        \"param\": [\n          \"2.80%\"\n        ],\n        \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconAttribute/T_Iconpropertyredbaoji_UI.T_Iconpropertyredbaoji_UI\"\n      }\n    },\n    \"17\": {\n      \"parent_nodes\": [],\n      \"node_type\": 3,\n      \"coordinate\": 1,\n      \"un_lock_condition\": 0,\n      \"skill_branch_ids\": [],\n      \"consume\": [\n        {\n          \"key\": 43020032,\n          \"value\": 2\n        },\n        {\n          \"key\": 41100022,\n          \"value\": 3\n        },\n        {\n          \"key\": 2,\n          \"value\": 3900\n        }\n      ],\n      \"skill\": {\n        \"name\": \"Tune Break: Sword\",\n        \"desc\": \"When the target's \u003Ccolor=Highlight>Off-Tune Level\u003C/color> is full, the Resonator may cast \u003Ccolor=Highlight>\u003Cte href=100001>Tune Break\u003C/te>\u003C/color> on the target.\",\n        \"param\": [],\n        \"simple_desc\": \"When the target's \u003Ccolor=Highlight>Off-Tune Level\u003C/color> is full, the Resonator may cast \u003Ccolor=Highlight>\u003Cte href=100001>Tune Break\u003C/te>\u003C/color> on the target.\",\n        \"simple_param\": [],\n        \"icon\": \"/Game/Aki/UI/UIResources/Common/Atlas/SkillIcon/SkillIconNor/SP_IconWeakPointBreakKnife.SP_IconWeakPointBreakKnife\",\n        \"type\": \"Tune Break\",\n        \"level\": {},\n        \"consume\": {\n          \"1\": []\n        },\n        \"damage\": {}\n      }\n    }\n  },\n  \"skill_branches\": {},\n  \"chains\": {\n    \"1\": {\n      \"name\": \"Crown Destined by Fate\",\n      \"desc\": \"Gain \u003Ccolor=Highlight>Zeal\u003C/color> that lasts for {0}s when \u003Ccolor=Highlight>Cartethyia's\u003C/color> or \u003Ccolor=Highlight>Fleurdelys's\u003C/color> attacks directly damage and defeat targets inflicted with \u003Ccolor=Wind>\u003Cte href=850009>Aero Erosion\u003C/te>\u003C/color>.\\nIn the \u003Ccolor=Highlight>Zeal\u003C/color> state, upon defeating enemies, the next move that directly damages targets raises the \u003Ccolor=Wind>\u003Cte href=850009>Aero Erosion\u003C/te>\u003C/color> stacks on the targets to the highest count among the targets defeated. This will not exceed the current max \u003Ccolor=Wind>\u003Cte href=850009>Aero Erosion\u003C/te>\u003C/color> stack limit. \u003Ccolor=Highlight>Zeal\u003C/color> is removed afterward and enters a {1}s cooldown.\\nWhen \u003Ccolor=Highlight>Fleurdelys's\u003C/color> \u003Ccolor=Highlight>\u003Cte href=850179>Conviction\u003C/te>\u003C/color> hits 30/60/90/120, \u003Ccolor=Highlight>Fleurdelys's\u003C/color> Crit. DMG is increased by {2} for {3}s, up to 4 stacks. The duration of this effect does not reset upon gaining new stacks. After casting \u003Ccolor=Highlight>Resonance Liberation - Blade of Howling Squall\u003C/color>, the increased Crit. DMG is removed.\",\n      \"param\": [\n        \"10\",\n        \"1\",\n        \"25%\",\n        \"15\"\n      ],\n      \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconDevice/T_IconDevice_KatixiyaM1_UI.T_IconDevice_KatixiyaM1_UI\"\n    },\n    \"2\": {\n      \"name\": \"Blade Broken by Tempest\",\n      \"desc\": \"Casting \u003Ccolor=Highlight>Resonance Liberation - A Knight's Heartfelt Prayers\u003C/color> increases the max stack limit of \u003Ccolor=Wind>\u003Cte href=850009>Aero Erosion\u003C/te>\u003C/color> on targets within a certain range by \u003CSapTag=0>{0}\u003C/SapTag> {Cus:Sap,S=stack P=stacks SapTag=0}. The next attack that directly damages the target inflicts \u003CSapTag=1>{1}\u003C/SapTag> {Cus:Sap,S=stack P=stacks SapTag=1} of \u003Ccolor=Wind>\u003Cte href=850009>Aero Erosion\u003C/te>\u003C/color> on all targets within a certain range and immediately triggers the \u003Ccolor=Wind>\u003Cte href=850009>Aero Erosion\u003C/te>\u003C/color> DMG on the targets hit once without consuming the \u003Ccolor=Wind>\u003Cte href=850009>Aero Erosion\u003C/te>\u003C/color> stacks.\\nThe DMG Multipliers of \u003Ccolor=Highlight>Cartethyia's\u003C/color> Basic Attack, Heavy Attack, Dodge Counter, and Intro Skill are increased by {2} and the DMG Multiplier of her Mid-air Attack is increased by {3}.\\nAfter casting \u003Ccolor=Highlight>Mid-air Attack - Cartethyia\u003C/color>, every 1 type of Sword Shadow recalled reduces the cooldown of \u003Ccolor=Highlight>Resonance Skill - Cartethyia\u003C/color> by 1s.\",\n      \"param\": [\n        \"3\",\n        \"3\",\n        \"50%\",\n        \"200%\"\n      ],\n      \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconDevice/T_IconDevice_KatixiyaM2_UI.T_IconDevice_KatixiyaM2_UI\"\n    },\n    \"3\": {\n      \"name\": \"Prisoner Hanged in the Tower\",\n      \"desc\": \"\u003Ccolor=Highlight>Basic Attack - Fleurdelys Stage 5\u003C/color>, \u003Ccolor=Highlight>Mid-air Attack - Fleurdelys Stage 2\u003C/color>, \u003Ccolor=Highlight>Enhanced Heavy Attack - Fleurdelys\u003C/color>, and \u003Ccolor=Highlight>Resonance Skill - May Tempest Break the Tides\u003C/color> now inflict \u003CSapTag=0>{0}\u003C/SapTag> {Cus:Sap,S=stack P=stacks SapTag=0} of \u003Ccolor=Wind>\u003Cte href=850009>Aero Erosion\u003C/te>\u003C/color> on the targets hit.\\nThe DMG Multiplier of \u003Ccolor=Highlight>Resonance Liberation - Blade of Howling Squall\u003C/color> is increased by {1}.\",\n      \"param\": [\n        \"2\",\n        \"100%\"\n      ],\n      \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconDevice/T_IconDevice_KatixiyaM3_UI.T_IconDevice_KatixiyaM3_UI\"\n    },\n    \"4\": {\n      \"name\": \"Sacrifice Made for Salvation\",\n      \"desc\": \"After Resonators in the team inflict \u003Ccolor=Highlight>\u003Cte href=850012>Havoc Bane\u003C/te>\u003C/color>, \u003Ccolor=Highlight>\u003Cte href=850011>Fusion Burst\u003C/te>\u003C/color>, \u003Ccolor=Highlight>\u003Cte href=850008>Spectro Frazzle\u003C/te>\u003C/color>, \u003Ccolor=Highlight>\u003Cte href=850013>Electro Flare\u003C/te>\u003C/color>, \u003Ccolor=Highlight>\u003Cte href=850010>Glacio Chafe\u003C/te>\u003C/color>, or\u003Ccolor=Highlight>\u003Cte href=850009>Aero Erosion\u003C/te>\u003C/color>, all Resonators in the team gain {0} DMG Bonus for all Attributes for {1}s.\",\n      \"param\": [\n        \"20%\",\n        \"20\"\n      ],\n      \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconDevice/T_IconDevice_KatixiyaM5_UI.T_IconDevice_KatixiyaM5_UI\"\n    },\n    \"5\": {\n      \"name\": \"Hope Reshaped in Storms\",\n      \"desc\": \"When \u003Ccolor=Highlight>Cartethyia\u003C/color> or \u003Ccolor=Highlight>Fleurdelys\u003C/color> takes a fatal blow, they will not be downed by this instance of damage, but instead gain a Shield equal to {0} of \u003Ccolor=Highlight>Cartethyia's\u003C/color> Max HP for {1}s. This effect can be triggered once every 10 min.\\nThe HP cost for casting \u003Ccolor=Highlight>Resonance Liberation - A Knight's Heartfelt Prayers\u003C/color> is reduced to {2} of Max HP.\",\n      \"param\": [\n        \"20%\",\n        \"10\",\n        \"25%\"\n      ],\n      \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconDevice/T_IconDevice_KatixiyaM4_UI.T_IconDevice_KatixiyaM4_UI\"\n    },\n    \"6\": {\n      \"name\": \"Freedom Found in Storm's Wake\",\n      \"desc\": \"After casting \u003Ccolor=Highlight>Resonance Liberation - Blade of Howling Squall\u003C/color>, raise the \u003Ccolor=Wind>\u003Cte href=850009>Aero Erosion\u003C/te>\u003C/color> stacks on the target hit to max. Casting \u003Ccolor=Highlight>Resonance Liberation - Blade of Howling Squall\u003C/color> no longer removes the \u003Ccolor=Wind>\u003Cte href=850009>Aero Erosion\u003C/te>\u003C/color> stacks on the target.\\nWithin {0}s after casting \u003Ccolor=Highlight>Intro Skill - Sword to Mark Tide's Trace\u003C/color>, \u003Ccolor=Highlight>Intro Skill - Sword to Call for Freedom\u003C/color>, \u003Ccolor=Highlight>Resonance Liberation - A Knight's Heartfelt Prayers\u003C/color>, and \u003Ccolor=Highlight>Resonance Liberation - Blade of Howling Squall\u003C/color>, when any Resonator in the team inflicts \u003Ccolor=Wind>\u003Cte href=850009>Aero Erosion\u003C/te>\u003C/color> on the targets with max stacks of \u003Ccolor=Wind>\u003Cte href=850009>Aero Erosion\u003C/te>\u003C/color>, immediately trigger the \u003Ccolor=Wind>\u003Cte href=850009>Aero Erosion\u003C/te>\u003C/color> DMG once.\\nThe targets take {1} more DMG from \u003Ccolor=Highlight>Fleurdelys\u003C/color>.\",\n      \"param\": [\n        \"30\",\n        \"40%\"\n      ],\n      \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconDevice/T_IconDevice_KatixiyaM6_UI.T_IconDevice_KatixiyaM6_UI\"\n    }\n  },\n  \"ascensions\": {\n    \"1\": [\n      {\n        \"key\": 41100051,\n        \"value\": 4\n      },\n      {\n        \"key\": 2,\n        \"value\": 5000\n      }\n    ],\n    \"2\": [\n      {\n        \"key\": 41400214,\n        \"value\": 3\n      },\n      {\n        \"key\": 42601220,\n        \"value\": 4\n      },\n      {\n        \"key\": 41100052,\n        \"value\": 4\n      },\n      {\n        \"key\": 2,\n        \"value\": 10000\n      }\n    ],\n    \"3\": [\n      {\n        \"key\": 41400214,\n        \"value\": 6\n      },\n      {\n        \"key\": 42601220,\n        \"value\": 8\n      },\n      {\n        \"key\": 41100052,\n        \"value\": 8\n      },\n      {\n        \"key\": 2,\n        \"value\": 15000\n      }\n    ],\n    \"4\": [\n      {\n        \"key\": 41400214,\n        \"value\": 9\n      },\n      {\n        \"key\": 42601220,\n        \"value\": 12\n      },\n      {\n        \"key\": 41100053,\n        \"value\": 4\n      },\n      {\n        \"key\": 2,\n        \"value\": 20000\n      }\n    ],\n    \"5\": [\n      {\n        \"key\": 41400214,\n        \"value\": 12\n      },\n      {\n        \"key\": 42601220,\n        \"value\": 16\n      },\n      {\n        \"key\": 41100053,\n        \"value\": 8\n      },\n      {\n        \"key\": 2,\n        \"value\": 40000\n      }\n    ],\n    \"6\": [\n      {\n        \"key\": 41400214,\n        \"value\": 16\n      },\n      {\n        \"key\": 42601220,\n        \"value\": 20\n      },\n      {\n        \"key\": 41100054,\n        \"value\": 4\n      },\n      {\n        \"key\": 2,\n        \"value\": 80000\n      }\n    ]\n  },\n  \"skin\": {\n    \"81001409\": {\n      \"id\": 81001409,\n      \"suit_weapon_skin_id\": 0,\n      \"quality_id\": 3,\n      \"name\": \"Cartethyia\",\n      \"title_name\": \"Thorny Rain\",\n      \"sub_dec_name\": \"Cartethyia - Original Outfit\",\n      \"bg_description\": \"The dress Cartethyia wore during her coronation as the Blessed Maiden. These thorns accompanied her through storms of solitude, and they serve to engrave the responsibilities of \\\"salvation\\\" deep into her heart.\",\n      \"background\": \"/Game/Aki/UI/UIResources/Common/Image/IconRolePile/T_IconRole_Pile_katixiya_UI.T_IconRole_Pile_katixiya_UI\",\n      \"portrait\": \"/Game/Aki/UI/UIResources/Common/Image/PixActivity/T_ActivityRoleKatixiya.T_ActivityRoleKatixiya\",\n      \"sort_index\": 0,\n      \"formation_spine_skel\": \"/Game/Aki/UI/UIResources/Common/Spine/Portraits/Portraits_Katixiya/Portraits_Katixiya.Portraits_Katixiya-data\",\n      \"formation_spine_atlas\": \"/Game/Aki/UI/UIResources/Common/Spine/Portraits/Portraits_Katixiya/Portraits_Katixiya.Portraits_Katixiya-atlas\"\n    }\n  },\n  \"forte\": {\n    \"skill_input_list\": {\n      \"140901\": {\n        \"desc\": \"Enhanced \u003Ccolor=Highlight>Plunging Attack\u003C/color>: As \u003Ccolor=Highlight>Cartethyia\u003C/color>, when there is at least 1 \u003Ccolor=Highlight>Sword Shadow\u003C/color> on the field, {Cus:Ipt,Touch=tap PC=press Gamepad=press} {0} while airborne.\",\n        \"input_list\": [\n          \"攻击\"\n        ]\n      },\n      \"140902\": {\n        \"desc\": \"\u003Ccolor=Highlight>Fleurdelys\u003C/color> Resonance Skill Stage 2: {Cus:Ipt,Touch=Tap PC=Press Gamepad=Press} {0} following \u003Ccolor=Highlight>Fleurdelys\u003C/color> Resonance Skill Stage 1.\",\n        \"input_list\": [\n          \"技能1\"\n        ]\n      },\n      \"140903\": {\n        \"desc\": \"\u003Ccolor=Highlight>Fleurdelys\u003C/color> Enhanced Heavy Attack Stage 2: Hold {0} and then {Cus:Ipt,Touch=tap PC=press Gamepad=press} {0} again.\",\n        \"input_list\": [\n          \"攻击\"\n        ]\n      },\n      \"140904\": {\n        \"desc\": \"Temporarily transform back to \u003Ccolor=Highlight>Cartethyia\u003C/color>: As \u003Ccolor=Highlight>Fleurdelys\u003C/color>, {Cus:Ipt,Touch=tap PC=press Gamepad=press} {0} when \u003Ccolor=Highlight>Conviction\u003C/color> is below 120 points.\",\n        \"input_list\": [\n          \"大招\"\n        ]\n      },\n      \"140905\": {\n        \"desc\": \"\u003Ccolor=Highlight>Resonance Liberation - Blade of Howling Squall\u003C/color>: As \u003Ccolor=Highlight>Fleurdelys\u003C/color>, {Cus:Ipt,Touch=tap PC=press Gamepad=press} {0} when \u003Ccolor=Highlight>Conviction\u003C/color> reaches 120 points.\",\n        \"input_list\": [\n          \"大招\"\n        ]\n      }\n    },\n    \"icon\": \"/Game/Aki/UI/UIResources/UiRole/Image/T_RoleSkillTreeKatixiya.T_RoleSkillTreeKatixiya\",\n    \"desc_list\": [\n      \"As \u003Ccolor=Highlight>Cartethyia\u003C/color>: The last Stage of Basic Attack, Heavy Attack, Intro Skill, and Resonance Skill of \u003Ccolor=Highlight>Cartethyia\u003C/color> will summon different \u003Ccolor=Highlight>Sword Shadows\u003C/color>. When there are \u003Ccolor=Highlight>Sword Shadows\u003C/color> on the field, \u003Ccolor=Highlight>Cartethyia's\u003C/color> Plunging Attack will recall the \u003Ccolor=Highlight>Sword Shadows\u003C/color> and cause additional DMG based on the Sword Shadows recalled.\",\n      \"When \u003Ccolor=Highlight>Cartethyia's\u003C/color> Resonance Energy is full, {Cus:Ipt,Touch=tap PC=press Gamepad=press} Resonance Liberation to transform into \u003Ccolor=Highlight>Fleurdelys\u003C/color> and obtain different bonus effects for a certain period of time based on the \u003Ccolor=Highlight>Sword Shadows\u003C/color> recalled.\\n\\nAs \u003Ccolor=Highlight>Fleurdelys\u003C/color>: Attacks restore \u003Ccolor=Highlight>Conviction\u003C/color>. When \u003Ccolor=Highlight>Conviction\u003C/color> reaches 120 points, \u003Ccolor=Highlight>Resonance Liberation - Blade of Howling Squall\u003C/color> becomes available.\"\n    ]\n  },\n  \"forte_new\": {},\n  \"live2d\": \"Katixiya\",\n  \"audio\": \"katixiya\",\n  \"recommend\": {\n    \"weapon\": [\n      21020056,\n      21020015\n    ],\n    \"property\": \"\",\n    \"param\": []\n  }\n}"}</script>
			<script type="application/json" data-sveltekit-fetched data-url="https://static.nanoka.cc/ww/3.5.3/en/hyperlink.json" data-ttl="52">{"status":200,"statusText":"OK","headers":{},"body":"{\n  \"800001\": {\n    \"name\": \"Golden Anthem\",\n    \"desc\": \"Once a reputable poets society in Ragunna, consisting of three members: Faroll, Selena, and Rimbaud. They composed numerous anthems and poems glorifying the Sentinel and the Order, but were later accused of blasphemy by the Order and sent on a Pilgrim's Sail. They vanished thereafter without a trace, and mentioning of their names is now forbidden in Ragunna.\",\n    \"param\": []\n  },\n  \"800002\": {\n    \"name\": \"Anniversary Cake\",\n    \"desc\": \"A large cake dedicated to the 1st anniversary of the launch of the Second Coming of Solaris Beta, as well as the control hub for its simulator. When asked about the hub's cake-shaped design, lead designer Encore replied, \\\"What's a birthday without cake! Happy Anniversary!\\\"\",\n    \"param\": []\n  },\n  \"800003\": {\n    \"name\": \"Second Coming of Solaris\",\n    \"desc\": \"A virtual simulation game developed by the Pioneer Association. Despite many setbacks during development, thanks to Rover's trust and support, the game is steadily evolving towards its ideal form.\",\n    \"param\": []\n  },\n  \"800004\": {\n    \"name\": \"Cube\",\n    \"desc\": \"Officially known as \\\"Remnant Cubes,\\\" these advanced artificial intelligences were created for the Second Coming of Solaris using Encore's abilities and Tethys's microprocessing support. Please note: Remnant Cubes are experimental simulations, automatically generated by the system. Their personalities and actions in the game do not reflect those of real individuals.\",\n    \"param\": []\n  },\n  \"800005\": {\n    \"name\": \"Chamber of Discipline\",\n    \"desc\": \"The Order's executive arm. Unlike Order Penitentiary, which trials the heretics and maintains faith, the Chamber of Discipline deals with secular cases, and enforces law and order, while also overseeing Ragunna's defenses against Tacet Discords. Its enforcers are often referred to as \\\"Inquisitors.\\\"\",\n    \"param\": []\n  },\n  \"800006\": {\n    \"name\": \"Sonoro Sphere\",\n    \"desc\": \"Sonoro Sphere is a space of dense Remnant Energy capable of preserving transdimensional information. In Huanglong culture, such ethereal realms—neither tangible nor illusory—are often referred to as \\\"mirages.\\\"\",\n    \"param\": []\n  },\n  \"800007\": {\n    \"name\": \"Channel\",\n    \"desc\": \"A signal transmission pathway. During its simulation, the Second Coming of Solaris briefly linked with the Tethys System, creating a temporary channel between them.\",\n    \"param\": []\n  },\n  \"800008\": {\n    \"name\": \"Ghost Hounds\",\n    \"desc\": \"A mercenary group in the New Federation led by Calcharo.\",\n    \"param\": []\n  },\n  \"800009\": {\n    \"name\": \"The Golden Bough\",\n    \"desc\": \"An ancient epic poem of Rinascita. It pioneered blending various regional folkfore with the tales of the Sentinel, including the first accounts of the Carnevale's origins.\",\n    \"param\": []\n  },\n  \"800010\": {\n    \"name\": \"Requiem Paradise\",\n    \"desc\": \"A shore where Rinascitan poets and musicians bury their retired instruments.\",\n    \"param\": []\n  },\n  \"800011\": {\n    \"name\": \"Celestial Steed\",\n    \"desc\": \"The autumn night's brightest constellation, shrouded in legends. A poet of Golden Anthem once wrote, \\\"I am a night hawk of wings aflame, soaring towards the Celestial Steed, whose praises I sing and whose true form I behold.\\\" Such imagery always evokes Rinascita's Sentinel. But why soar towards it and behold its true form? Maybe the poem was intended to convey some message.\",\n    \"param\": []\n  },\n  \"800012\": {\n    \"name\": \"Melody\",\n    \"desc\": \"Music is composed of frequency, as is everything. Thus, everything hums its own melody. Ciaccona's Forte allows her to perceive these melodies; by retuning them, she crafts a Sonoro Sphere in her hands where stories and memories carried in music replay themselves. The deeper her understanding of the melodies, the richer the stories she can summon.\",\n    \"param\": []\n  },\n  \"850001\": {\n    \"name\": \"Incarnation\",\n    \"desc\": \"While in \u003Ccolor=Highlight>Incarnation\u003C/color>:\\n- Alternative Basic Attack \u003Ccolor=Highlight>\\\"Incarnation - Basic Attack\\\"\u003C/color> becomes available. Perform up to 4 consecutive strikes, dealing \u003Ccolor=Light>Spectro DMG\u003C/color> considered as Resonance Skill DMG. The basic attack cycle of this will not be reset. Can be cast in mid-air.\\n- Alternative Resonance Skill \u003Ccolor=Highlight>\\\"Crescent Divinity\\\"\u003C/color> becomes available. Deal \u003Ccolor=Light>Spectro DMG\u003C/color>. Can be cast in mid-air.\\n- Alternative Heavy Attack \u003Ccolor=Highlight>\\\"Incarnation - Heavy Attack\\\"\u003C/color> becomes available. Attack the target in mid-air at the cost of Stamina, dealing \u003Ccolor=Light>Spectro DMG\u003C/color>.\\n- Alternative Dodge \u003Ccolor=Highlight>\\\"Incarnation - Dodge\\\"\u003C/color> is available while in mid-air. Can be cast multiple times at the cost of Stamina.\\n- Alternative Dodge Counter \u003Ccolor=Highlight>\\\"Incarnation - Dodge Counter\\\"\u003C/color> becomes available. Deal \u003Ccolor=Light>Spectro DMG\u003C/color>.\\nCan be cast in mid-air.\",\n    \"param\": []\n  },\n  \"850002\": {\n    \"name\": \"Incandescence\",\n    \"desc\": \"Jinhsi can hold up to 50 Incandescence.\\nWhen Jinhsi is in the party, all nearby Resonators in the team gain \u003Ccolor=Highlight>Eras in Unity\u003C/color>.\\n\u003Ccolor=Highlight>Eras in Unity\u003C/color> provides 2 independent effects:\\nJinhsi gains 1 Incandescence each time Resonators in the team inflict Attribute DMG. This effect may be triggered by the same Attribute DMG for up to 1 time every 3s. Additionally, Jinhsi gains 2 Incandescence when Resonators in the team deal damage with Coordinated Attacks. This effect may be triggered by Coordinated Attacks of the same Attribute for up to 1 time every 3s.\",\n    \"param\": []\n  },\n  \"850003\": {\n    \"name\": \"True Sight\",\n    \"desc\": \"\u003Csize=40>\u003Ccolor=Title>Basic Attack: True Sight - Conquest\u003C/color>\u003C/size>\\nWhen in \u003Ccolor=Highlight>True Sight\u003C/color>, if Changli uses \u003Ccolor=Highlight>Ground Basic Attack\u003C/color>, she releases \u003Ccolor=Highlight>True Sight: Conquest\u003C/color>, dashing towards the enemy and dealing \u003Ccolor=Fire>Fusion DMG\u003C/color>, considered as Resonance Skill DMG. After releasing \u003Ccolor=Highlight>True Sight: Conquest\u003C/color>, \u003Ccolor=Highlight>True Sight\u003C/color> ends.\\n\u003Csize=10>\u003C/size>\\n\u003Csize=40>\u003Ccolor=Title>Basic Attack: True Sight - Charge\u003C/color>\u003C/size>\\nWhen in \u003Ccolor=Highlight>True Sight\u003C/color>, if Changli \u003Ccolor=Highlight>jumps\u003C/color> or uses \u003Ccolor=Highlight>Basic Attack\u003C/color> in mid-air, she releases \u003Ccolor=Highlight>True Sight: Charge\u003C/color>, dashing towards the enemy and dealing \u003Ccolor=Fire>Fusion DMG\u003C/color>, considered as Resonance Skill DMG. After releasing \u003Ccolor=Highlight>True Sight: Charge\u003C/color>, \u003Ccolor=Highlight>True Sight\u003C/color> ends.\",\n    \"param\": []\n  },\n  \"850004\": {\n    \"name\": \"Enflamement\",\n    \"desc\": \"Changli can hold up to 4 stacks of Enflamement.\\nChangli obtains 1 stack of Enflamement for every Basic Attack: \u003Ccolor=Highlight>True Sight - Conquest\u003C/color> on hit.\\nChangli obtains 1 stack of Enflamement for every Basic Attack: \u003Ccolor=Highlight>True Sight - Charge\u003C/color> on hit.\\nChangli obtains 4 stacks of Enflamement for every Resonance Liberation \u003Ccolor=Highlight>Radiance of Fealty\u003C/color>.\",\n    \"param\": []\n  },\n  \"850005\": {\n    \"name\": \"Photosynthesis Energy\",\n    \"desc\": \"Verina can hold up to 4 stacks of Photosynthesis Energy.\\nVerina obtains 1 stack of Photosynthesis Energy for every \u003Ccolor=Highlight>Basic Attack 5\u003C/color> on hit.\\nVerina obtains 1 stack of Photosynthesis Energy after casting Resonance Skill \u003Ccolor=Highlight>Botany Experiment\u003C/color>.\\nVerina obtains 1 stack of Photosynthesis Energy after casting Intro Skill \u003Ccolor=Highlight>Verdant Growth\u003C/color>.\",\n    \"param\": []\n  },\n  \"850006\": {\n    \"name\": \"Concerto Energy\",\n    \"desc\": \"Switch Resonator when Concerto Energy is full to trigger the exiting Resonator's \u003Ccolor=Highlight>Outro Skill\u003C/color>, and consume all the Concerto Energy to trigger the incoming Resonator's \u003Ccolor=Highlight>Intro Skill\u003C/color>.\",\n    \"param\": []\n  },\n  \"850007\": {\n    \"name\": \"Ring of Mirrors\",\n    \"desc\": \"- When Phoebe is outside of the Ring of Mirrors, any \u003Ccolor=Highlight>Basic Attack\u003C/color> or \u003Ccolor=Highlight>Dodge Counter\u003C/color> that hits the Ring of Mirrors will refract Holy Light, which deals \u003Ccolor=Light>Spectro DMG\u003C/color> to targets inside the \u003Ccolor=Highlight>Ring of Mirrors\u003C/color> and pulls them to the center of the ring. The DMG dealt is considered Basic Attack DMG. Can be triggered once every 0.5s.\\n- When Phoebe is inside the Ring of Mirrors, \u003Ccolor=Highlight>Basic Attack\u003C/color> becomes Basic Attack \u003Ccolor=Highlight>Chamuel's Star\u003C/color>, which performs up to 3 consecutive attacks, dealing \u003Ccolor=Light>Spectro DMG\u003C/color>, considered as Basic Attack DMG.\",\n    \"param\": []\n  },\n  \"850008\": {\n    \"name\": \"Spectro Frazzle\",\n    \"desc\": \"- While Spectro Frazzle lasts, it deals periodic \u003Ccolor=Light>Spectro DMG\u003C/color> to the target. The target loses 1 stack of the effect with each instance of damage.\\n- The DMG of Spectro Frazzle scales with its stacks.\",\n    \"param\": []\n  },\n  \"850009\": {\n    \"name\": \"Aero Erosion\",\n    \"desc\": \"- While Aero Erosion lasts, it deals periodic \u003Ccolor=Wind>Aero DMG\u003C/color> to the target.\\n- The DMG of Aero Erosion scales with its stacks.\",\n    \"param\": []\n  },\n  \"850010\": {\n    \"name\": \"Glacio Chafe\",\n    \"desc\": \"- Glacio Chafe deals \u003Ccolor=Ice>Glacio DMG\u003C/color> when being inflicted on the target.\\n- Each stack of Glacio Chafe reduces the target's movement speed.\\n- When Glacio Chafe is stacked to its max, the target will be \u003Ccolor=Highlight>frozen\u003C/color>, and all stacks of Glacio Chafe will be removed. Struggle to accelerate your recovery from the frozen state.\\n- Glacio Chafe stacks up to 10 times by default. The higher the stacks, the more DMG dealt, and the longer the \u003Ccolor=Highlight>frozen\u003C/color> duration.\",\n    \"param\": []\n  },\n  \"850011\": {\n    \"name\": \"Fusion Burst\",\n    \"desc\": \"- When Fusion Burst is stacked to its max, all stacks will be removed to trigger an \u003Ccolor=Highlight>explosion\u003C/color>, dealing \u003Ccolor=Fire>Fusion DMG\u003C/color> to the target and nearby enemies.\\n- Fusion Burst stacks up to 10 times by default. The higher the stacks, the more DMG dealt.\",\n    \"param\": []\n  },\n  \"850012\": {\n    \"name\": \"Havoc Bane\",\n    \"desc\": \"- While Havoc Bane lasts, the DEF of the inflicted target is reduced.\\n- Havoc Bane stacks up to 3 times by default. Each stack reduces the target's DEF by 2%.\",\n    \"param\": []\n  },\n  \"850013\": {\n    \"name\": \"Electro Flare\",\n    \"desc\": \"- While Electro Flare lasts, it deals periodic \u003Ccolor=Thunder>Electro DMG\u003C/color> to the target. The target loses half of the effect stacks with each instance of damage.\\n- At maximum stacks of Electro Flare, any new stack inflicted becomes stackable Electro Rage.\\n- Electro Rage increases the DMG dealt by the next Electro Flare trigger. This effect is removed once triggered.\\n- Electro Flare and Electro Rage stack up to 10 times by default. The higher the stacks, the more DMG dealt.\",\n    \"param\": []\n  },\n  \"850014\": {\n    \"name\": \"Divine Voice\",\n    \"desc\": \"Casting Heavy Attack \u003Ccolor=Highlight>Absolution Litany\u003C/color> or Resonance Skill \u003Ccolor=Highlight>Utter Confession\u003C/color> restores 60 Divine Voice.\",\n    \"param\": []\n  },\n  \"850015\": {\n    \"name\": \"Imagination\",\n    \"desc\": \"Roccia can hold up to 300 Imagination.\\n- Dealing DMG with Normal Attacks restores Imagination.\\n- Hold \u003Ccolor=Highlight>Normal Attack\u003C/color> to charge the next attack while restoring Imagination.\\n- Casting Resonance Skill \u003Ccolor=Highlight>Acrobatic Trick\u003C/color> restores 100 Imagination.\\n- Casting Intro Skill \u003Ccolor=Highlight>Pero, Help\u003C/color> restores 100 Imagination.\",\n    \"param\": []\n  },\n  \"850016\": {\n    \"name\": \"Beyond Imagination\",\n    \"desc\": \"- When Roccia is in \u003Ccolor=Highlight>Beyond Imagination\u003C/color> with at least 100 Imagination, {Cus:Ipt,Touch=tap PC=press Gamepad=press} the \u003Ccolor=Highlight>Basic Attack\u003C/color> button to consume 100 Imagination to cast Basic Attack \u003Ccolor=Highlight>Real Fantasy\u003C/color>.\\n- Roccia exits this state when she is not airborne or when switched off the field.\",\n    \"param\": []\n  },\n  \"850017\": {\n    \"name\": \"Moldable Crystal\",\n    \"desc\": \"Carlotta can hold up to 6 Moldable Crystals.\\n- Cannot gain Moldable Crystal while in \u003Ccolor=Highlight>Twilight Tango\u003C/color> triggered by Resonance Liberation.\\n- Restore 3 Moldable Crystals upon casting \u003Ccolor=Highlight>Basic Attack Stage 2\u003C/color>.\\n- Restore 3 Moldable Crystals upon casting \u003Ccolor=Highlight>Heavy Attack\u003C/color>.\\n- Restore 3 Moldable Crystals upon casting Mid-air Attack \u003Ccolor=Highlight>Customary Greetings\u003C/color>.\\n- Restore 3 Moldable Crystals upon casting Intro Skill \u003Ccolor=Highlight>Wintertime Aria\u003C/color>.\\n- Restore 3 Moldable Crystals upon casting Resonance Skill \u003Ccolor=Highlight>Art of Violence\u003C/color>.\\n- Restore 3 Moldable Crystals upon a successful \u003Ccolor=Highlight>Dodge\u003C/color>.\",\n    \"param\": []\n  },\n  \"850018\": {\n    \"name\": \"Substance\",\n    \"desc\": \"Carlotta can hold up to 120 points of Substance.\\n- Cannot gain Substance while in \u003Ccolor=Highlight>Twilight Tango\u003C/color> triggered by Resonance Liberation.\\n- Restore 30 points of Substance upon casting Intro Skill \u003Ccolor=Highlight>Wintertime Aria\u003C/color>.\\n- Restore 10 points of Substance for every 1 Moldable Crystal consumed upon casting Resonance Skill \u003Ccolor=Highlight>Chromatic Splendor\u003C/color>.\\n- Restore 10 points of Substance for every 1 Moldable Crystal consumed upon casting Basic Attack \u003Ccolor=Highlight>Necessary Measures\u003C/color>.\\n- Consume 1 Moldable Crystal and restore 10 points of Substance upon casting \u003Ccolor=Highlight>Dodge Counter\u003C/color>.\",\n    \"param\": []\n  },\n  \"850019\": {\n    \"name\": \"Deconstruction\",\n    \"desc\": \"Dealing DMG to targets inflicted with \u003Ccolor=Highlight>Deconstruction\u003C/color> ignores 18% of their DEF.\",\n    \"param\": []\n  },\n  \"850020\": {\n    \"name\": \"Dispersion\",\n    \"desc\": \"Targets with Dispersion are immobilized for 1.5s.\",\n    \"param\": []\n  },\n  \"850021\": {\n    \"name\": \"Budding Mode\",\n    \"desc\": \"- \u003Ccolor=Highlight>Sweet Dream\u003C/color>: Increase the DMG Multiplier of \u003Ccolor=Highlight>Normal Attack\u003C/color>, Basic Attack \u003Ccolor=Highlight>Vining Waltz\u003C/color>, Basic Attack \u003Ccolor=Highlight>Blazing Waltz\u003C/color>, Basic Attack \u003Ccolor=Highlight>Vining Ronde\u003C/color>, Dodge Counter \u003Ccolor=Highlight>Atonement\u003C/color>, Resonance Skill \u003Ccolor=Highlight>Crimson Blossom\u003C/color>, and Resonance Skill \u003Ccolor=Highlight>Floral Ravage\u003C/color> by 150%.\\n- Casting \u003Ccolor=Highlight>Ephemeral\u003C/color> consumes all Crimson Buds. Each Crimson Bud consumed additionally increases the DMG Multiplier of \u003Ccolor=Highlight>Sweet Dream\u003C/color> by 5%, up to 50%. \\n- When in \u003Ccolor=Highlight>Budding Mode\u003C/color>, Camellya cannot gain Crimson Buds.\\n- When in \u003Ccolor=Highlight>Budding Mode\u003C/color>, the Energy Regen Multiplier of \u003Ccolor=Highlight>Normal Attack\u003C/color>, Basic Attack \u003Ccolor=Highlight>Vining Waltz\u003C/color>, Basic Attack \u003Ccolor=Highlight>Blazing Waltz\u003C/color>, Basic Attack \u003Ccolor=Highlight>Vining Ronde\u003C/color>, Dodge Counter \u003Ccolor=Highlight>Atonement\u003C/color>, Resonance Skill \u003Ccolor=Highlight>Crimson Blossom\u003C/color>, and Resonance Skill \u003Ccolor=Highlight>Floral Ravage\u003C/color> is reduced to 0%.\\n- \u003Ccolor=Highlight>Budding Mode\u003C/color> ends when Camellya is switched off the field.\\n- \u003Ccolor=Highlight>Budding Mode\u003C/color> ends when all Crimson Pistils are consumed.\",\n    \"param\": []\n  },\n  \"850022\": {\n    \"name\": \"Collapsed Core\",\n    \"desc\": \"Hitting a target with a Normal Attack generates a \u003Ccolor=Highlight>Collapsed Core\u003C/color>, which transforms into a \u003Ccolor=Highlight>Flare Star Butterfly\u003C/color> after 6s. \u003Ccolor=Highlight>Flare Star Butterflies\u003C/color> automatically track and attack a target, dealing \u003Ccolor=Light>Spectro DMG\u003C/color>. If there are already 5 \u003Ccolor=Highlight>Collapsed Cores\u003C/color>, Shorekeeper's next \u003Ccolor=Highlight>Basic Attack\u003C/color> hit will instantly convert a \u003Ccolor=Highlight>Collapsed Core\u003C/color> into a \u003Ccolor=Highlight>Flare Star Butterfly\u003C/color>.\",\n    \"param\": []\n  },\n  \"850023\": {\n    \"name\": \"Stellarealm\",\n    \"desc\": \"Generate a \u003Ccolor=Highlight>Stellarealm\u003C/color> to restore HP for all party members within its effective range continuously. This effect can be triggered once every 3s.\",\n    \"param\": []\n  },\n  \"850024\": {\n    \"name\": \"Outer Stellarealm\",\n    \"desc\": \"Generate a \u003Ccolor=Highlight>Stellarealm\u003C/color> to restore HP for all party members within its effective range continuously. This effect can be triggered once every 3s.\",\n    \"param\": []\n  },\n  \"850025\": {\n    \"name\": \"Intuition\",\n    \"desc\": \"When in the \u003Ccolor=Highlight>Intuition\u003C/color> state:\\n- Gain 3 Hypercubes. Each time Resonance Skill \u003Ccolor=Highlight>Law of Reigns\u003C/color> is cast, consume 1 Hypercube. \u003Ccolor=Highlight>Intuition\u003C/color> ends once all Hypercubes are consumed.\\n- \u003Ccolor=Highlight>Basic Attack\u003C/color> and \u003Ccolor=Highlight>Heavy Attack\u003C/color> are replaced with Basic Attack \u003Ccolor=Highlight>Pivot - Impale\u003C/color>, dealing \u003Ccolor=Thunder>Electro DMG\u003C/color>.\\n- Resonance Skill \u003Ccolor=Highlight>Deduction\u003C/color> becomes Resonance Skill \u003Ccolor=Highlight>Divergence\u003C/color>, dealing \u003Ccolor=Thunder>Electro DMG\u003C/color>.\\n- \u003Ccolor=Highlight>Dodge Counter\u003C/color> becomes Dodge Counter \u003Ccolor=Highlight>Unfathomed\u003C/color>, dealing Resonance Liberation DMG.\",\n    \"param\": []\n  },\n  \"850026\": {\n    \"name\": \"Phatasmic Imprint\",\n    \"desc\": \"\u003Csize=40>\u003Ccolor=Title>Resonance Skill - Stroke of Genius\u003C/color>\u003C/size>\\nWhen a \u003Ccolor=Highlight>Phatasmic Imprint\u003C/color> is nearby, Zhezhi's Resonance Skill is replaced with \u003Ccolor=Highlight>Stroke of Genius\u003C/color>, which can be cast while in mid-air. When it is cast, Zhezhi will:\\n- Move to the location of the \u003Ccolor=Highlight>Phatasmic Imprint\u003C/color>, remove it, and then summon an Ivory Herald to attack the target, dealing \u003Ccolor=Ice>Glacio DMG\u003C/color>, considered as Basic Attack DMG. Refresh the mid-air Dodge attempts if the target \u003Ccolor=Highlight>Phatasmic Imprint\u003C/color> is in mid-air.\\n- Gain 1 stack of Painter's Delight, lasting for 8s and stacking up to 2 times.\\n\u003Csize=10>\u003C/size>\\n\u003Csize=40>\u003Ccolor=Title>Resonance Skill - Creation's Zenith\u003C/color>\u003C/size>\\nWhen a \u003Ccolor=Highlight>Phantasmic Imprint\u003C/color> is nearby and there are 2 stacks of Painter's Delight, \u003Ccolor=Highlight>Stroke of Genius\u003C/color> is replaced with \u003Ccolor=Highlight>Creation's Zenith\u003C/color>, which can be cast while in mid-air. When it is cast, Zhezhi will:\\n- Lose all stacks of Painter's Delight\\n- Move to the location of the \u003Ccolor=Highlight>Phantasmic Imprint\u003C/color>, remove it, and then summon an Ivory Herald to attack the target, dealing greater \u003Ccolor=Ice>Glacio DMG\u003C/color>, considered as Basic Attack DMG, additionally increasing the Basic Attack DMG Bonus by 18% for 27s. Refresh the mid-air Dodge attempts if the target \u003Ccolor=Highlight>Phatasmic Imprint\u003C/color> is in mid-air.\",\n    \"param\": []\n  },\n  \"850027\": {\n    \"name\": \"Resonance Energy\",\n    \"desc\": \"When Resonance Energy is full, the powerful \u003Ccolor=Highlight>Resonance Liberation\u003C/color> becomes available.\",\n    \"param\": []\n  },\n  \"850028\": {\n    \"name\": \"Afflatus\",\n    \"desc\": \"Zhezhi can hold up to 90 Afflatus.\\nNormal Attacks grant Afflatus on hit.\\nCasting Intro Skill grants Afflatus.\",\n    \"param\": []\n  },\n  \"850029\": {\n    \"name\": \"Sinner's Mark\",\n    \"desc\": \"Normal Attack \u003Ccolor=Highlight>Zapstring's Dance\u003C/color>, Resonance Liberation \u003Ccolor=Highlight>Thundering Wrath\u003C/color>, and Intro Skill \u003Ccolor=Highlight>Raging Storm\u003C/color> will apply \u003Ccolor=Highlight>Sinner's Mark\u003C/color> on hit.\\n\u003Ccolor=Highlight>Sinner's Mark\u003C/color> is removed when Yinlin leaves the field.\",\n    \"param\": []\n  },\n  \"850030\": {\n    \"name\": \"Judgement Points\",\n    \"desc\": \"Yinlin can hold up to 100 Judgement Points. Yinlin gains Judgement Points through the following ways:\\nUpon casting Intro Skill \u003Ccolor=Highlight>Raging Storm\u003C/color>;\\nWhen Basic Attack \u003Ccolor=Highlight>Zapstring's Dance\u003C/color> hits a target;\\nUpon casting Resonance Skill \u003Ccolor=Highlight>Magnetic Roar\u003C/color>;\\nWhen Resonance Skill \u003Ccolor=Highlight>Electromagnetic Blast\u003C/color> hits a target;\\nUpon casting Resonance Skill \u003Ccolor=Highlight>Lightning Execution\u003C/color>.\",\n    \"param\": []\n  },\n  \"850031\": {\n    \"name\": \"Qingloong Mode\",\n    \"desc\": \"- Jiyan's resistance to interruption increases.\\n- \u003Ccolor=Highlight>Basic Attack\u003C/color>, \u003Ccolor=Highlight>Heavy Attack\u003C/color>, and \u003Ccolor=Highlight>Dodge Counter\u003C/color> are replaced with Heavy Attack \u003Ccolor=Highlight>Lance of Qingloong\u003C/color>.\",\n    \"param\": []\n  },\n  \"850032\": {\n    \"name\": \"Resolve\",\n    \"desc\": \"Jiyan can hold up to 60 Resolve.\\nJiyan gains Resolve when his Normal Attack \u003Ccolor=Highlight>Lone Lance\u003C/color> hits the target.\\nJiyan gains Resolve when the Intro Skill \u003Ccolor=Highlight>Tactical Strike\u003C/color> hits the target.\\nResolve will gradually decrease if Jiyan does not hit a target within 15s.\",\n    \"param\": []\n  },\n  \"850033\": {\n    \"name\": \"Concentration\",\n    \"desc\": \"Baizhi can hold up to 4 Concentration.\\nBaizhi obtains 1 Concentration for every \u003Ccolor=Highlight>Basic Attack\u003C/color> on hit.\",\n    \"param\": []\n  },\n  \"850034\": {\n    \"name\": \"Dark Surge\",\n    \"desc\": \"After casting \u003Ccolor=Highlight>Devastation\u003C/color>, Rover enters the \u003Ccolor=Highlight>Dark Surge\u003C/color> state. In this state:\\n- \u003Ccolor=Highlight>Basic Attack\u003C/color> is replaced with \u003Ccolor=Highlight>Enhanced Basic Attack\u003C/color>, which performs up to 5 consecutive attacks, dealing \u003Ccolor=Dark>Havoc DMG\u003C/color>.\\n- \u003Ccolor=Highlight>Heavy Attack\u003C/color> is replaced with \u003Ccolor=Highlight>Enhanced Heavy Attack\u003C/color>;\\n- Use \u003Ccolor=Highlight>Basic Attack\u003C/color> after casting \u003Ccolor=Highlight>Enhanced Heavy Attack\u003C/color> to cast Heavy Attack \u003Ccolor=Highlight>Thwackblade\u003C/color> to attack the target, dealing \u003Ccolor=Dark>Havoc DMG\u003C/color>, considered as Heavy Attack DMG.\\n- Use \u003Ccolor=Highlight>Basic Attack\u003C/color> after casting Heavy Attack \u003Ccolor=Highlight>Thwackblade\u003C/color> to cast \u003Ccolor=Highlight>Enhanced Basic Attack 3\u003C/color> to attack the target, dealing \u003Ccolor=Dark>Havoc DMG\u003C/color>;\\n- Resonance Skill \u003Ccolor=Highlight>Wingblade\u003C/color> is replaced with Resonance Skill \u003Ccolor=Highlight>Lifetaker\u003C/color>, transforming sounds into blades to attack the target, dealing \u003Ccolor=Dark>Havoc DMG\u003C/color>.\",\n    \"param\": []\n  },\n  \"850035\": {\n    \"name\": \"Ice Prism\",\n    \"desc\": \"Can be detonated by Heavy Attack \u003Ccolor=Highlight>Detonate\u003C/color>, dealing \u003Ccolor=Ice>Glacio DMG\u003C/color>.\",\n    \"param\": []\n  },\n  \"850036\": {\n    \"name\": \"Ice Thorn\",\n    \"desc\": \"Can be detonated by Heavy Attack \u003Ccolor=Highlight>Detonate\u003C/color>, dealing \u003Ccolor=Ice>Glacio DMG\u003C/color>.\",\n    \"param\": []\n  },\n  \"850037\": {\n    \"name\": \"Glacier\",\n    \"desc\": \"Can be detonated by Heavy Attack \u003Ccolor=Highlight>Detonate\u003C/color>, dealing \u003Ccolor=Ice>Glacio DMG\u003C/color>.\",\n    \"param\": []\n  },\n  \"850038\": {\n    \"name\": \"Burning Rhapsody\",\n    \"desc\": \"- When the active Resonator's \u003Ccolor=Highlight>Basic Attack\u003C/color> hits the target, Mortefi launches a Coordinated Attack, firing 1 \u003Ccolor=Highlight>Marcato\u003C/color>.\\n- When the active Resonator's \u003Ccolor=Highlight>Heavy Attack\u003C/color> hits the target, Mortefi launches a Coordinated Attack, firing 2 \u003Ccolor=Highlight>Marcato\u003C/color>.\\nMortefi can launch one Coordinated Attack every 0.35s.\",\n    \"param\": []\n  },\n  \"850039\": {\n    \"name\": \"Ruby Blossom\",\n    \"desc\": \"Danjin can hold up to 120 Ruby Blossom.\\nDanjin obtains Ruby Blossom when using Resonance Skill \u003Ccolor=Highlight>Crimson Fragment\u003C/color>.\",\n    \"param\": []\n  },\n  \"850040\": {\n    \"name\": \"Incinerating Will\",\n    \"desc\": \"When Danjin attacks a target with Resonance Skill's \u003Ccolor=Highlight>Incinerating Will\u003C/color>, her damage dealt is increased by 20%.\",\n    \"param\": []\n  },\n  \"850041\": {\n    \"name\": \"Thermobaric Bullets\",\n    \"desc\": \"Chixia can hold up to 60 Thermobaric Bullets.\\nInherent Skill \u003Ccolor=Highlight>Scorching Magazine\u003C/color> increases Max Thermobaric Bullets by 10.\\nChixia obtains Thermobaric Bullets for every Normal Attack \u003Ccolor=Highlight>POW POW\u003C/color> on hit.\\nChixia obtains Thermobaric Bullets upon casting Intro Skill \u003Ccolor=Highlight>Grand Entrance\u003C/color> and Resonance Skill \u003Ccolor=Highlight>Whizzing Fight Spirit\u003C/color>.\",\n    \"param\": []\n  },\n  \"850042\": {\n    \"name\": \"Chi\",\n    \"desc\": \"Jianxin can hold up to 120 Chi.\\nChi is obtained when Normal Attack \u003Ccolor=Highlight>Fengyiquan\u003C/color> hits the target.\\nChi is obtained when the Resonance Skill \u003Ccolor=Highlight>Calming Air\u003C/color> is cast.\\nChi is obtained when the Resonance Skills \u003Ccolor=Highlight>Chi Counter\u003C/color> or \u003Ccolor=Highlight>Chi Parry\u003C/color> hits the target.\\nChi is obtained when the Intro Skill \u003Ccolor=Highlight>Essence of Tao\u003C/color> hits the target.\",\n    \"param\": []\n  },\n  \"850043\": {\n    \"name\": \"Yellow Light Mode\",\n    \"desc\": \"Perform ranged attacks when in Yellow Light Mode.\",\n    \"param\": []\n  },\n  \"850044\": {\n    \"name\": \"Red Light Mode\",\n    \"desc\": \"Perform melee attacks when in Red Light Mode.\",\n    \"param\": []\n  },\n  \"850045\": {\n    \"name\": \"Lucky Draw\",\n    \"desc\": \"Youhu obtains a random \u003Ccolor=Highlight>Antique\u003C/color> after the \u003Ccolor=Highlight>Lucky Draw\u003C/color>. With an \u003Ccolor=Highlight>Antique\u003C/color>, her next \u003Ccolor=Highlight>Basic Attack\u003C/color> will activate the corresponding \u003Ccolor=Highlight>Antique Appraisal\u003C/color>.\\nOnly one \u003Ccolor=Highlight>Antique\u003C/color> can exist at a time, and the newly drawn \u003Ccolor=Highlight>Antique\u003C/color> will replace the existing one.\",\n    \"param\": []\n  },\n  \"850046\": {\n    \"name\": \"Antique\",\n    \"desc\": \"With an \u003Ccolor=Highlight>Antique\u003C/color>, Youhu's next \u003Ccolor=Highlight>Basic Attack\u003C/color> will activate the corresponding \u003Ccolor=Highlight>Antique Appraisal\u003C/color>.\\nOnly one \u003Ccolor=Highlight>Antique\u003C/color> can exist at a time, and the newly drawn \u003Ccolor=Highlight>Antique\u003C/color> will replace the existing one.\",\n    \"param\": []\n  },\n  \"850047\": {\n    \"name\": \"Rocksteady Shield\",\n    \"desc\": \"When the active character on the team is attacked, 1 Rocksteady Shield is consumed to reduce the damage taken.\",\n    \"param\": []\n  },\n  \"850048\": {\n    \"name\": \"Mist\",\n    \"desc\": \"- When Aalto passes through Mist or Gate of Quandary, he enters the \u003Ccolor=Highlight>Mistcloak Dash\u003C/color>.\\n- When \u003Ccolor=Highlight>Basic Attack\u003C/color> or \u003Ccolor=Highlight>Mid-air Attack\u003C/color> passes through Mist and hits the target, 1 Mist Drop is recovered.\",\n    \"param\": []\n  },\n  \"850049\": {\n    \"name\": \"Gate of Quandary\",\n    \"desc\": \"When Aalto passes through Mist or Gate of Quandary, he enters the \u003Ccolor=Highlight>Mistcloak Dash\u003C/color>.\",\n    \"param\": []\n  },\n  \"850050\": {\n    \"name\": \"Bravo\",\n    \"desc\": \"Brant can hold up to 100 Bravo.\\n- Obtain Bravo when Normal Attacks hit the target.\\n- Obtain Bravo when Intro Skill hits the target.\\n- Obtain Bravo when Resonance Skill hits the target.\",\n    \"param\": []\n  },\n  \"850051\": {\n    \"name\": \"Aflame\",\n    \"desc\": \"The efficiency of gaining Bravo is increased by 100% when \u003Ccolor=Highlight>Normal Attack\u003C/color> or Resonance Skill \u003Ccolor=Highlight>Anchors Aweigh!\u003C/color> hits the target. Meanwhile, Forte Circuit \u003Ccolor=Highlight>Theatrical Moment\u003C/color> is replaced by \u003Ccolor=Highlight>\\\"My\\\" Moment\u003C/color>.\",\n    \"param\": []\n  },\n  \"850052\": {\n    \"name\": \"Theatrical Moment\",\n    \"desc\": \"Brant gains additional ATK based on his Energy Regen: For every 1% of his Energy Regen over 150%, Brant gains additional 12 points of ATK, up to 1560.\",\n    \"param\": []\n  },\n  \"850053\": {\n    \"name\": \"Waves of Acclaims\",\n    \"desc\": \"Heal all nearby Resonators in the team when Bravo reaches 25, 50, 75, and 100.\",\n    \"param\": []\n  },\n  \"850054\": {\n    \"name\": \"Mirage\",\n    \"desc\": \"- \u003Ccolor=Highlight>Basic Attack\u003C/color> becomes Basic Attack \u003Ccolor=Highlight>Phantom Sting\u003C/color>. Perform up to 3 consecutive attacks, dealing \u003Ccolor=Dark>Havoc DMG\u003C/color>. Can be cast in mid-air. When cast mid-air, Basic Attack \u003Ccolor=Highlight>Phantom Sting\u003C/color> consumes STA, and the combo does not reset when Cantarella is airborne.\\n- Hitting the target with Basic Attack \u003Ccolor=Highlight>Phantom Sting\u003C/color> consumes 1 point of Trance to obtain 1 point of Shiver and heal all nearby Resonators in the team.\\n- The third stage of Basic Attack \u003Ccolor=Highlight>Phantom Sting\u003C/color> triggers 3 Coordinated Attacks, dealing \u003Ccolor=Dark>Havoc DMG\u003C/color>.\\n- \u003Ccolor=Highlight>Mid-air Attack\u003C/color> becomes \u003Ccolor=Highlight>Abysmal Vortex\u003C/color>. {Cus:Ipt,Touch=Tap PC=Press Gamepad=Press} \u003Ccolor=Highlight>Jump\u003C/color> to perform a Plunging Attack at the cost of STA, dealing \u003Ccolor=Dark>Havoc DMG\u003C/color>.\\n- \u003Ccolor=Highlight>Dodge Counter\u003C/color> becomes Dodge Counter \u003Ccolor=Highlight>Shadowy Sweep\u003C/color>. Attack the target, dealing \u003Ccolor=Dark>Havoc DMG\u003C/color>. {Cus:Ipt,Touch=Tap PC=Press Gamepad=Press} \u003Ccolor=Highlight>Normal Attack\u003C/color> right after casting the skill to cast Basic Attack \u003Ccolor=Highlight>Phantom Sting Stage 2\u003C/color>.\\n- When Mid-air Attack \u003Ccolor=Highlight>Abysmal Vortex\u003C/color> or Dodge Counter \u003Ccolor=Highlight>Shadowy Sweep\u003C/color> hits a target, consume 1 point of Trance to obtain 1 point of Shiver and heal all nearby Resonators in the team.\\n- Mirage lasts for 8s.\\n- \u003Ccolor=Highlight>Mirage\u003C/color> ends when Trance is depleted.\",\n    \"param\": []\n  },\n  \"850055\": {\n    \"name\": \"Hazy Dream\",\n    \"desc\": \"Reduce the target's movement speed for 6.5s. When the target takes damage, \u003Ccolor=Highlight>Jolt\u003C/color> is triggered once, removing \u003Ccolor=Highlight>Hazy Dream\u003C/color> to deal \u003Ccolor=Dark>Havoc DMG\u003C/color>, considered Basic Attack DMG.\\nAttacks by other Resonators in the team will not \u003Ccolor=Highlight>Jolt\u003C/color> a target influenced by \u003Ccolor=Highlight>Hazy Dream\u003C/color> and will remove the \u003Ccolor=Highlight>Hazy Dream\u003C/color>. \\nCoordinated Attacks and damage from Utilities will not trigger \u003Ccolor=Highlight>Jolt\u003C/color>.\",\n    \"param\": []\n  },\n  \"850056\": {\n    \"name\": \"Windstring\",\n    \"desc\": \"Rover can hold up to 120 Windstrings.\\nEach stage of Mid-air Attack \u003Ccolor=Highlight>Cloudburst Dance\u003C/color> restores 25 Windstrings on hit.\\nCasting \u003Ccolor=Highlight>Intro Skill\u003C/color> restores 20 Windstrings.\\nHitting a target with \u003Ccolor=Highlight>Basic Attack Stage 3 or 4\u003C/color> or \u003Ccolor=Highlight>Dodge Counter\u003C/color> restores 10 Windstrings.\",\n    \"param\": []\n  },\n  \"850057\": {\n    \"name\": \"Euphonia\",\n    \"desc\": \"ATK of the Resonators who pick up Euphonia is increased by 15% for 20s.\",\n    \"param\": []\n  },\n  \"850058\": {\n    \"name\": \"Striding Lion\",\n    \"desc\": \"In the \u003Ccolor=Highlight>Striding Lion\u003C/color> state:\\n- Attacks can be launched in mid-air. If Lingyang is on the ground, use Heavy Attack \u003Ccolor=Highlight>Glorious Plunge\u003C/color> to get back in the air.\\n- Lion's Spirit is continuously consumed before running out in 5s, and when it runs out, \u003Ccolor=Highlight>Striding Lion\u003C/color> ends;\\n- If Lingyang is in the Resonance Liberation \u003Ccolor=Highlight>Lion's Vigor\u003C/color> state, the consumption speed of Lion's Spirit is reduced by 50%, extending \u003Ccolor=Highlight>Striding Lion\u003C/color> state by up to 10s.\\n- Lingyang's \u003Ccolor=Highlight>Basic Attack\u003C/color> is replaced with Basic Attack \u003Ccolor=Highlight>Feral Gyrate\u003C/color>, which performs up to 2 consecutive attacks, dealing \u003Ccolor=Ice>Glacio DMG\u003C/color>;\\n- Lingyang's \u003Ccolor=Highlight>Resonance Skill\u003C/color> is replaced with \u003Ccolor=Highlight>Mountain Roamer\u003C/color>, dealing \u003Ccolor=Ice>Glacio DMG\u003C/color>;\\n- When Lion's Spirit is less than 10, use \u003Ccolor=Highlight>Basic Attack\u003C/color> to perform \u003Ccolor=Highlight>Stormy Kicks\u003C/color>, dealing \u003Ccolor=Ice>Glacio DMG\u003C/color>; after performing Basic Attack \u003Ccolor=Highlight>Stormy Kicks\u003C/color>, the Mid-air Attack \u003Ccolor=Highlight>Tail Strike\u003C/color> becomes available.\\n- Concerto Energy is restored when Lion's Spirit is consumed.\",\n    \"param\": []\n  },\n  \"850059\": {\n    \"name\": \"Ensemble Sylph\",\n    \"desc\": \"Up to 2 \u003Ccolor=Highlight>Ensemble Sylphs\u003C/color> may exist simultaneously.\\nIf Ciaccona's Basic Attack Stage 4 is interrupted, the \u003Ccolor=Highlight>Ensemble Sylphs\u003C/color> generated will finish the action for Ciaccona and send Ciaccona into \u003Ccolor=Highlight>Solo Concert\u003C/color>.\\nIf Ciaccona's \u003Ccolor=Highlight>Solo Concert\u003C/color> is interrupted, the \u003Ccolor=Highlight>Ensemble Sylphs\u003C/color> generated will continue the \u003Ccolor=Highlight>Solo Concert\u003C/color> for Ciaccona.\",\n    \"param\": []\n  },\n  \"850060\": {\n    \"name\": \"Solo Concert\",\n    \"desc\": \"When Ciaccona or Ensemble Sylph performs Solo Concert, they give 24% Aero DMG Bonus to all nearby Resonators in the team. This effect is not stackable.\",\n    \"param\": []\n  },\n  \"850061\": {\n    \"name\": \"Musical Essence\",\n    \"desc\": \"Ciaccona can hold up to 3 segments of Musical Essence.\\nCasting \u003Ccolor=Highlight>Basic Attack Stage 4\u003C/color> and \u003Ccolor=Highlight>Intro Skill\u003C/color> recovers 1 segment of Musical Essence.\",\n    \"param\": []\n  },\n  \"850062\": {\n    \"name\": \"Vibration Strength\",\n    \"desc\": \"When the Vibration Strength is depleted, the enemy is \u003Ccolor=Highlight>Immobilized\u003C/color> and cannot take any action for a period of time.\",\n    \"param\": []\n  },\n  \"850063\": {\n    \"name\": \"Redundant Energy\",\n    \"desc\": \"Zani can hold up to 100 Redundant Energy.\\nObtain Redundant Energy when Normal Attacks hit a target.\\nObtain Redundant Energy when Intro Skill \u003Ccolor=Highlight>Immediate Execution\u003C/color> hits a target.\\nObtain Redundant Energy when casting Resonance Skill \u003Ccolor=Highlight>Standard Defense Protocol\u003C/color>.\\nObtain Redundant Energy when casting Resonance Skill \u003Ccolor=Highlight>Pinpoint Strike\u003C/color>.\\nCannot obtain Redundant Energy while in \u003Ccolor=Highlight>Inferno Mode\u003C/color>.\",\n    \"param\": []\n  },\n  \"850064\": {\n    \"name\": \"Inferno Mode\",\n    \"desc\": \"Casting Resonance Liberation Rekindle sends Zani into Infernal Mode.\",\n    \"param\": []\n  },\n  \"850065\": {\n    \"name\": \"Blaze\",\n    \"desc\": \"Blaze is capped at 100 when not in \u003Ccolor=Highlight>Inferno Mode\u003C/color>.\\nBlaze is capped at 150 in \u003Ccolor=Highlight>Inferno Mode\u003C/color>.\\nCasting Resonance Skill \u003Ccolor=Highlight>Crisis Response Protocol\u003C/color> grants 10 Blazes.\\nEvery stack of Heliacal Ember converted from \u003Ccolor=Highlight>Spectro Frazzle\u003C/color> grants 5 Blazes.\\nCasting Resonance Liberation \u003Ccolor=Highlight>Rekindle\u003C/color> grants 50 Blazes.\",\n    \"param\": []\n  },\n  \"850066\": {\n    \"name\": \"Heliacal Ember\",\n    \"desc\": \"When Zani is in the team and a nearby Resonator inflicts \u003Ccolor=Highlight>Spectro Frazzle\u003C/color> upon a target, immediately consume all Spectro Frazzle stacks and trigger the corresponding DMG, then convert Spectro Frazzle into equal stacks of Heliacal Ember. Every time the conversion happens, Zani obtains Blaze based on the stacks of Heliacal Ember inflicted. Heliacal Ember is capped at 60 stacks, with each stack lasting for 6s. Heliacal Ember stacks are counted toward the Spectro Frazzle stacks for the Eternal Radiance Sonata Effect.\",\n    \"param\": []\n  },\n  \"850067\": {\n    \"name\": \"Rabelle's Curve\",\n    \"desc\": \"Developed by Dr. Scott Rabelle, this method was originally designed to examine Resonators. It is also known as \\\"Rabelle's Test.\\\"\\nKnown for its safety, reliability, and ease of use, the test has since been adopted across multiple regions.\",\n    \"param\": []\n  },\n  \"850068\": {\n    \"name\": \"Congenital Resonator\",\n    \"desc\": \"A Resonator born with innate Forte.\",\n    \"param\": []\n  },\n  \"850069\": {\n    \"name\": \"Mutant Resonator\",\n    \"desc\": \"A Resonator who awakened their Forte through a life-changing event.\",\n    \"param\": []\n  },\n  \"850070\": {\n    \"name\": \"Natural Resonator\",\n    \"desc\": \"A Resonator who naturally awakened their Forte during their growth.\",\n    \"param\": []\n  },\n  \"850071\": {\n    \"name\": \"Induced Resonator\",\n    \"desc\": \"A Resonator whose latent Forte was prematurely awakened via controlled artificial stimulation.\",\n    \"param\": []\n  },\n  \"850072\": {\n    \"name\": \"Tacet Mark\",\n    \"desc\": \"A mark found either on a Resonator's skin or the ground of a Tacet Field.\\nFor Resonators, these marks serve as conduits for their Forte, a sign of their rebirth after awakening.\\nIn Tacet Fields, the mark becomes the focal point where chaotic energy coalesces, forming the white Resonance Cord that births endless Tacet Discords into this world.\",\n    \"param\": []\n  },\n  \"850073\": {\n    \"name\": \"Overclocking\",\n    \"desc\": \"Overuse of power or obsession can overload a Resonator's mind and Forte, leading to Overclocking.\\nWhile Overclocking can be controlled, there is currently no known permanent cure.\",\n    \"param\": []\n  },\n  \"850074\": {\n    \"name\": \"Threnodian\",\n    \"desc\": \"Threnodians are formidable creatures born from the Laments, with the power to destroy human spirit and feed off of their collapsed will. If civilizations represent mankind's collective will, the Threnodians embody our fears and struggles. They manifest as destructive Tacet Discord disasters spreading across the planet.\",\n    \"param\": []\n  },\n  \"850075\": {\n    \"name\": \"Lament\",\n    \"desc\": \"The term \\\"Lament\\\" refers to the ongoing catastrophic events on Solaris-3. Since the onset of the first Lament, the cycle of destruction has persisted relentlessly. The tide of devastation remains ceaseless, with no signs of stopping.\",\n    \"param\": []\n  },\n  \"850076\": {\n    \"name\": \"Remnant Energy\",\n    \"desc\": \"A form of pure energy with complete frequencies. The information it carries transcends time and space, enduring in a stable, unchanging state.\",\n    \"param\": []\n  },\n  \"850077\": {\n    \"name\": \"Sonoro Sphere\",\n    \"desc\": \"Transdimensional spaces where Remnant Energy is abundant are known as the Sonoro Spheres.\",\n    \"param\": []\n  },\n  \"850078\": {\n    \"name\": \"Tacet Field\",\n    \"desc\": \"The \\\"Tacet Fields\\\" are thought to be where all Tacet Discords originate. These locations feature a sky of inverted seas and a deep cross-shaped Tacet Mark on the ground. Reverberations fill the air, linking our world to an unknown space through a white Resonance Cord. These areas attract gatherings of Tacet Discords.\",\n    \"param\": []\n  },\n  \"850079\": {\n    \"name\": \"Solaris\",\n    \"desc\": \"SOL-3, the third planet from the sun. A world of chaos and change, where old conventions are discarded and disasters run rampant. Human civilization struggles to survive in this new era of destruction and rebirth, facing uncharted challenges with unwavering determination.\",\n    \"param\": []\n  },\n  \"850080\": {\n    \"name\": \"Waveworn Phenomena\",\n    \"desc\": \"The Lament's power causes destructive waves across the land of Solaris. Manifestations like the \\\"Tacet Fields,\\\" \\\"Tacet Discord Outbreaks,\\\" and the enigmatic \\\"Tacetite\\\" are part of what is collectively known as the \\\"Waveworn Phenomena.\\\"\",\n    \"param\": []\n  },\n  \"850081\": {\n    \"name\": \"Tacet Discord\",\n    \"desc\": \"Tacet Discords, beings created by the Waveworn Phenomena bearing \\\"Tacet Cores\\\", are dangerous entities with ever-changing, amorphous forms, which feed on other frequencies to maintain stability and evolution. These creatures mimic their prey's abilities, shapes, and behaviors, influenced by the types of frequency they consume.\",\n    \"param\": []\n  },\n  \"850082\": {\n    \"name\": \"Echo\",\n    \"desc\": \"A type of special frequency that can be captured by the Terminal to reproduce Tacet Discords' abilities.\\nThere's a chance for Tacet Discords to leave behind \\\"Reverberations\\\" when they are eliminated, which can then be transformed into \\\"Echoes\\\" through the Terminal's Data Bank, providing a useful advantage in battle.\",\n    \"param\": []\n  },\n  \"850083\": {\n    \"name\": \"Sentinel\",\n    \"desc\": \"Wherever there is civilization and history, there will be Sentinels. They serve as mankind's guardians and conductors. Their immortal existence has helped humanity through countless troubles, sharing wisdom and prophecies. As humanity embarks on a new journey after enduring the Lament, the Sentinels remain as the record keeper and beacon in times of disaster.\",\n    \"param\": []\n  },\n  \"850084\": {\n    \"name\": \"Magistrate\",\n    \"desc\": \"The Magistrate is a governing official who oversees one of the major regions within Huanglong.\",\n    \"param\": []\n  },\n  \"850085\": {\n    \"name\": \"Ministry of Development\",\n    \"desc\": \"The Ministry of Development serves as the engineering and construction arm of the Central Office of State Affairs.\\nIt is comprised of three key divisions: the Ordnance and Defense Divisions, which handle all military applications. And the Infrastructure Division, tasked with public works and construction projects.\",\n    \"param\": []\n  },\n  \"850086\": {\n    \"name\": \"Midnight Rangers\",\n    \"desc\": \"The Midnight Rangers are a military force under the Jinzhou Ministry of War, commanded by General Jiyan. They consist of three divisions: Outriders (reconnaissance), Vanguard (offensive operations), and Rearguard (defensive operations).\",\n    \"param\": []\n  },\n  \"850087\": {\n    \"name\": \"Patroller\",\n    \"desc\": \"Public Security Bureau staff who are responsible for the security issues of their jurisdictions.\",\n    \"param\": []\n  },\n  \"850088\": {\n    \"name\": \"Public Security Bureau\",\n    \"desc\": \"The local law enforcement arm of the Justice Commission. Operating through Patrol Stations, it maintains civil order and handles public security matters. Its officers are known as \\\"Patrollers.\\\"\",\n    \"param\": []\n  },\n  \"850089\": {\n    \"name\": \"Patrol Station\",\n    \"desc\": \"The local enforcement unit of the Public Security Bureau that handles routine security operations and maintains public order.\",\n    \"param\": []\n  },\n  \"850090\": {\n    \"name\": \"Lollo Logistics\",\n    \"desc\": \"Lollo Logistics is a trusted logistics company that delivers not only the tangible, but also the intangible.\\nWhether it's sending sweet words to a loved one or retrieving lost memories, if it's ordered and can be delivered, Lollo Logistics will handle them with care.\",\n    \"param\": []\n  },\n  \"850091\": {\n    \"name\": \"Jinzhou\",\n    \"desc\": \"Jinzhou, a fortified city on the frontier, stands guard against the looming Tacet Discord crisis. As one of Huanglong's six major regions, it bears the weight of this responsibility as the youngest provincial capital. The Midnight Rangers defend its northern border without hesitation.\",\n    \"param\": []\n  },\n  \"850092\": {\n    \"name\": \"Huaxu Academy\",\n    \"desc\": \"The state-run research institute of Huanglong, with branch organizations established in each city.\",\n    \"param\": []\n  },\n  \"850093\": {\n    \"name\": \"Huanglong\",\n    \"desc\": \"Located at the edge of the continent, this country borders the sea to the east. It boasts a vast territory with one capital and six major cities.\",\n    \"param\": []\n  },\n  \"850094\": {\n    \"name\": \"Fisalia\",\n    \"desc\": \"The most enduring and enigmatic family in Ragunna, the Fisalias are renowned for their expertise in medicine and poison crafting. Their unwavering devotion to the Sentinel is well-known among the citizens.\",\n    \"param\": []\n  },\n  \"850095\": {\n    \"name\": \"Porto-Veno Castle\",\n    \"desc\": \"Nestled on the edge of a cliff in Thessalleo Fells, Porto Veno Castle is a mysterious and magnificent residence of the Fisalias.\\nAmong all the Fisalia family properties across Rinacista, this imposing cliffside castle stands out as the most special. It is the home of the current head of the Fisalia family.\",\n    \"param\": []\n  },\n  \"850096\": {\n    \"name\": \"Rinascita\",\n    \"desc\": \"A nation of independent city-states scattered across a vast archipelago, with no central administrative center. It is also known as the \\\"Land of Echoes,\\\" which boasts unique natural and cultural landscapes.\\nLegends speak of how Rinascita's founders fled their homelands and sailed to these islands to escape the Lament.\",\n    \"param\": []\n  },\n  \"850097\": {\n    \"name\": \"Ragunna\",\n    \"desc\": \"One of the city-states in Rinascita, Ragunna is a thriving port city on the edge of the sea, its districts linked by winding waterways.\\nThe Ragunnesi are devout followers of the Sentinel, who believe Common Echoes to be gifts from the Sentinel that carry Their divine will.\",\n    \"param\": []\n  },\n  \"850098\": {\n    \"name\": \"Cathedral of Mercury\",\n    \"desc\": \"A two-tiered holy edifice in Ragunna City, devoted to the worship of the Sentinel's statue.\",\n    \"param\": []\n  },\n  \"850099\": {\n    \"name\": \"Order of the Deep\",\n    \"desc\": \"The de facto ruling authority of Ragunna that manages all city matters, from municipal policies and currency to civil disputes.\\nThe head of the Order, known as the Primus, is currently Fenrico, who claims to be the Enlightened One—the Resonator of Rinascita's Sentinel Imperator.\\nAccording to city tradition, the Order's clergy serve as the Sentinel's earthly emissaries, guiding the people with Their divine word.\",\n    \"param\": []\n  },\n  \"850100\": {\n    \"name\": \"Acolyte\",\n    \"desc\": \"Religious people devoted themselves to the Order of the Deep.\",\n    \"param\": []\n  },\n  \"850101\": {\n    \"name\": \"Montelli\",\n    \"desc\": \"One of the most powerful families in Ragunna, renowned for their pioneering spirit.\\nThe Montelli family played an instrumental role in charting trade routes that not only connect Ragunna, but also greater Rinascita to the wider world. As the city opened its doors, the Montellis rose to prominence, amassing great wealth and unmatched influence.\",\n    \"param\": []\n  },\n  \"850102\": {\n    \"name\": \"Carnevale\",\n    \"desc\": \"The Carnevale is the grandest celebration of Ragunna, a time with never-ending masquerades, wine flowing like rivers, and music pulsing through the night.\\nDuring this time, people cast aside the weight of the world and surrender to the wild, unrestrained joy of the festival.\",\n    \"param\": []\n  },\n  \"850103\": {\n    \"name\": \"Laurel\",\n    \"desc\": \"At the peak of the Carnevale, the Sentinel is said to manifest and crown the finest performer with the \\\"Laurel.\\\"\\nThis honor grants the bearer the privilege to commune with the Sentinel and hear Their wisdom.\",\n    \"param\": []\n  },\n  \"850104\": {\n    \"name\": \"Shell Credit\",\n    \"desc\": \"The universal currency issued by Huanglong, officially recognized across many regions.\\nIn the ancient past, the ancestors of Huanglong utilized seashells as currency. Though the manufacturing techniques have evolved over time, the shell-like appearance of this currency has endured.\",\n    \"param\": []\n  },\n  \"850105\": {\n    \"name\": \"Imperator\",\n    \"desc\": \"The Sentinel of Rinascita. Though worshipped as the Divinity by the Order of the Deep, Imperator rarely reveals Their presence to the public.\",\n    \"param\": []\n  },\n  \"850106\": {\n    \"name\": \"Cetus the Tidebreaker\",\n    \"desc\": \"A colossal, whale-like Tacet Discord. Depite its gentle nature, its gargantuan size can inadvertently cause significant destruction.\",\n    \"param\": []\n  },\n  \"850107\": {\n    \"name\": \"Averardo Bank\",\n    \"desc\": \"A Montelli bank situated at the heart of the Ragunna City.\",\n    \"param\": []\n  },\n  \"850108\": {\n    \"name\": \"Troupe of Fools\",\n    \"desc\": \"A troupe formed by exiles drifted to the Penitent's End on the Pilgrim's Sails for their supposed \\\"transgressions.\\\"\\nTo reveal the truth hidden by the Order, they wrote numerous plays and \\\"danced in chains,\\\" performing tirelessly across the archipelago.\",\n    \"param\": []\n  },\n  \"850109\": {\n    \"name\": \"The Black Shores\",\n    \"desc\": \"Solaris' foremost authority on observing the Lament cycle.\\nThrough constant observation and analysis of Lament's shifting patterns, this organization predicts and warns of impending manifestations before they occur.\",\n    \"param\": []\n  },\n  \"850110\": {\n    \"name\": \"Tethys\",\n    \"desc\": \"Also known as the Civilization Simulation Sand Table, the Tethys System is a supercomputer unique to the Black Shores. By inputting Lament frequency data—collected both manually and via beacon access—into the system, the Black Shores can issue Lament warnings for locations worldwide within a 24 to 48-hour time range. This capability is the cornerstone of the Black Shores' extensive collaborations with countries across the globe.\",\n    \"param\": []\n  },\n  \"850111\": {\n    \"name\": \"Modulator\",\n    \"desc\": \"Modulation is the process of adjusting frequencies. In Solaris-3, frequencies serve as a crucial tool for uncovering the truth about reality. By altering these frequencies, one can delve into the very core of existence.\\nAt the Black Shores, modulating Stellar Matrices is crucial for tracing and analyzing the Lament. Over the course of the Black Shores' history, only one individual has ever been honored with the title of \\\"The Modulator\\\"—Rover.\",\n    \"param\": []\n  },\n  \"850112\": {\n    \"name\": \"Jinzhou Patroller\",\n    \"desc\": \"Patrollers in Jinzhou.\",\n    \"param\": []\n  },\n  \"850113\": {\n    \"name\": \"Overdash\",\n    \"desc\": \"A globally popular competitive sport that puts both the strength and endurance of its participants to the test.\",\n    \"param\": []\n  },\n  \"850114\": {\n    \"name\": \"Leihuangquan\",\n    \"desc\": \"A unique martial art practiced by Yuanwu, known for its heavy and fierce strikes. However, only those who temper their strength with precise control can wield it without breaking themselves.\",\n    \"param\": []\n  },\n  \"850115\": {\n    \"name\": \"Loong Whiskers Crisp\",\n    \"desc\": \"Danjin's favorite dessert. It is considered a symbol of good luck and blessings because of its association with loong.\",\n    \"param\": []\n  },\n  \"850116\": {\n    \"name\": \"Sentinel Jué\",\n    \"desc\": \"One of the Sentinels of Huanglong, taking the shape of a Loong. The guiding force behind Jinzhou's civilization.\\nA majestic \\\"deity\\\" with unquestionable power, omniscient of Jinzhou's past, present, and future. Jué, the wielder of time's flow, sees eons as mere moments. In an instant, Jué can change the universe forever.\\n\\\"Seasons shift by decree, and all beings abide by their laws. Such is the nature of the universe.\\\"\",\n    \"param\": []\n  },\n  \"850117\": {\n    \"name\": \"Grand Library\",\n    \"desc\": \"A grand construction located in the central axis of Jinzhou. Not only it reserves the functions of important reception and discussion of major issues, but also sets itself as the symbol of hope for the people of Huanglong.\",\n    \"param\": []\n  },\n  \"850118\": {\n    \"name\": \"Magistrate of Jinzhou\",\n    \"desc\": \"The head governor of Jinzhou.\\nIn Huanglong, when a Magistrate takes office, they adopt the region's name as their own. For example, Jinhsi was originally named Hsi but changed her name to Jinhsi after becoming the Magistrate of Jinzhou.\",\n    \"param\": []\n  },\n  \"850119\": {\n    \"name\": \"Illusory Dream\",\n    \"desc\": \"Cantarella's Resonance ability of poison manipulation. It induces vivid hallucinations in its targets, whether manifestations of their deepest desires or carefully crafted illusions.\\nLike all Fisalia family's abilities, it comes at a price. Prolonged use risks trapping the wielder in their own dreams, blurring the line between reality and fantasy permanently.\",\n    \"param\": []\n  },\n  \"850120\": {\n    \"name\": \"Velvet Dream\",\n    \"desc\": \"A potion Cantarella developed in her girlhood through relentless experimentation.\\nWhile mildly toxic itself, the brew counteracts most poison reactions and induces deep relaxation. It even offers partial protection against Threnodian whispers.\\nHowever, those untrained in toxin tolerance may experience hallucinations.\",\n    \"param\": []\n  },\n  \"850121\": {\n    \"name\": \"The Other Side of the Dream\",\n    \"desc\": \"The reality, as opposed to \\\"this side of the dream.\\\"\",\n    \"param\": []\n  },\n  \"850122\": {\n    \"name\": \"Pero\",\n    \"desc\": \"A strange being that resides within the Magic Box carried by Roccia. It appears to be born from the inspirations imbued in the collected objects inside the box.\",\n    \"param\": []\n  },\n  \"850123\": {\n    \"name\": \"Magic Box\",\n    \"desc\": \"A massive suitcase that never leaves Roccia's side, housing various stage props, play scripts, and Pero.\",\n    \"param\": []\n  },\n  \"850124\": {\n    \"name\": \"Magistrate's Bodyguard\",\n    \"desc\": \"A dedicated protector of the Magistrate, also serving as their personal secretary.\",\n    \"param\": []\n  },\n  \"850125\": {\n    \"name\": \"Golden Anthem\",\n    \"desc\": \"Once a renowned Poets Society of Ragunna, its three members—Faroll, Selena, and Rimbaud—wrote many poems praising the Sentinel and the Order.\\nHowever, they were banished by the Order for blaspheme against the Divinity. Sent aboard a Pilgrim's Sail, they vanished without a trace, and their names were forbidden in Ragunna.\",\n    \"param\": []\n  },\n  \"850126\": {\n    \"name\": \"Shelter Home\",\n    \"desc\": \"Rebuilt by Changli during her time serving in Huanglong's capital, this charity organization is directly managed by the Central Court. It provides shelter to refugees and orphans displaced by plagues, famines, and TD Outbreaks.\",\n    \"param\": []\n  },\n  \"850127\": {\n    \"name\": \"Master Xuanmiao\",\n    \"desc\": \"Changli's mentor, a revered hermit in Huanglong known for his knowledge of statecraft and diplomacy. He traveled widely to share his wisdom and knowledge.\",\n    \"param\": []\n  },\n  \"850128\": {\n    \"name\": \"Jinzhou Counselor\",\n    \"desc\": \"The advisor of Jinzhou's Magistrate. The current Counselor taught Jinhsi the way of governing before she became the Magistrate.\",\n    \"param\": []\n  },\n  \"850129\": {\n    \"name\": \"Riverside Games\",\n    \"desc\": \"The origin of the games stems from the unwavering faith and determination of the people of Jinzhou to overcome the Lament. What started as a small-scale event to celebrate the victory against the Tacet Discords has now evolved into a military-civilian athletic gathering, aimed at promoting physical fitness and fostering camaraderie between soldiers and citizens to overcome any future challenges together.\",\n    \"param\": []\n  },\n  \"850130\": {\n    \"name\": \"Liondance Troupe\",\n    \"desc\": \"A traveling performance group specializing in the traditional Liondance. They take commissions from both the Jinzhou Theater and private clients to support themselves and cover their travel expenses.\",\n    \"param\": []\n  },\n  \"850131\": {\n    \"name\": \"Liondance\",\n    \"desc\": \"Liondance is combination of martial arts and choreography that has now become a signature folk art in Jinzhou. It originated from traditional boxing and martial arts in Huanglong, emphasizing swift footwork and powerful postures.\",\n    \"param\": []\n  },\n  \"850132\": {\n    \"name\": \"Lion Head\",\n    \"desc\": \"This traditional performance takes many forms, from solo shows featuring only the Agile Head to a duo combining both the Agile Head and the Steady Tail.\\nAgile Head is a jargon for Lion Head.\",\n    \"param\": []\n  },\n  \"850133\": {\n    \"name\": \"Starflower\",\n    \"desc\": \"This star-like flower represents love and courage. One day, these earthly stars will blanket every field.\",\n    \"param\": []\n  },\n  \"850134\": {\n    \"name\": \"Fengyiquan\",\n    \"desc\": \"A martial art embodying Taoist wisdom, where practitioners harmonize with nature's rhythms to develop balanced strength of body and mind.\",\n    \"param\": []\n  },\n  \"850135\": {\n    \"name\": \"Bank\",\n    \"desc\": \"The Averardo Bank run by the Montellis in the Ragunna City.\",\n    \"param\": []\n  },\n  \"850136\": {\n    \"name\": \"Black Alley\",\n    \"desc\": \"A popular name referring both to the abandoned underground waterway in Ragunna and the street gang that once operated there. Though the criminal organization was crushed by a mysterious vigilante years ago, rumors suggest they are creeping back from oblivion.\",\n    \"param\": []\n  },\n  \"850137\": {\n    \"name\": \"The Second Dark Tide\",\n    \"desc\": \"A catastrophe happened twenty years ago that not only destroyed the Avinoleum Theological Seminary but also wreaked havoc across Ragunna.\\nFor the people of Ragunna, it was the sacrifice of Fleurdelys, the Blessed Maiden, who single-handedly halted the Second Dark Tide.\",\n    \"param\": []\n  },\n  \"850138\": {\n    \"name\": \"Carnevale Event A Decade Ago\",\n    \"desc\": \"A decade ago, the Carnevale was attacked by a giant sea creature and plagued by TD outbreaks. Primus Fenrico intervened to end the chaos, but the event left new wounds for Ragunna City, which was still recovering from the Second Dark Tide.\",\n    \"param\": []\n  },\n  \"850139\": {\n    \"name\": \"Outrider\",\n    \"desc\": \"The Midnight Rangers have three divisions: Outriders (reconnaissance), Vanguard (offensive operations), and Rearguard (defensive operations), all under the command of General Jiyan.\",\n    \"param\": []\n  },\n  \"850140\": {\n    \"name\": \"You'tan\",\n    \"desc\": \"A Remnant Creature reminiscent of a white udumbara. It can communicate with Baizhi through telepathy.\",\n    \"param\": []\n  },\n  \"850141\": {\n    \"name\": \"Necrostar\",\n    \"desc\": \"A type of special Stellar Matrix used to contain the errors and discarded data of Tethys System.\",\n    \"param\": []\n  },\n  \"850142\": {\n    \"name\": \"Somnoire\",\n    \"desc\": \"A special expanse that collects all the dreams in Solaris since it came into being. It is managed by two Gatekeepers.\",\n    \"param\": []\n  },\n  \"850143\": {\n    \"name\": \"Cinema Solaris\",\n    \"desc\": \"A special dimension dedicated to the mysterious film festival in the depths of Somnoire. Though isolated from the rest of Somnoire, it boasts the best equipment and environment for movie screenings.\",\n    \"param\": []\n  },\n  \"850144\": {\n    \"name\": \"Solaris Film Festival\",\n    \"desc\": \"An activity held in the depths of Somnoire. You've been invited to be a judge, but the identity of the host remains a complete mystery.\",\n    \"param\": []\n  },\n  \"850145\": {\n    \"name\": \"Nightmare Tacet Discord\",\n    \"desc\": \"The Tacet Discords emerge from the frequencies of nightmares and negative emotions. They can often be found in Somnoire.\",\n    \"param\": []\n  },\n  \"850146\": {\n    \"name\": \"Ebony Gatekeeper\",\n    \"desc\": \"One of the administrators of Somnoire, tasked with deleting \\\"useless data\\\" within the realm, or so he says. However, he has his own opinions on what qualifies as \\\"useless.\\\"\",\n    \"param\": []\n  },\n  \"850147\": {\n    \"name\": \"Ivory Doorkeeper\",\n    \"desc\": \"One of the administrators of Somnoire, tasked with keeping the realm running smoothly, or so he says.\",\n    \"param\": []\n  },\n  \"850148\": {\n    \"name\": \"Deep Water Zone\",\n    \"desc\": \"A hidden, inaccessible space deep within Somnoire, where countless collected dreams lie buried.\",\n    \"param\": []\n  },\n  \"850149\": {\n    \"name\": \"Great Agon\",\n    \"desc\": \"The largest and most influential Gladiator event in Septimont, as well as a key economic pillar of the city.\",\n    \"param\": []\n  },\n  \"850150\": {\n    \"name\": \"Gryphon's Fortress\",\n    \"desc\": \"A majestic name for the city of Septimont, perched atop Capitoline Hill. Its people are renowned as master sculptors, skilled hunters, and awe-inspiring gladiators who celebrate heroism.\",\n    \"param\": []\n  },\n  \"850151\": {\n    \"name\": \"Heartpour\",\n    \"desc\": \"An energy drink endorsed by Lupa.\",\n    \"param\": []\n  },\n  \"850152\": {\n    \"name\": \"Priestess\",\n    \"desc\": \"Leaders of Septimont's temple who can foretell fate. They listen to the strings of destiny at a personal cost and offer guidance to those who seek answers.\",\n    \"param\": []\n  },\n  \"850153\": {\n    \"name\": \"Play\",\n    \"desc\": \"A play script given by Phrolova. Every actor has their assigned role, and all stories unfold exactly as written, unless...\",\n    \"param\": []\n  },\n  \"850154\": {\n    \"name\": \"Mengzhou\",\n    \"desc\": \"One of the six major cities in Huanglong, renowned for its abundant waterways, thriving greenery, and enchanting landscapes. Under the guidance of the local Sentinel, the Mengzhou people have developed unique Automata Mechanics.\",\n    \"param\": []\n  },\n  \"850155\": {\n    \"name\": \"Team\",\n    \"desc\": \"The current Ephor reformed the Great Agon into a two-on-two competition. Now, gladiators must find a trusted partner to win the championship together.\",\n    \"param\": []\n  },\n  \"850156\": {\n    \"name\": \"Solis\",\n    \"desc\": \"A popular tavern situated in the commoner neighborhood, famous for its signature drink \\\"Solis.\\\" Gladiators often spar there, with the loser footing the bill.\",\n    \"param\": []\n  },\n  \"850157\": {\n    \"name\": \"Ephor\",\n    \"desc\": \"The ruler of Septimont. Ephors wield absolute power, as only the strong are deemed worthy to lead.\",\n    \"param\": []\n  },\n  \"850158\": {\n    \"name\": \"Copper Mirror\",\n    \"desc\": \"In the tales of Huanglong, mirrors are said to reveal hidden truths. And this one appears to show things unseen...\",\n    \"param\": []\n  },\n  \"850159\": {\n    \"name\": \"High Tide\",\n    \"desc\": \"One of the signs that heralds the coming of a Dark Tide. It's when countless Tacet Discords swarm beneath the Blightcloud, descending upon Septimont in waves of destruction.\",\n    \"param\": []\n  },\n  \"850160\": {\n    \"name\": \"Vale of Glory\",\n    \"desc\": \"The final resting place of Septimont's heroes and legendary gladiators. Stone monuments, shaped after each fallen hero's signature weapon, stand tall in tribute to ensure their names and deeds endure through the ages.\",\n    \"param\": []\n  },\n  \"850161\": {\n    \"name\": \"Tidal Blight\",\n    \"desc\": \"Scars of the Dark Tide's touch. It may appear as discoloration, calcification, or even coral-like growths, depending on what has been corrupted.\",\n    \"param\": []\n  },\n  \"850162\": {\n    \"name\": \"Marvis Industry\",\n    \"desc\": \"A premier forge of high-end weaponry and gear, partnered with numerous noble houses. Its premium pricing, bespoke designs, and elite craftsmanship make it the top choice for aristocrats outfitting their champions.\",\n    \"param\": []\n  },\n  \"850163\": {\n    \"name\": \"Border Mountains\",\n    \"desc\": \"A chain of mountains marking Septimont's edge, severely corrupted by the Dark Tide. Only the most daring Gladiators venture here seeking to train in its harsh conditions.\",\n    \"param\": []\n  },\n  \"850164\": {\n    \"name\": \"Gladiator\",\n    \"desc\": \"Participants in Gladiator matches. They are renowned for their strength and battle prowess and driven by an unyielding thirst for victory and glory.\",\n    \"param\": []\n  },\n  \"850165\": {\n    \"name\": \"Echo Gladiating\",\n    \"desc\": \"Septimont's signature sport, where Echoes battle beside Gladiators. Victory in the arena hinges on their cooperation.\",\n    \"param\": []\n  },\n  \"850166\": {\n    \"name\": \"Hero's Legacy Armor\",\n    \"desc\": \"An Echo formed from the Reverberation of a fallen hero, fused into his armor. It longs to relive the thrill of glorious battle.\",\n    \"param\": []\n  },\n  \"850167\": {\n    \"name\": \"Capitoline Hill\",\n    \"desc\": \"Septimont's central city—home to Gryphon's Fortress and the stage of the Great Agon.\",\n    \"param\": []\n  },\n  \"850168\": {\n    \"name\": \"Guardian Echo\",\n    \"desc\": \"The Lioness of Glory, Arsinosa. Born of battle cries and laughter, fused into the stone form of a mighty half-human, half-lion Echo. Since her genesis, she has stood watch over the City of Septimont.\",\n    \"param\": []\n  },\n  \"850169\": {\n    \"name\": \"House Silva\",\n    \"desc\": \"The House Lupa fights for. One of Septimont's founding bloodlines, House Silva's roots once ran deep in the city's spire of influence. But with the rise of the new Ephor, such past glories have begun to wane.\",\n    \"param\": []\n  },\n  \"850170\": {\n    \"name\": \"Senate\",\n    \"desc\": \"The governing body of Septimont, tasked with advising the Ephor and wielding authority in key administrative matters. It also exercises power over the appointment and dismissal of public officials.\",\n    \"param\": []\n  },\n  \"850171\": {\n    \"name\": \"Blightcloud\",\n    \"desc\": \"An omen of the coming Dark Tide, one that has lingered over Septimont for years. The region it shrouds is known to Septimontians as the \\\"hunting grounds.\\\"\",\n    \"param\": []\n  },\n  \"850172\": {\n    \"name\": \"Cliffside Harbor\",\n    \"desc\": \"The port that connects Septimont to the outside world. Vessels laden with goods and fresh catch arrive by the hour, while visiting Gladiators and travelers make landfall here upon reaching Septimont.\",\n    \"param\": []\n  },\n  \"850173\": {\n    \"name\": \"Ready Stance\",\n    \"desc\": \"When Zani is under the following states, hold \u003Ccolor=Highlight>Resonance Skill\u003C/color> to enter \u003Ccolor=Highlight>Ready Stance\u003C/color>.\\n- While not in the \u003Ccolor=Highlight>Inferno Mode\u003C/color> and Redundant Energy is full.\\n- While in the \u003Ccolor=Highlight>Inferno Mode\u003C/color>.\",\n    \"param\": []\n  },\n  \"850174\": {\n    \"name\": \"Wolflame\",\n    \"desc\": \"\u003Csize=40>\u003Ccolor=Title>Wolflame\u003C/color>\u003C/size>\\nLupa can hold up to 100 points of Wolflame.\\n- Restore Wolflame when Normal Attacks hit the target.\\n- Restore Wolflame while casting Resonance Skill.\\n- Restore Wolflame while casting Resonance Liberation.\",\n    \"param\": []\n  },\n  \"850175\": {\n    \"name\": \"Wolfaith\",\n    \"desc\": \"\u003Csize=40>\u003Ccolor=Title>Wolfaith\u003C/color>\u003C/size>\\nLupa can hold up to 2 points of Wolfaith.\\nWolfaith lasts for 10s. The duration is reset when Wolfaith is restored. At the end of its duration, each remaining point of Wolfaith yields 50 points of Wolflame.\\nGain1 point of Wolfaith when casting \u003Ccolor=Highlight>Heavy Attack - Wolf's Gnawing\u003C/color>, \u003Ccolor=Highlight>Heavy Attack - Wolf's Claw\u003C/color>, or \u003Ccolor=Highlight>Mid-air Attack - Firestrike\u003C/color>.\",\n    \"param\": []\n  },\n  \"850176\": {\n    \"name\": \"Pack Hunt\",\n    \"desc\": \"\u003Csize=40>\u003Ccolor=Title>Pack Hunt\u003C/color>\u003C/size>\\nResonators with \u003Ccolor=Highlight>Pack Hunt\u003C/color> gain a 6% ATK increase, and 10% Fusion DMG Bonus when they attack Overlord Class or Calamity Class targets (Both are non-stackable). If there are 3 Fusion Resonators in the team, the Fusion DMG Bonus against Overlord Class or Calamity Class targets additionally increases by 10%. When the active Resonator casts \u003Ccolor=Highlight>Intro Skill\u003C/color>, \u003Ccolor=Highlight>Pack Hunt\u003C/color> is enhanced, granting an additional 6% ATK increase to all Resonators in the team, up to a maximum of 18%.\\nIf Lupa's \u003Ccolor=Highlight>Pack Hunt\u003C/color> reaches its cap within its duration, she enters \u003Ccolor=Highlight>Wild Hunt\u003C/color> and Intro Skill - \u003Ccolor=Highlight>Nowhere to Run!\u003C/color> becomes available. \u003Ccolor=Highlight>Wild Hunt\u003C/color> can be triggered once during \u003Ccolor=Highlight>Pack Hunt\u003C/color>.\",\n    \"param\": []\n  },\n  \"850177\": {\n    \"name\": \"Burning Matchpoint\",\n    \"desc\": \"Normal Attacks increase Wolflame Regen by 500% on hit. Cannot perform Resonance Skill \u003Ccolor=Highlight>Shewolf's Hunt\u003C/color> and Resonance Skill \u003Ccolor=Highlight>Feral Fang\u003C/color> in this state.\",\n    \"param\": []\n  },\n  \"850178\": {\n    \"name\": \"Glory\",\n    \"desc\": \"\u003Csize=40>\u003Ccolor=Title>Resonance Liberation - Glory\u003C/color>\u003C/size>\\nCasting Resonance Liberation \u003Ccolor=Highlight>Fire-Kissed Glory\u003C/color> grants \u003Ccolor=Highlight>Glory\u003C/color>. Within 35s:\\nAttacks of all Resonators in the team ignore 3% Fusion RES. For each Fusion Resonator in the team other than Lupa, this effect increases by 3%, up to the maximum of 9%. When there are 3 Fusion Resonators in the team, Resonators' attacks further ignore 6% Fusion RES.\",\n    \"param\": []\n  },\n  \"850179\": {\n    \"name\": \"Conviction\",\n    \"desc\": \"When \u003Ccolor=Highlight>Conviction\u003C/color> reaches 120 points, {Cus:Ipt,Touch=tap PC=press Gamepad=press} Resonance Liberation to cast \u003Ccolor=Highlight>Resonance Liberation - Blade of Howling Squall\u003C/color>.\",\n    \"param\": []\n  },\n  \"850180\": {\n    \"name\": \"Negative Status\",\n    \"desc\": \"Includes Spectro Frazzle, Havoc Bane, Fusion Burst, Glacio Chafe, Electro Flare and Aero Erosion.\",\n    \"param\": []\n  },\n  \"850181\": {\n    \"name\": \"Heart of Virtue\",\n    \"desc\": \"When \u003Ccolor=Highlight>Fleurdelys\u003C/color> has \u003Ccolor=Highlight>Heart of Virtue\u003C/color> in \u003Ccolor=Highlight>Manifest\u003C/color>:\\n- \u003Ccolor=Highlight>Basic Attack - Fleurdelys Stage 4\u003C/color> will generate a force field to Stagnate the targets within the range.\\n- \u003Ccolor=Highlight>Fleurdelys's\u003C/color> resistance to interruption increases.\\n- \u003Ccolor=Highlight>Heart of Virtue\u003C/color> is removed when \u003Ccolor=Highlight>Manifest\u003C/color> ends.\",\n    \"param\": []\n  },\n  \"850182\": {\n    \"name\": \"Mandate of Divinity\",\n    \"desc\": \"When \u003Ccolor=Highlight>Fleurdelys\u003C/color> has \u003Ccolor=Highlight>Mandate of Divinity\u003C/color> in \u003Ccolor=Highlight>Manifest\u003C/color>:\\n\u003Ccolor=Wind>Aero Erosion\u003C/color> DMG is Amplified by 50% and its damage interval is decreased by 50% for enemies within a certain distance from \u003Ccolor=Highlight>Fleurdelys\u003C/color>.\\n\u003Ccolor=Highlight>Mandate of Divinity\u003C/color> is removed when \u003Ccolor=Highlight>Manifest\u003C/color> ends.\",\n    \"param\": []\n  },\n  \"850183\": {\n    \"name\": \"Power of Discord\",\n    \"desc\": \"When \u003Ccolor=Highlight>Fleurdelys\u003C/color> has \u003Ccolor=Highlight>Power of Discord\u003C/color> in \u003Ccolor=Highlight>Manifest\u003C/color>, gain the following effect:\\nWhen casting \u003Ccolor=Highlight>Basic Attack - Fleurdelys Stage 5\u003C/color>, \u003Ccolor=Highlight>Mid-air Attack - Fleurdelys Stage 2\u003C/color>, \u003Ccolor=Highlight>Enhanced Heavy Attack - Fleurdelys\u003C/color>, or after \u003Ccolor=Highlight>Resonance Skill - May Tempest Break the Tides\u003C/color> deals damage, raise the \u003Ccolor=Wind>Aero Erosion\u003C/color> stacks on all nearby targets to the highest count among the targets.\\n\u003Ccolor=Highlight>Power of Discord\u003C/color> is removed when \u003Ccolor=Highlight>Manifest\u003C/color> ends.\",\n    \"param\": []\n  },\n  \"850184\": {\n    \"name\": \"Sword of Virtue's Shadow\",\n    \"desc\": \"Casting \u003Ccolor=Highlight>Mid-air Attack - Cartethyia\u003C/color> recalls all \u003Ccolor=Highlight>Sword Shadows\u003C/color> and, based on the number and types of the \u003Ccolor=Highlight>Sword Shadows\u003C/color> recalled, perform the specific forms of Plunging Attack and obtain the corresponding \u003Ccolor=Highlight>Heart of Virtue\u003C/color>, \u003Ccolor=Highlight>Mandate of Divinity\u003C/color>, and \u003Ccolor=Highlight>Power of Discord\u003C/color>\",\n    \"param\": []\n  },\n  \"850185\": {\n    \"name\": \"Sword of Discord's Shadow\",\n    \"desc\": \"Casting \u003Ccolor=Highlight>Mid-air Attack - Cartethyia\u003C/color> recalls all \u003Ccolor=Highlight>Sword Shadows\u003C/color> and, based on the number and types of the \u003Ccolor=Highlight>Sword Shadows\u003C/color> recalled, perform the specific forms of Plunging Attack and obtain the corresponding \u003Ccolor=Highlight>Heart of Virtue\u003C/color>, \u003Ccolor=Highlight>Mandate of Divinity\u003C/color>, and \u003Ccolor=Highlight>Power of Discord\u003C/color>.\",\n    \"param\": []\n  },\n  \"850186\": {\n    \"name\": \"Sword of Divinity's Shadow\",\n    \"desc\": \"Casting \u003Ccolor=Highlight>Mid-air Attack - Cartethyia\u003C/color> recalls all \u003Ccolor=Highlight>Sword Shadows\u003C/color> and, based on the number and types of the \u003Ccolor=Highlight>Sword Shadows\u003C/color> recalled, perform the specific forms of Plunging Attack and obtain the corresponding \u003Ccolor=Highlight>Heart of Virtue\u003C/color>, \u003Ccolor=Highlight>Mandate of Divinity\u003C/color>, and \u003Ccolor=Highlight>Power of Discord\u003C/color>.\",\n    \"param\": []\n  },\n  \"851000\": {\n    \"name\": \"Dream of Gradation\",\n    \"desc\": \"Echoes with this Dream Attribute center around Gradation as their core ability. Certain Echoes will trigger Gradation once and obtain buffs after staying on the field for a set number of days\",\n    \"param\": []\n  },\n  \"851001\": {\n    \"name\": \"Dream of Devouring\",\n    \"desc\": \"Echoes with this Dream Attribute center around Devouring as their core ability. Certain Echoes grow stronger in the Dreamland by Devouring. When a powerful Echo absorbs another one, its Daily Coupon yield increases.\",\n    \"param\": []\n  },\n  \"851002\": {\n    \"name\": \"Dream of Exchange\",\n    \"desc\": \"Echoes with this Dream Attribute center on Exchange as their core ability. In the Dream of Exchange Some Echoes can Exchange themselves to reshape the Dreamland. After staying in the Dream for a set number of days, they Remove themselves and leave behind various buff effects.\",\n    \"param\": []\n  },\n  \"851003\": {\n    \"name\": \"Dream of Integration\",\n    \"desc\": \"Echoes with this Dream Attribute can cause considerable alterations in the dream through Integration. When conditions are met, certain Echoes will merge with another Echo on the same row into a brand-new Echo and grant various buff effects.\",\n    \"param\": []\n  },\n  \"851004\": {\n    \"name\": \"Dream of Connection\",\n    \"desc\": \"Echoes with this Dream Attribute have no unique abilities and are suited for synergizing with Echoes with other Dream Attributes. These Echoes will automatically be added to Echo Recruitment after being unlocked.\",\n    \"param\": []\n  },\n  \"851005\": {\n    \"name\": \"Gradation\",\n    \"desc\": \"Echoes with this Dream Attribute can grow stronger through Gradation. When certain Echoes meet their Gradation conditions, their Daily Coupon yield increases.\",\n    \"param\": []\n  },\n  \"851006\": {\n    \"name\": \"Devour\",\n    \"desc\": \"Echoes with this Dream Attribute center around Devouring as their core ability. Certain Echoes grow stronger in the Dreamland by Devouring. When a powerful Echo absorbs a weaker one, its Daily Coupon yield increases.\",\n    \"param\": []\n  },\n  \"851007\": {\n    \"name\": \"Exchange\",\n    \"desc\": \"Echoes with this Dream Attribute center on Exchange as their core ability. Some Echoes can Exchange themselves to reshape the Dreamland. After staying in the Dream for a set number of days, they Remove themselves and leave behind various buff effects.\",\n    \"param\": []\n  },\n  \"851008\": {\n    \"name\": \"Integration\",\n    \"desc\": \"Echoes with this Dream Attribute center on Integration as their core ability. Some Echoes can reshape the Dreamland through Integration. When conditions are met, adjacent Echoes merge into a brand-new Echo and grant various buff effects.\",\n    \"param\": []\n  },\n  \"851009\": {\n    \"name\": \"Daily Coupon\",\n    \"desc\": \"Daily Coupon yield refers to the base quantity of Dreamland Coupons Echoes can collect per day.\",\n    \"param\": []\n  },\n  \"851010\": {\n    \"name\": \"Dreamland Coupon\",\n    \"desc\": \"Coupons collected by Echoes to meet revenue targets and keep the Dreamland stable.\",\n    \"param\": []\n  },\n  \"851011\": {\n    \"name\": \"Frequency Crystal\",\n    \"desc\": \"Crystallized fragments of frozen frequencies. These Dream creations possess unique powers.\",\n    \"param\": []\n  },\n  \"851012\": {\n    \"name\": \"Echo Recruitment\",\n    \"desc\": \"Choose your preferred Echoes and place them on the field.\",\n    \"param\": []\n  },\n  \"851013\": {\n    \"name\": \"Item of Exchange\",\n    \"desc\": \"After staying in the Dream for a set number of days, it Removes itself and leaves behind various buff effects.\",\n    \"param\": []\n  },\n  \"851014\": {\n    \"name\": \"Rooted\",\n    \"desc\": \"The Echo is placed in a fixed place on the field.\",\n    \"param\": []\n  },\n  \"851015\": {\n    \"name\": \"Dream Block: Gravel\",\n    \"desc\": \"The Daily Coupon yield of Echoes on these Dream Blocks is increased by 2.\",\n    \"param\": []\n  },\n  \"851016\": {\n    \"name\": \"Dream Block: Ice Shards\",\n    \"desc\": \"All Echoes on these Dream Blocks are considered to be in the same row.\",\n    \"param\": []\n  },\n  \"851017\": {\n    \"name\": \"Lillibet\",\n    \"desc\": \"The current Head Priestess of Septimont.\",\n    \"param\": []\n  },\n  \"851018\": {\n    \"name\": \"Book of Prophecies\",\n    \"desc\": \"A scroll Lillibet carries, recording visions glimpsed in the flame light. Both this book and the murals within Tetragon Temple are media through which the Priestesses of Septimont convey prophecies to the people.\",\n    \"param\": []\n  },\n  \"851019\": {\n    \"name\": \"Hero of Heroes\",\n    \"desc\": \"The legendary ruler of Septimont. The legend traces its roots to an ancient prophecy that only the one who becomes the Hero of Heroes can save Septimont from falling into ruin.\",\n    \"param\": []\n  },\n  \"851020\": {\n    \"name\": \"Fabricatorium of the Deep\",\n    \"desc\": \"A secluded underwater experiment facility built by the Fractsidus and the Order, where they both pursue hidden ambitions under the guise of Common Echo reprocessing and production.\",\n    \"param\": []\n  },\n  \"851021\": {\n    \"name\": \"The Lost Beyond\",\n    \"desc\": \"Phrolova's Sonoro Sphere, designed to replicate the Beyond through artificial means. Using the powers of Threnodian Leviathan, she intends to use bodies of Tacet Discords as hosts for the reverberating consciousness of the departed. In doing so, the Sonoro may merge with reality, and those long past can live in a new, eternal world free of decay.\",\n    \"param\": []\n  },\n  \"851022\": {\n    \"name\": \"Echo Brooder\",\n    \"desc\": \"A device for incubating Common Echoes. Twisted, shattered Echo frequencies are reconstructed into new Common Echoes within its chamber.\",\n    \"param\": []\n  },\n  \"851023\": {\n    \"name\": \"Dark Tide\",\n    \"desc\": \"A Waveworn Phenomenon unique to Rinascita, the Dark Tide is a manifestation of the Threnodian Leviathan's power of Unity. Dark clouds amass overhead and crash down like a waterfall, surging in all directions. Wherever the Dark Tide spreads, it spawns Tacet Discords and scars the land with Tidal Blight. At its epicenter, a new Tacet Field forms.\",\n    \"param\": []\n  },\n  \"851024\": {\n    \"name\": \"Retroact Rain\",\n    \"desc\": \"High-density Remnant Energy from the Etheric Sea that projects past events with uncanny fidelity. The Retroact Rain unfolds in three distinct phases: natural descent, near-ground suspension, and reverse flow.\",\n    \"param\": []\n  },\n  \"851025\": {\n    \"name\": \"Harbinger\",\n    \"desc\": \"Humans selected by the Threnodian Leviathan to spread its doctrine, and sow sorrow and despair among the masses. Influence appears to be a key factor in their selection. Marked by the Dark Tide's corruption, they wield fragments of Leviathan's power, such as summoning its creations.\",\n    \"param\": []\n  },\n  \"851026\": {\n    \"name\": \"Beyond\",\n    \"desc\": \"A world built upon thousands of Reverberations. A domain of decaying frequencies. A place where Phrolova found rebirth, which has now become a part of her existence.\",\n    \"param\": []\n  },\n  \"851027\": {\n    \"name\": \"Threnodian's Gem\",\n    \"desc\": \"Lingering power of the Threnodian Leviathan. After escaping from Mya's broken form, it concealed itself within the Ragunna gemstone on her helmet.\",\n    \"param\": []\n  },\n  \"851028\": {\n    \"name\": \"Sanguis Plateaus\",\n    \"desc\": \"The Sanguis Plateaus was once the Septimont frontline against the Dark Tide. Due to the region's unique landscape, Remnant energy gathers here in unusual density, along with a Blightcloud perpetually looming overhead, formed since the first Dark Tide. During High Tide seasons, Gladiators from across Septimont arrive here to hunt Dark Tide creations in the name of glory.\",\n    \"param\": []\n  },\n  \"160801\": {\n    \"name\": \"Volatile Note\",\n    \"desc\": \"Phrolova can hold up to 6 \u003Ccolor=Highlight>Volatile Notes\u003C/color>. When \u003Ccolor=Highlight>Volatile Notes\u003C/color> reach the max number, all \u003Ccolor=Highlight>Volatile Notes\u003C/color> shift one slot to the left, and the leftmost \u003Ccolor=Highlight>Volatile Note - Strings\u003C/color> or \u003Ccolor=Highlight>Volatile Note - Winds\u003C/color> will be removed.\\nHitting a target with \u003Ccolor=Highlight>Basic Attack Stage 3\u003C/color> or \u003Ccolor=Highlight>Movement of Fate and Finality\u003C/color> grants 1 \u003Ccolor=Highlight>Volatile Note - Strings\u003C/color>.\\nHitting a target with Resonance Skill \u003Ccolor=Highlight>Whispers in a Fleeting Dream\u003C/color> or Resonance Skill \u003Ccolor=Highlight>Murmurs in a Haunting Dream\u003C/color> grants 1 \u003Ccolor=Highlight>Volatile Note - Winds\u003C/color>.\\nWhen \u003Ccolor=Highlight>Inherent Skill - Accidental\u003C/color> is activated, casting Suite of Quietus, Suite of Immortality, or Echo Skill turns the next Volatile Note into \u003Ccolor=Highlight>Volatile Note - Cadenza\u003C/color>.\\nPhrolova cannot obtain \u003Ccolor=Highlight>Volatile Notes\u003C/color> during \u003Ccolor=Highlight>Resolving Chord\u003C/color>.\",\n    \"param\": []\n  },\n  \"160802\": {\n    \"name\": \"Resolving Chord\",\n    \"desc\": \"Phrolova enters \u003Ccolor=Highlight>Resolving Chord\u003C/color> after casting \u003Ccolor=Highlight>Scarlet Coda\u003C/color>.\\nWhen in the \u003Ccolor=Highlight>Resolving Chord\u003C/color> state, \u003Ccolor=Highlight>Waltz of Forsaken Depths\u003C/color> becomes available.\",\n    \"param\": []\n  },\n  \"160803\": {\n    \"name\": \"Aftersound\",\n    \"desc\": \"Max {0} stacks.\\nWhen Phrolova is not on the field, casting \u003Ccolor=Highlight>Enhanced Attack - Hecate: Strings\u003C/color>, \u003Ccolor=Highlight>Enhanced Attack - Hecate: Winds\u003C/color>, and \u003Ccolor=Highlight>Enhanced Attack - Hecate: Cadenza\u003C/color> grants \u003CSapTag=1>{1}\u003C/SapTag> {Cus:Sap,S=stack P=stacks SapTag=1} of Aftersound.\\nWhen Phrolova is out of combat, all stacks of Aftersound are removed every {2}s.\",\n    \"param\": [\n      \"24\",\n      \"1\",\n      \"30\"\n    ]\n  },\n  \"160804\": {\n    \"name\": \"Maestro\",\n    \"desc\": \"Gain {1} ATK increase.\\nPhrolova floats in the air and commands Hecate to fight. Hecate will share Phrolova's stats and statuses, and damage dealt by Hecate will be considered coming from Phrolova.\\nDuring this period, Phrolova plays out the \u003Ccolor=Highlight>Volatile Notes\u003C/color> in order. Each \u003Ccolor=Highlight>Volatile Note\u003C/color> holds for {0}s.\",\n    \"param\": [\n      \"4\",\n      \"120%\"\n    ]\n  },\n  \"851029\": {\n    \"name\": \"Figurine: Conductor\",\n    \"desc\": \"When an Echo on the field is Devoured, there is a 20% chance to generate a basic form of itself on a blank block.\",\n    \"param\": []\n  },\n  \"851030\": {\n    \"name\": \"Fortune Bell\",\n    \"desc\": \"When an Echo undergoes Gradation, there is a 5% chance to increase its Daily Coupon yield by 100%.\",\n    \"param\": []\n  },\n  \"851031\": {\n    \"name\": \"Figurine: Gulpuff\",\n    \"desc\": \"Before Daily Coupon settlement, gain 2 Frequency Crystals for every 10 Echoes obtained.\",\n    \"param\": []\n  },\n  \"851032\": {\n    \"name\": \"Dreaming Round n' Round\",\n    \"desc\": \"There is a 10% chance to gain 1 extra Echo during Echo Recruitment.\",\n    \"param\": []\n  },\n  \"851033\": {\n    \"name\": \"Dreamy Firework\",\n    \"desc\": \"For every blue-rarity Echo on the field, whenever an Item of Exchange is Exchanged, there is a 5% chance to generate an Echo of the same name, stacking up to 5 times.\",\n    \"param\": []\n  },\n  \"851034\": {\n    \"name\": \"Kaleidoscope\",\n    \"desc\": \"The first Echo that initiate Integration require 1 less Echo.\",\n    \"param\": []\n  },\n  \"851035\": {\n    \"name\": \"Surprise Box\",\n    \"desc\": \"The shop offers 1 random Dream Box for free starting from the next phase.\",\n    \"param\": []\n  },\n  \"851036\": {\n    \"name\": \"Clockwork Illuminator\",\n    \"desc\": \"Dreamland Coupon gained through sources other than Echo Daily Coupon yield is increased by 10%.\",\n    \"param\": []\n  },\n  \"851037\": {\n    \"name\": \"Figurine: Excarat\",\n    \"desc\": \"Gain 5 Dreamland Coupons each time Devouring occurs.\",\n    \"param\": []\n  },\n  \"851038\": {\n    \"name\": \"Dreamscape Train\",\n    \"desc\": \"When an Echo Removes itself or is Integrated into a new Echo, gain additional Dreamland Coupons equal to its own Daily Coupon yield.\",\n    \"param\": []\n  },\n  \"851039\": {\n    \"name\": \"Stamp Book\",\n    \"desc\": \"Before Daily Coupon settlement, gain 500 Dreamland Coupons for every 10 Echoes obtained.\",\n    \"param\": []\n  },\n  \"851040\": {\n    \"name\": \"Figurine: Clang Bang\",\n    \"desc\": \"Receive Dreamland Coupons equal to the number of Frequency Crystals in each Phase.\",\n    \"param\": []\n  },\n  \"851041\": {\n    \"name\": \"Remove\",\n    \"desc\": \"Echoes are seen as Removed when they are Exchanged, Integrated, Devoured, or Removed by themselves. Dismissing an Echo does not count as Removal.\",\n    \"param\": []\n  },\n  \"851042\": {\n    \"name\": \"Stonewall Bracer\",\n    \"desc\": \"Integration: When 3 Echoes with the same Dream Attribute and rarity as this Echo are in the same row, they Integrate into 1 Rage Against the Statue and gain Dreamland Coupons equal to 60 + total Daily Coupon yield x2.\",\n    \"param\": []\n  },\n  \"851043\": {\n    \"name\": \"Rage Against the Statue\",\n    \"desc\": \"Integration: When 3 Echoes with the same Dream Attribute and rarity as this Echo are in the same row, they Integrate into 1 Crownless and gain Dreamland Coupons equal to 150 + total Daily Coupon yield x3.\",\n    \"param\": []\n  },\n  \"851044\": {\n    \"name\": \"Crownless\",\n    \"desc\": \"Integration: When 3 Echoes with the same Dream Attribute and rarity as this Echo are in the same row, they Integrate into 1 Crownless and gain Dreamland Coupons equal to 450 + total Daily Coupon yield x4. Its Daily Coupon yield equals the total Daily Coupon yield of all the Integrated Echoes.\",\n    \"param\": []\n  },\n  \"851045\": {\n    \"name\": \"Basic Form\",\n    \"desc\": \"A copy of the Echo that shares its Daily Coupon yield and Dream Attribute. It has no skills or buff effects.\",\n    \"param\": []\n  },\n  \"851046\": {\n    \"name\": \"Fission Junrock\",\n    \"desc\": \"Integration: When 3 Echoes with the same Dream Attribute and rarity as this Echo are in the same row, they Ingrate into 1 Stonewall Bracer and gain Dreamland Coupons equal to 30 + total Daily Coupon yield x1.\",\n    \"param\": []\n  },\n  \"851047\": {\n    \"name\": \"Roseshroom\",\n    \"desc\": \"Exchange: After 2 days, Remove itself as an Item of Exchange. This Echo will always appear on the same block. When Exchanging, there is a 50% chance to generate a Mourning Aix on a blank block. This Echo cannot be obtained through Echo Recruitment.\",\n    \"param\": []\n  },\n  \"851048\": {\n    \"name\": \"Dream Block: Obsidian\",\n    \"desc\": \"The Daily Coupon yield of Echoes on these Dream Blocks temporarily increases by 2. The bonus is removed once it leaves these Dream Blocks.\",\n    \"param\": []\n  },\n  \"851049\": {\n    \"name\": \"Chop Chop\",\n    \"desc\": \"Chop Chop Echoes include: Chop Chop, Chop Chop: Head, Chop Chop: Leftless, Chop Chop: Rightless, Dreamborne: Chop Chop.\",\n    \"param\": []\n  },\n  \"851050\": {\n    \"name\": \"Prism\",\n    \"desc\": \"Prism Echoes include: Glacio Prism, Fusion Prism, Havoc Prism, Spectro Prism.\",\n    \"param\": []\n  },\n  \"851051\": {\n    \"name\": \"Adjacent\",\n    \"desc\": \"Echoes with this effect are considered adjacent to each other.\",\n    \"param\": []\n  },\n  \"851052\": {\n    \"name\": \"Same Row\",\n    \"desc\": \"Echoes with this effect are considered to be in the same row.\",\n    \"param\": []\n  },\n  \"851053\": {\n    \"name\": \"Any Rarity\",\n    \"desc\": \"Echoes with this effect can be considered of any rarity.\",\n    \"param\": []\n  },\n  \"851054\": {\n    \"name\": \"Questless Knight\",\n    \"desc\": \"Gradation: Gradation occurs every 6 days. After Gradation, increase the Gradation progress of the Gradatable Echoes in the same row by 1, up to 2 times per day.\",\n    \"param\": []\n  },\n  \"851055\": {\n    \"name\": \"Adjacent\",\n    \"desc\": \"Hexagonal areas that share a border are considered adjacent to each other.\",\n    \"param\": []\n  },\n  \"851056\": {\n    \"name\": \"Roseshroom\",\n    \"desc\": \"Roseshroom Echoes include: Baby Roseshroom, Roseshroom, Dreamborne: Baby Roseshroom, Dreamborne: Roseshroom.\",\n    \"param\": []\n  },\n  \"851057\": {\n    \"name\": \"Violet-Feathered Heron\",\n    \"desc\": \"Devour: Devour 1 adjacent Echo of grey or blue rarity every day, and gain the Devoured target's Daily Coupon yield. It will Devour Prism Echoes first.\",\n    \"param\": []\n  },\n  \"851058\": {\n    \"name\": \"Fusion Cube\",\n    \"desc\": \"When an Echo on the field initiates Integration, there is a 20% chance to generate a copy of that Echo.\",\n    \"param\": []\n  },\n  \"851059\": {\n    \"name\": \"Vanguard Junrock\",\n    \"desc\": \"After 1 day, randomly transform into an Echo in the same row. This effect can only be triggered once.\",\n    \"param\": []\n  },\n  \"851060\": {\n    \"name\": \"Hoochief Cyclone\",\n    \"desc\": \"When a unit is Removed, increase its own Daily Coupon yield by 2, up to 1 time per day.\",\n    \"param\": []\n  },\n  \"160805\": {\n    \"name\": \"Reincarnate\",\n    \"desc\": \"\u003Csize=40>\u003Ccolor=Title>Basic Attack - Movement of Fate and Finality\u003C/color>\u003C/size>\\nWhen in \u003Ccolor=Highlight>Reincarnate\u003C/color>, {Cus:Ipt,Touch=tap PC=press Gamepad=press} \u003Ccolor=Highlight>Normal Attack\u003C/color> on the ground to cast \u003Ccolor=Highlight>Movement of Fate and Finality\u003C/color>, which deals \u003Ccolor=Dark>Havoc DMG\u003C/color> (considered \u003Ccolor=Highlight>Resonance Skill DMG\u003C/color>), Stagnates the target, and ends \u003Ccolor=Highlight>Reincarnate\u003C/color> afterward.\\n\u003Csize=10>\u003C/size>\\n\u003Csize=40>\u003Ccolor=Title>Resonance Skill - Murmurs in a Haunting Dream\u003C/color>\u003C/size>\\nWhen in \u003Ccolor=Highlight>Reincarnate\u003C/color>, {Cus:Ipt,Touch=tap PC=press Gamepad=press} \u003Ccolor=Highlight>Resonance Skill\u003C/color> on the ground to cast \u003Ccolor=Highlight>Murmurs in a Haunting Dream\u003C/color>, dealing \u003Ccolor=Dark>Havoc DMG\u003C/color> (considered \u003Ccolor=Highlight>Resonance Skill DMG\u003C/color>) and ending \u003Ccolor=Highlight>Reincarnate\u003C/color> afterward.\",\n    \"param\": []\n  },\n  \"851061\": {\n    \"name\": \"Mourning Aix\",\n    \"desc\": \"Exchange: After 2 days, Removes itself as an Item of Exchange. When Exchanging, adjacent Echoes' Daily Coupon yield increases by 30% of this Echo's Daily Coupon yield. This Echo cannot be obtained through Echo Recruitment.\",\n    \"param\": []\n  },\n  \"851062\": {\n    \"name\": \"Dreamborne: Roseshroom\",\n    \"desc\": \"Exchange: After 2 days, it Removes itself as the Item of Exchange. When Exchanging or Devoured, it grants Dreamland Coupons equal to the current Daily Coupon yield x10. There is a 50% chance to generate a Mourning Aix. This Echo cannot be obtained through Echo Recruitment.\",\n    \"param\": []\n  },\n  \"851063\": {\n    \"name\": \"Dream Block: Watermirror\",\n    \"desc\": \"All Echoes on these Dream Blocks are considered Adjacent to each other.\",\n    \"param\": []\n  },\n  \"750001\": {\n    \"name\": \"Hunt\",\n    \"desc\": \"An operation conducted by Septimont's Gladiators to eliminate the Dark Tide and its creations within the Sanguis Plateaus.\\nThe Plateaus' unique terrain allows Remnant Energy to accumulate, sustaining the lingering Blightcloud hanging over the area, a remnant of the first Dark Tide outbreak in Rinascita. Consequently, the region has become a breeding ground for Dark Tide creatures, where the Dark Tide's corruption continues to spread unchecked.\\nAs the confrontation with the Dark Tide stretched on, the Septimontians discovered a strategy to effectively curb the Dark Tide's advance: luring its creations toward the Earthrend Wedge and hunting them near its base. Since then, the \\\"hunt\\\" gradually evolved into an institutionalized tradition deeply woven into Septimont's culture.\",\n    \"param\": []\n  },\n  \"750002\": {\n    \"name\": \"Dark Tide Creation\",\n    \"desc\": \"A type of Tacet Discord born from the Dark Tide.\",\n    \"param\": []\n  },\n  \"750003\": {\n    \"name\": \"Earthrend Wedge\",\n    \"desc\": \"A colossal wedge-shaped structure located in the lower levels of the Sanguis Plateaus. It descended from the high heavens alongside Rinascita's Sentinel Imperator, who had full control over it. When the first Dark Tide outbreak struck Rinascita, the Earthrend Wedge was activated. Its energy field effectively suppressed the Blightcloud above the hunting grounds, preventing it from spreading into Septimont's urban areas. Subsequently, the Dark Tide stemming from the clouds has been mostly contained within the lower levels of the Plateaus.\",\n    \"param\": []\n  },\n  \"750004\": {\n    \"name\": \"Tempest Cliffs\",\n    \"desc\": \"Located on the outskirts of the city of Septimont, it's the \\\"air terminal\\\" where Gladiators cross the canyons and make their trip to and from the Sanguis Plateaus.\",\n    \"param\": []\n  },\n  \"750005\": {\n    \"name\": \"Tetragon Temple\",\n    \"desc\": \"The living quarters of Priestesses, where fate is observed and prophecies are documented. Commonly referred to as the \\\"Temple.\\\"\",\n    \"param\": []\n  },\n  \"750006\": {\n    \"name\": \"Maroonwood\",\n    \"desc\": \"The main hunting ground on the mid to upper levels of the Sanguis Plateaus, where generations of Septimontians battled the Dark Tide and its creations.\",\n    \"param\": []\n  },\n  \"750007\": {\n    \"name\": \"Hornett\",\n    \"desc\": \"A Common Echo in the form of a large horn. Hornett's high-pitched and lengthy blare is used to signal the beginning or the conclusion of large-scale hunting operations.\",\n    \"param\": []\n  },\n  \"750008\": {\n    \"name\": \"Canyons\",\n    \"desc\": \"The mainland of Septimont and the Sanguis Plateaus are separated by a narrow and long waterway.\",\n    \"param\": []\n  },\n  \"750009\": {\n    \"name\": \"Sacred Flame\",\n    \"desc\": \"A unique flame produced by igniting specific minerals. Its appearance resembles sunlight more than ordinary fire. The precise types and proportions of minerals used to create this flame are a closely guarded secret, passed down exclusively through generations of Priestesses.\\nWhile the Sacred Flame offers no special power, Priestesses channel their Resonance power through it, using its light to glimpse the future and deliver prophecies.\\nYet to the Priestesses, the Sacred Flame is more than just a medium for divination. They view it as \\\"celestial light descended to the mortal world,\\\" often referring to it as \\\"the flames.\\\"\",\n    \"param\": []\n  },\n  \"750010\": {\n    \"name\": \"Manes Deep\",\n    \"desc\": \"The ruins of a bygone civilization, said to be hidden deep beneath the Sanguis Plateaus. Its entrance is located in the Wastelands. Long ago, it was visited by the three Heroes of Heroes from Septimont.\\nLegend has it that those who manage to set foot in Manes Deep can hear the whispers of the Heroes of Heroes and thereby gain powers rivaling their own. Some also hold that since the Heroes of Heroes walked this place, the journey to Manes Deep has become an inescapable trial for any who would claim that title.\",\n    \"param\": []\n  },\n  \"750011\": {\n    \"name\": \"Holmleaf Medal\",\n    \"desc\": \"A medal bestowed by the rulers of Septimont exclusively to Gladiators who demonstrate exceptional performance in the hunt against the Dark Tide. It is regarded as one of the highest honors among Gladiators.\",\n    \"param\": []\n  },\n  \"750012\": {\n    \"name\": \"Griffrex\",\n    \"desc\": \"Native to the Septimont region, Griffrexes once coexisted with the ancestors of Septimont who sought refuge in Rinascita.\\nHowever, the outbreak of the first Dark Tide devastated the Border Mountains, the Griffrexes' habitat, driving most of the species to extinction. Since then, Griffrexes exist mostly as Common Echoes, which are generated at a fixed frequency from Resonance Beacons.\\nOver time, Septimontians became aware that these Griffrex Echoes still retained their instincts of hunting and sensing external frequencies. As a result, they were trained as Common Echoes for hunting purposes to track and attack Dark Tide creations.\",\n    \"param\": []\n  },\n  \"750013\": {\n    \"name\": \"Anchor Stone\",\n    \"desc\": \"A type of small device manufactured with Tacetite formed around the Earthrend Wedge. It provides energy to Anchor Obelisks, which in turn amplify its frequency to repel the Dark Tide and its creations.\\nDuring the hunts, Gladiators of Septimont strategically set up Anchor Obelisks carrying Anchor Stones at critical locations across Maroonwood, the main battlefield. These devices help them drive the Dark Tide and its creations toward the base of the Earthrend Wedge, where they are eliminated. The strategy has proven highly effective in preventing the Dark Tide's spread beyond the Earthrend Wedge's containment.\",\n    \"param\": []\n  },\n  \"750014\": {\n    \"name\": \"Anchor Obelisk\",\n    \"desc\": \"An installation that can be field-deployed to amplify the frequency produced by Anchor Stones. Once the Anchor Stone is inserted, it can generate an energy field to repel the Dark Tide and its creations.\\nDuring the hunts, Gladiators of Septimont strategically set up Anchor Obelisks carrying Anchor Stones at critical locations across Maroonwood, the main battlefield. These devices help them drive the Dark Tide and its creations toward the base of the Earthrend Wedge, where they are eliminated. The strategy has proven highly effective in preventing the Dark Tide's spread beyond the Earthrend Wedge's containment.\",\n    \"param\": []\n  },\n  \"750015\": {\n    \"name\": \"Asphodel Barrens\",\n    \"desc\": \"A field nestled deep within Maroonwood. At an elevation approaching Earthrend Wedge and situated in the lower middle level of the Sanguis Plateaus, it serves as the primary battleground where Gladiators engage in deadly combat with the Dark Tide and its creatures.\",\n    \"param\": []\n  },\n  \"750016\": {\n    \"name\": \"Murmurstown\",\n    \"desc\": \"A lost Gladiator town located in the Wastelands at lower levels of the Sanguis Plateaus.\",\n    \"param\": []\n  },\n  \"750017\": {\n    \"name\": \"Wastelands\",\n    \"desc\": \"The term referring to the lower levels of the Sanguis Plateaus corrupted by the Dark Tide. This desolate region is marked by hostile conditions and is largely devoid of human activity.\",\n    \"param\": []\n  },\n  \"750018\": {\n    \"name\": \"Mesona\",\n    \"desc\": \"A legendary plant said to grow in Manes Deep. It can survive for years in environments tainted by the Dark Tide, giving it a natural resistance to corruption. When used in medicine, it can slow the Dark Tide's corruption effect on the human body and help restore consciousness.\",\n    \"param\": []\n  },\n  \"750019\": {\n    \"name\": \"Hollow Figure\",\n    \"desc\": \"Victims of Dark Tide corruption who have lost all self-awareness. Their bodies usually resemble stone statues while retaining their original size. Such individuals constantly murmur and recite incomprehensible words and \\\"hymns praising the Dark Tide.\\\" The voices from the Hollow Figures have been confirmed to be mentally debilitating, capable of influencing the cognition and mental stability of ordinary people to some extent.\",\n    \"param\": []\n  },\n  \"750020\": {\n    \"name\": \"Waystone\",\n    \"desc\": \"Objects that look like giant stone statues. They are often found near heavily traveled routes or high vantage points, serving as navigational markers for passersby. Some argue that these Waystones are a special type of Echo, formed from the fervent emotional frequencies of Gladiators who traveled through these areas. This theory, however, remains controversial in academic circles.\",\n    \"param\": []\n  },\n  \"750021\": {\n    \"name\": \"Echo-Type Combat Machine\",\n    \"desc\": \"This type includes Hologram Echo: Chest Mimic, Hologram Echo: Junrock, Hologram Echo: Drake, Hologram Echo: Hoartoise, and Hologram Echo: Puff.\",\n    \"param\": []\n  },\n  \"130601\": {\n    \"name\": \"Crown of Wills\",\n    \"desc\": \"Each stack grants {0} Electro DMG Bonus, stacking up to \u003CSapTag=1>{1}\u003C/SapTag> {Cus:Sap,S=time P=times SapTag=1}. When \u003Ccolor=Highlight>Resonance Liberation - Sublime is the Sun: Everbright Protector\u003C/color> ends, all stacks of Crown of Wills are removed.\",\n    \"param\": [\n      \"15%\",\n      \"1\"\n    ]\n  },\n  \"750022\": {\n    \"name\": \"Glacio-Type Combat Machine\",\n    \"desc\": \"This type includes Tacetite Spikes with Optional Module II, Glacio Beacon, Hologram Echo: Junrock with Optional Module I, Frost Spout, Hologram Echo: Puff, and Freeze Jet\",\n    \"param\": []\n  },\n  \"750023\": {\n    \"name\": \"Fusion-Type Combat Machine\",\n    \"desc\": \"This type includes: Tacetite Barrage with Optional Module I, Hologram Echo: Drake, Hologram Echo: Hoartoise with Optional Module II, Hologram Echo: Chest Mimic, and Burst Launcher\",\n    \"param\": []\n  },\n  \"750024\": {\n    \"name\": \"Aero-Type Combat Machine\",\n    \"desc\": \"This type includes Repulsor Spout, Vortex Generator, Whirlpool Device.\",\n    \"param\": []\n  },\n  \"750025\": {\n    \"name\": \"Electro-Type Combat Machine\",\n    \"desc\": \"This type includes Stun Emitter, Tacetite Spikes with Optional Module I, Thunder Lance, and Shock Inductor.\",\n    \"param\": []\n  },\n  \"750026\": {\n    \"name\": \"Lucky Coin\",\n    \"desc\": \"Nimbus Wraith and Tacet Discords defeated by Hologram Echo: Chest Mimic may drop this item.\",\n    \"param\": []\n  },\n  \"750027\": {\n    \"name\": \"KU-Money's Shop\",\n    \"desc\": \"KU-Money's Shop appears after certain waves, where you can consume Sim Credits to purchase Tactics and items.\",\n    \"param\": []\n  },\n  \"750028\": {\n    \"name\": \"Silent Lightning\",\n    \"desc\": \"A Tactic Set that generates Chain Lightnings bouncing between targets, which is triggered by inflicting Paralysis on the targets.\",\n    \"param\": []\n  },\n  \"750029\": {\n    \"name\": \"Silver Bullet\",\n    \"desc\": \"A Tactic Set that improves resource acquisition efficiency and converts surplus resources into offensive power.\",\n    \"param\": []\n  },\n  \"750030\": {\n    \"name\": \"Saturation Fire\",\n    \"desc\": \"A Tactic Set focused on fire suppression by boosting Attack Speed and Control effects.\",\n    \"param\": []\n  },\n  \"750031\": {\n    \"name\": \"Core\",\n    \"desc\": \"The highly recommended core tactics of a Tactic Set.\",\n    \"param\": []\n  },\n  \"750032\": {\n    \"name\": \"DMG Enhancement\",\n    \"desc\": \"This type of Tactic increases ATK, Crit. Rate, and DMG of certain Attributes, and reduces Tacet Discords' RES, improving the attack efficiency.\",\n    \"param\": []\n  },\n  \"750033\": {\n    \"name\": \"Enhancement Field\",\n    \"desc\": \"This type of Tactic enhances nearby Combat Machines within a certain range when active.\",\n    \"param\": []\n  },\n  \"141001\": {\n    \"name\": \"Lunar Cycle\",\n    \"desc\": \"Iuno can switch between \u003Ccolor=Highlight>Half Moon\u003C/color> and \u003Ccolor=Highlight>New Moon\u003C/color> states.\\nHalf Moon: Attacks recover Forte Gauge on hit. \\nNew Moon: Basic Attack, Resonance Skill, and Dodge Counter consume Forte Gauge to increase this skill's DMG Multiplier.\",\n    \"param\": []\n  },\n  \"141002\": {\n    \"name\": \"Blessing of the Wan Light\",\n    \"desc\": \"The receiving Resonator gains 4% all DMG Amplification for 10s, stacking up to 10 times. Gaining new stacks resets the duration. This effect ends early if the receiving Resonator is switched off the field.\",\n    \"param\": []\n  },\n  \"141003\": {\n    \"name\": \"Sentience\",\n    \"desc\": \"Iuno can hold up to 100 points of \u003Ccolor=Highlight>Sentience\u003C/color>.\\nCasting Intro Skill restores 40 points of \u003Ccolor=Highlight>Sentience\u003C/color>.\\nCasting Resonance Liberation restores 60 points of \u003Ccolor=Highlight>Sentience\u003C/color>.\\nCasting \u003Ccolor=Highlight>Closing Refrain\u003C/color> or \u003Ccolor=Highlight>Unfinished Refrain\u003C/color> restores 25 points of \u003Ccolor=Highlight>Sentience\u003C/color>.\\nWhen Iuno is in \u003Ccolor=Highlight>Lunar Cycle\u003C/color>, Moonring - Basic Attack,  Moonring - Dodge Counter, and Mid-air Attack restore \u003Ccolor=Highlight>Sentience\u003C/color> on hit.\",\n    \"param\": []\n  },\n  \"130602\": {\n    \"name\": \"Prowess\",\n    \"desc\": \"Augusta can hold up to {0} points of Prowess.\\n- Prowess is obtained when \u003Ccolor=Highlight>Basic Attack\u003C/color>, \u003Ccolor=Highlight>Heavy Attack - Steelclash\u003C/color>, \u003Ccolor=Highlight>Mid-air Attack\u003C/color>, \u003Ccolor=Highlight>Mid-air Dodge Counter\u003C/color>, \u003Ccolor=Highlight>Resonance Skill - Warrior's Blade\u003C/color>, \u003Ccolor=Highlight>Dodge Counter\u003C/color>, or \u003Ccolor=Highlight>Dodge Counter - Heavy Attack: Steelclash\u003C/color> deal damage.\\n- Casting \u003Ccolor=Highlight>Intro Skill - Stride of Goldenflare\u003C/color> fully restores Prowess.\",\n    \"param\": [\n      \"100\"\n    ]\n  },\n  \"130603\": {\n    \"name\": \"Ascendancy\",\n    \"desc\": \"Augusta can hold up to {0} points of Ascendancy.\\n- Ascendancy is obtained when \u003Ccolor=Highlight>Normal Attacks\u003C/color> deal damage.\\n- Casting \u003Ccolor=Highlight>Intro Skill - Stride of Goldenflare\u003C/color> restores {1} Ascendancy.\\n- Casting \u003Ccolor=Highlight>Resonance Skill - Warrior's Blade\u003C/color> restores {2} Ascendancy.\\n- Casting \u003Ccolor=Highlight>Resonance Liberation - Sword of Eternal Oath\u003C/color> restores {3} Ascendancy.\",\n    \"param\": [\n      \"100\",\n      \"20%\",\n      \"10%\",\n      \"40%\"\n    ]\n  },\n  \"130604\": {\n    \"name\": \"Majesty\",\n    \"desc\": \"Augusta can hold up to 2 stacks of Majesty.\\n- 1 stack of Majesty is obtained when casting \u003Ccolor=Highlight>Resonance Skill - Undying Sunlight: Plunge\u003C/color>.\\n- 1 stack of Majesty is obtained when Resonators in the team cast \u003Ccolor=Highlight>Outro Skills\u003C/color> under the effect of Augusta's \u003Ccolor=Highlight>Outro Skill - Battlesong of the Unyielding\u003C/color>.\",\n    \"param\": []\n  },\n  \"130605\": {\n    \"name\": \"Ruler's Realm\",\n    \"desc\": \"- \u003Ccolor=Highlight>Ruler's Realm\u003C/color> lasts for {3}s.\\n- When Resonators in the team casts \u003Ccolor=Highlight>Intro Skill\u003C/color> within \u003Ccolor=Highlight>Ruler's Realm\u003C/color>, they gain a shield equal to {5} + {4} of Augusta's Max HP for {6}s. This effect is unstackable. This Shield will not be passed on to the incoming Resonator.\",\n    \"param\": [\n      \"2\",\n      \"7\",\n      \"9\",\n      \"30\",\n      \"5%\",\n      \"650\",\n      \"10\"\n    ]\n  },\n  \"130606\": {\n    \"name\": \"Sworn Allegiance\",\n    \"desc\": \"- In the \u003Ccolor=Highlight>Sworn Allegiance\u003C/color> state, time is temporarily stopped, and \u003Ccolor=Highlight>Resonator switching\u003C/color> is disabled. Only \u003Ccolor=Highlight>Sublime is the Sun - Sunborne\u003C/color>, \u003Ccolor=Highlight>Sublime is the Sun - Everbright Protector\u003C/color>, and \u003Ccolor=Highlight>Dodge\u003C/color> can be performed in the \u003Ccolor=Highlight>Sworn Allegiance\u003C/color> state. \u003Ccolor=Highlight>Mid-air Attacks\u003C/color> can be performed in this state while airborne.\\n- In the \u003Ccolor=Highlight>Sworn Allegiance\u003C/color> state, \u003Ccolor=Highlight>{Cus:Ipt,Touch=tap PC=press Gamepad=press}\u003C/color> or \u003Ccolor=Highlight>hold Normal Attack\u003C/color> to cast \u003Ccolor=Highlight>Sublime is the Sun - Sunborne\u003C/color>. Augusta can walk on water without consuming STA in this state.\\n- When \u003Ccolor=Highlight>Sworn Allegiance\u003C/color> ends, cast \u003Ccolor=Highlight>Sublime is the Sun - Everbright Protector\u003C/color> automatically.\\n- Performing \u003Ccolor=Highlight>environmental, gameplay, or other interactions\u003C/color> ends \u003Ccolor=Highlight>Sworn Allegiance\u003C/color> without triggering \u003Ccolor=Highlight>Sublime is the Sun - Everbright Protector\u003C/color>.\",\n    \"param\": []\n  },\n  \"750034\": {\n    \"name\": \"Hunting Trap\",\n    \"desc\": \"This type of Tactic enhances debuffs like Paralysis, Slow, Frozen, and Burning.\",\n    \"param\": []\n  },\n  \"260001\": {\n    \"name\": \"Internal Security Agency\",\n    \"desc\": \"An institution that operates independently of the administrative, judicial, and military branches of Huanglong, with the highest official titled \\\"Chief Commander.\\\" Reporting directly to the Emperor of Huanglong, it holds the authority to investigate any case, official, or criminal without approval from other agencies, with the power to \\\"act first, report later.\\\" Tasked with handling intricate cases year-round, the agency has developed specialized expertise in managing Resonators.\",\n    \"param\": []\n  },\n  \"260002\": {\n    \"name\": \"Ministry of Sentinel Affairs\",\n    \"desc\": \"A special agency responsible for monitoring Sentinels, astronomy, and calendars across Huanglong's various cities. Led by the Minister of Sentinel Affairs in Mingting, it has subordinate bureaus in the other six cities, each headed by a Supervisor. While they hold independent authority on Sentinel-related matters, they are limited to advising and supervising the administrative bodies of each city and Mingting.\",\n    \"param\": []\n  },\n  \"260003\": {\n    \"name\": \"Mindsight\",\n    \"desc\": \"A unique Resonance Ability of Qiuyuan. By perceiving the nature and differences of surrounding frequencies, he can discern an enemy's location and even state of mind. In extreme cases, this perception can be amplified through Sonoro Spheres, bringing to life the mental imagery of his enemies—or even his own.\",\n    \"param\": []\n  },\n  \"260004\": {\n    \"name\": \"Lahai-Roi\",\n    \"desc\": \"A civilization located at the polar region of Solaris. Ancient shifts in the planetary axis redefined the world's geography, turning the Lahai-Roi region into what is now the planet's pole. Over time, the vast caverns deep beneath thick layers of ice and snow gradually became habitable for humankind. In this warm and humid underground haven stands an academic metropolis for Resonators, celebrated as the \\\"Research Haven of Solaris\\\" and a \\\"Utopia for Researchers.\\\"\",\n    \"param\": []\n  },\n  \"260005\": {\n    \"name\": \"Chimera\",\n    \"desc\": \"A Tidespawn created by Leviathan. It is a fusion of the frequencies of three powerful Tacet Discords: the great lion \\\"Nemea,\\\" the ancestral goat \\\"Pan,\\\" and the slippery serpent \\\"Python.\\\" Once Leviathan's \\\"first offspring,\\\" it now \\\"resides\\\" within Galbrena after merging with her frequency.\\nWithin this fused being, the lion's brutal nature dominates Chimera's will, while the goat tempers its violence by feeding on human compassion. The serpent, sly and independent, appears loyal to Galbrena but secretly undermines her frequency.\",\n    \"param\": []\n  },\n  \"260006\": {\n    \"name\": \"Fabianum\",\n    \"desc\": \"The past name of \\\"Murmurstown.\\\" Devastated sixteen years ago by the outbreak of the Dark Tide, it is now a lost Gladiator town in the Wastelands.\",\n    \"param\": []\n  },\n  \"260007\": {\n    \"name\": \"Paradimensional Tacet Field\",\n    \"desc\": \"The Tacet Fields that exist in isolated dimensions. \\n\\\"Tacet Fields\\\" are thought to be where all Tacet Discords originate. These locations feature a sky of inverted seas and a deep cross-shaped Tacet Mark on the ground. Reverberations fill the air, linking our world to an unknown space through a white Resonance Cord. These areas attract gatherings of Tacet Discords.\",\n    \"param\": []\n  },\n  \"260008\": {\n    \"name\": \"Grand Marshal\",\n    \"desc\": \"As the highest official in Huanglong's Ministry of War, the Minister oversees all military affairs for the six cities in Huanglong. The honorific title \\\"Grand Marshal\\\" is used to signify the rank and authority of this position.\",\n    \"param\": []\n  },\n  \"260009\": {\n    \"name\": \"Mingting\",\n    \"desc\": \"The capital of Huanglong. The nation's political, economic, and cultural center.\",\n    \"param\": []\n  },\n  \"260010\": {\n    \"name\": \"Ministry of War\",\n    \"desc\": \"The Ministry of War is Huanglong's supreme military command, headquartered in Mingting with branches in all six cities. Its leader, the Minister of War, holds supreme command over all military affairs. Authority is delegated to a General in each city, who manages local forces. While Mingting usually appoints these Generals, local Sentinels have the authority to do so in certain special cities.\",\n    \"param\": []\n  },\n  \"260011\": {\n    \"name\": \"Censorate\",\n    \"desc\": \"One of Huanglong's three judicial bodies. It holds the authority to jointly try major cases and wields significant supervisory power, a duty summarized as \\\"to probe evil and maintain discipline.\\\" Its officials are generally titled Censors, while those stationed or assigned temporarily in the six cities are called Investigating Censors.\",\n    \"param\": []\n  },\n  \"260012\": {\n    \"name\": \"Fenrico the First\",\n    \"desc\": \"Just as the name enjoyed by Napoli the Second, it is a title Primus Fenrico should have rightfully possessed. However, due to unknown reasons, Fenrico forbade Acolytes from referring to him as such, until he met his end at the bottom of the sea. In the history of the Order of the Deep, he is the only one who bears the name \\\"Fenrico.\\\"\",\n    \"param\": []\n  },\n  \"800014\": {\n    \"name\": \"Zenith Windblade\",\n    \"desc\": \"Deals Aero DMG to enemies along its trajectory.\",\n    \"param\": []\n  },\n  \"800013\": {\n    \"name\": \"Isomer Bolt\",\n    \"desc\": \"Deals Glacio DMG to enemies around the point of impact.\",\n    \"param\": []\n  },\n  \"800015\": {\n    \"name\": \"Sanguine Wheel\",\n    \"desc\": \"Slices the enemies at close range to deal DMG. Cannot benefit from Attack Speed bonuses.\",\n    \"param\": []\n  },\n  \"800016\": {\n    \"name\": \"Glittering Ray\",\n    \"desc\": \"Pierces through enemies along its trajectory, dealing multiple instances of damage to enemies at intersections.\",\n    \"param\": []\n  },\n  \"800017\": {\n    \"name\": \"Phaser\",\n    \"desc\": \"Greatly increase range and DMG Multiplier.\",\n    \"param\": []\n  },\n  \"141101\": {\n    \"name\": \"Swordster's Soliloquy\",\n    \"desc\": \"Qiuyuan can hold up to 600 points of Swordster's Soliloquy.\\n- 100 points of Swordster's Soliloquy is obtained when performing \u003Ccolor=Highlight>Basic Attack\u003C/color> Stage 3.\\n- 100 points of Swordster's Soliloquy is obtained when performing each stage of \u003Ccolor=Highlight>Thus Spoke the Blade: Inkwash\u003C/color>.\\n- 100 points of Swordster's Soliloquy is obtained when performing \u003Ccolor=Highlight>Dodge Counter\u003C/color>.\\n- 400 points of Swordster's Soliloquy is obtained when performing \u003Ccolor=Highlight>Intro Skill\u003C/color>.\\n- Swordster's Soliloquy cannot be obtained during the Inksplash of Mind state.\\n- Swordster's Soliloquy is cleared when the Inksplash of Mind state ends.\",\n    \"param\": []\n  },\n  \"141102\": {\n    \"name\": \"Inksplash of Mind\",\n    \"desc\": \"When Swordster's Soliloquy is full, Qiuyuan enters the \u003Ccolor=Highlight>Inksplash of Mind\u003C/color> state for 8s. During this state, \u003Ccolor=Highlight>Heavy Attack\u003C/color> is replaced by Heavy Attack \u003Ccolor=Highlight>Thus Spoke the Blade: To Save\u003C/color>.\\nIn this state, hold \u003Ccolor=Highlight>Normal Attack\u003C/color> to consume Swordster's Soliloquy to perform Heavy Attack \u003Ccolor=Highlight>Thus Spoke the Blade: To Teach\u003C/color>, \u003Ccolor=Highlight>Thus Spoke the Blade: To Save\u003C/color>, and \u003Ccolor=Highlight>Thus Spoke the Blade: To Sacrifice\u003C/color> in order, dealing \u003Ccolor=Wind>Aero DMG\u003C/color>, considered as Heavy Attack DMG.\\n- Inksplash of Mind ends when Swordster's Soliloquy is used up.\",\n    \"param\": []\n  },\n  \"141103\": {\n    \"name\": \"Bamboo's Shade\",\n    \"desc\": \"When Qiuyuan holds 400 points of Swordster's Soliloquy, he obtains the \u003Ccolor=Highlight>Bamboo's Shade\u003C/color> effect, allowing all nearby active Resonators in the team to gain 30% Echo Skill DMG Bonus for 30s.\",\n    \"param\": []\n  },\n  \"800018\": {\n    \"name\": \"Breeze Breaker\",\n    \"desc\": \"Deal Aero DMG to surrounding enemies equal to 100% of Rover's ATK. Then increase Movement Speed by 48%, which gradually decreases to 0% over 4s. Each 1% Movement Speed gained during this time grants 0.8% DMG Bonus.\\n\u003Ccolor=Highlight>At Resonator Lv. 5\u003C/color>\\nMovement Speed bonus increases to 64%, and the damage conversion rate rises to 1%.\\n\u003Ccolor=Highlight>At Resonator Lv. 10\u003C/color>\\nMovement Speed bonus increases to 80%, and the damage conversion rate rises to 1.2%.\",\n    \"param\": []\n  },\n  \"800019\": {\n    \"name\": \"Ashen Oath\",\n    \"desc\": \"Deal Fusion DMG to surrounding enemies equal to 100% of Galbrena's ATK. Then increase Attack Speed by 30% for 5s. Each damage dealt during this time increases the Weapon's Crit. Rate by 1% for 5s, stacking up to 20 times.\\n\u003Ccolor=Highlight>At Resonator Lv. 5\u003C/color>\\nAttack Speed bonus increases to 40%, and the Crit. Rate bonus now stacks up to 30 times.\\n\u003Ccolor=Highlight>At Resonator Lv. 10\u003C/color>\\nAttack Speed bonus increases to 50%, and the Crit. Rate bonus now stacks up to 40 times.\",\n    \"param\": []\n  },\n  \"800020\": {\n    \"name\": \"Waxing Moon\",\n    \"desc\": \"Deal Aero DMG to surrounding enemies equal to 40% of Iuno's Max HP. Then lose 30% of the current HP to increase ATK by 40% of her Max HP for 4s. Hitting an enemy during this time restores 1.5% of her Max HP.\\n\u003Ccolor=Highlight>At Resonator Lv. 5\u003C/color>\\nATK conversion rate increases to 60%, and duration extends to 5s.\\n\u003Ccolor=Highlight>At Resonator Lv. 10\u003C/color>\\nATK conversion rate increases to 80%, and duration extends to 6s.\",\n    \"param\": []\n  },\n  \"800021\": {\n    \"name\": \"Zephyr Symphony\",\n    \"desc\": \"Summon a Harmonic Note that deals Aero DMG to surrounding enemies equal to 10% of Ciaccona's ATK every 0.5s for 10s. Enemies damaged by this skill have their DMG taken increased by 3% and their Movement Speed reduced by 1% for 5s, stacking up to 20 times.\\n\u003Ccolor=Highlight>At Resonator Lv. 5\u003C/color>\\nEnemies' DMG taken is increased by 4%, and Movement Speed is reduced by 2%.\\n\u003Ccolor=Highlight>At Resonator Lv. 10\u003C/color>\\nEnemies' DMG taken is increased by 5%, and Movement Speed is reduced by 3%.\",\n    \"param\": []\n  },\n  \"800022\": {\n    \"name\": \"Blazing Star\",\n    \"desc\": \"Randomly launches a star to fall upon enemies, dealing Fusion DMG.\",\n    \"param\": []\n  },\n  \"800023\": {\n    \"name\": \"Rampant Fire\",\n    \"desc\": \"Continuously sprays fire forward, dealing Havoc DMG. Cannot benefit from Attack Speed bonuses.\",\n    \"param\": []\n  },\n  \"800024\": {\n    \"name\": \"Feilian Shock\",\n    \"desc\": \"A summoned Feilian Beringal that stays in one place to deal Aero DMG to surrounding enemies. Cannot benefit from Attack Speed bonuses.\",\n    \"param\": []\n  },\n  \"800025\": {\n    \"name\": \"Explosive Omen\",\n    \"desc\": \"Randomly flips a trap that detonates after a while or upon touching an enemy, dealing AoE Fusion DMG.\",\n    \"param\": []\n  },\n  \"800026\": {\n    \"name\": \"Bullet Weapon\",\n    \"desc\": \"Weapons that fire ballistic impact projectiles, such as Isomer Bolt and Blazing Star.\",\n    \"param\": []\n  },\n  \"800027\": {\n    \"name\": \"Summon Weapon\",\n    \"desc\": \"Weapons that can summon Echo projections, such as Feilian Shock and Sanguine Wheel.\",\n    \"param\": []\n  },\n  \"800028\": {\n    \"name\": \"Beam Weapon\",\n    \"desc\": \"Weapons that shoot energy beams, such as Zenith Windblade and Glittering Ray.\",\n    \"param\": []\n  },\n  \"800029\": {\n    \"name\": \"Morph Weapon\",\n    \"desc\": \"Weapons with special effects, such as Rampant Fire and Explosive Omen.\",\n    \"param\": []\n  },\n  \"800030\": {\n    \"name\": \"Synergistic Evo\",\n    \"desc\": \"Some weapons can be absorbed to evolve another weapon into its Ultimate Form. The evolution requirements differ depending on the Weapon. The evolved Weapons inherit all buff effects of the absorbed weapon.\",\n    \"param\": []\n  },\n  \"120801\": {\n    \"name\": \"Afterflame\",\n    \"desc\": \"Galbrena can hold up to {0} points of \u003Ccolor=Highlight>Afterflame\u003C/color>.\\nIn \u003Ccolor=Highlight>Threshold State\u003C/color>, Galbrena restores \u003CSapTag=1>{1}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=1} of \u003Ccolor=Highlight>Afterflame\u003C/color> when nearby Resonators in the team casts Echo Skills. Echoes with the same name can only trigger this effect once. This effect resets when Galbrena exits \u003Ccolor=Highlight>Demon Hypostasis\u003C/color>.\\nWhile \u003Ccolor=Highlight>Demon Hypostasis\u003C/color> lasts, each point of \u003Ccolor=Highlight>Afterflame\u003C/color> increases the DMG dealt through \u003Ccolor=Highlight>Basic Attack - Seraphic Execution\u003C/color>, \u003Ccolor=Highlight>Heavy Attack - Flamewing Verdict\u003C/color>, \u003Ccolor=Highlight>Mid-air Attack - Hellsent Barrage\u003C/color>, \u003Ccolor=Highlight>Resonance Skill - Ravage\u003C/color>, and \u003Ccolor=Highlight>Dodge Counter - Purgatory Scourge\u003C/color>  by {2}, up to {3}. This effect is removed upon exiting \u003Ccolor=Highlight>Demon Hypostasis\u003C/color>.\\nAll \u003Ccolor=Highlight>Afterflame\u003C/color> is removed when Galbrena exits \u003Ccolor=Highlight>Demon Hypostasis\u003C/color>.\",\n    \"param\": [\n      \"40\",\n      \"8\",\n      \"1.5%\",\n      \"60%\"\n    ]\n  },\n  \"120802\": {\n    \"name\": \"Sinflame\",\n    \"desc\": \"Galbrena can hold up to {0} points of \u003Ccolor=Highlight>Sinflame\u003C/color>.\\nDuring \u003Ccolor=Highlight>Threshold State\u003C/color>, Basic Attack, Heavy Attack - Volley of Death, Mid-air Attack - Ashfall Barrage, Resonance Skill - Encroach, and Intro Skill - Hellflare Overload restore \u003Ccolor=Highlight>Sinflame\u003C/color> on hit.\\nWhen \u003Ccolor=Highlight>Sinflame\u003C/color> reaches {1} points, \u003Ccolor=Highlight>Resonance Skill\u003C/color> is replaced with \u003Ccolor=Highlight>Resonance Skill - Ascent of Malice\u003C/color>. \\nCasting \u003Ccolor=Highlight>Resonance Skill - Ascent of Malice\u003C/color> converts \u003Ccolor=Highlight>Sinflame\u003C/color> into an equivalent amount of \u003Ccolor=Highlight>Purging Flame\u003C/color>.\",\n    \"param\": [\n      \"100\",\n      \"100\"\n    ]\n  },\n  \"120803\": {\n    \"name\": \"Purging Flame\",\n    \"desc\": \"Galbrena can hold up to {0} points of \u003Ccolor=Highlight>Purging Flame\u003C/color>.\\nCasting \u003Ccolor=Highlight>Resonance Skill - Ascent of Malice\u003C/color> converts \u003Ccolor=Highlight>Sinflame\u003C/color> into an equivalent amount of \u003Ccolor=Highlight>Purging Flame\u003C/color>\\nWhile \u003Ccolor=Highlight>Demon Hypostasis\u003C/color> lasts, Basic Attack - Seraphic Execution, Heavy Attack - Flamewing Verdict, Mid-air Attack - Hellsent Barrage, Dodge Counter - Purgatory Scourge, and Resonance Skill - Ravage consume \u003Ccolor=Highlight>Purging Flame\u003C/color> on hit.\",\n    \"param\": [\n      \"100\"\n    ]\n  },\n  \"120804\": {\n    \"name\": \"Threshold State\",\n    \"desc\": \"By default, Galbrena is in \u003Ccolor=Highlight>Threshold State\u003C/color>, and in this state, she accumulates \u003Ccolor=Highlight>Afterflame\u003C/color> and \u003Ccolor=Highlight>Sinflame\u003C/color>.\",\n    \"param\": []\n  },\n  \"120805\": {\n    \"name\": \"Demon Hypostasis\",\n    \"desc\": \"Casting \u003Ccolor=Highlight>Resonance Skill - Ascent of Malice\u003C/color> sends Galbrena into \u003Ccolor=Highlight>Demon Hypostasis\u003C/color>.\\nWhile \u003Ccolor=Highlight>Demon Hypostasis\u003C/color> lasts, Galbrena's Basic Attack, Heavy Attack - Volley of Death, Mid-air Attack - Ashfall Barrage, Dodge Counter - Blood for Blood, Resonance Skill - Encroach are replaced with Basic Attack - Seraphic Execution, Heavy Attack - Flamewing Verdict, Mid-air Attack - Hellsent Barrage, Dodge Counter - Purgatory Scourge and Resonance Skill - Ravage, which consume \u003Ccolor=Highlight>Purging Flame\u003C/color> on hit.\\n\u003Ccolor=Highlight>Demon Hypostasis\u003C/color> ends when \u003Ccolor=Highlight>Purging Flame\u003C/color> depletes or when Galbrena stays in \u003Ccolor=Highlight>Demon Hypostasis\u003C/color> for over 50s.\",\n    \"param\": []\n  },\n  \"120806\": {\n    \"name\": \"Eternal Hypostasis\",\n    \"desc\": \"When Resonance Chain Node \u003Ccolor=Highlight>I Remain Who I am, Eternal My Flame\u003C/color> is activated, \u003Ccolor=Highlight>Demon Hypostasis\u003C/color> becomes \u003Ccolor=Highlight>Eternal Hypostasis\u003C/color>. \u003Ccolor=Highlight>Eternal Hypostasis\u003C/color> retains all effects of \u003Ccolor=Highlight>Demon Hypostasis\u003C/color>. Additionally, while \u003Ccolor=Highlight>Eternal Hypostasis\u003C/color> lasts, the DMG Multipliers of \u003Ccolor=Highlight>Basic Attack - Seraphic Execution\u003C/color>, \u003Ccolor=Highlight>Heavy Attack - Flamewing Verdict\u003C/color>,  \u003Ccolor=Highlight>Mid-air Attack - Hellsent Barrage\u003C/color>, and \u003Ccolor=Highlight>Dodge Counter - Purgatory Scourge\u003C/color> are increased by {0}.\",\n    \"param\": [\n      \"60%\"\n    ]\n  },\n  \"120807\": {\n    \"name\": \"Burning Drive\",\n    \"desc\": \"Casting \u003Ccolor=Highlight>Intro Skill\u003C/color>, \u003Ccolor=Highlight>Hellstride\u003C/color>, \u003Ccolor=Highlight>Basic Attack - Seraphic Execution Stage 4\u003C/color>, \u003Ccolor=Highlight>Resonance Skill - Encroach\u003C/color>, \u003Ccolor=Highlight>Resonance Skill - Ascent of Malice\u003C/color>, and \u003Ccolor=Highlight>Resonance Skill - Ravage\u003C/color> increases Galbrena's ATK and resistance to interruption by {0} for {1}s.\",\n    \"param\": [\n      \"20%\",\n      \"4\"\n    ]\n  },\n  \"270001\": {\n    \"name\": \"Land of Xuanfang\",\n    \"desc\": \"A region located between Mengzhou and Jinzhou. It is considered a vital passage way between the two cities, and also once a strategic hold for intercepting Tacet Discords.\",\n    \"param\": []\n  },\n  \"150801\": {\n    \"name\": \"Unseen Snare\",\n    \"desc\": \"When targets marked by \u003Ccolor=Highlight>Unseen Snare\u003C/color> take direct damage from Resonators, Chisa inflicts \u003CSapTag=0>{0}\u003C/SapTag> {Cus:Sap,S=stack P=stacks SapTag=0} of \u003Ccolor=Highlight>Havoc Bane\u003C/color> on them. This effect can be triggered up to once every {1}s.\",\n    \"param\": [\n      \"1\",\n      \"2\"\n    ]\n  },\n  \"150802\": {\n    \"name\": \"Thread of Bane\",\n    \"desc\": \"When dealing damage to the targets affected by \u003Ccolor=Highlight>Unseen Snare\u003C/color>, ignore {0} of their DEF.\",\n    \"param\": [\n      \"18%\"\n    ]\n  },\n  \"150803\": {\n    \"name\": \"Ring of Chainsaw\",\n    \"desc\": \"Chisa can hold up to {0} points of \u003Ccolor=Highlight>Ring of Chainsaw\u003C/color>.\\nHitting a target with \u003Ccolor=Highlight>Normal Attack \u003C/color> and Resonance Skill \u003Ccolor=Highlight>Eye of Unraveling\u003C/color> grants \u003Ccolor=Highlight>Ring of Chainsaw\u003C/color>.\\nCasting Resonance Liberation \u003Ccolor=Highlight>Moment of Nihility\u003C/color> grants {1} points of \u003Ccolor=Highlight>Ring of Chainsaw\u003C/color>.\\nCasting Intro Skill \u003Ccolor=Highlight>Reverberance - Return\u003C/color> grants {2} points of \u003Ccolor=Highlight>Ring of Chainsaw\u003C/color>.\",\n    \"param\": [\n      \"100\",\n      \"40\",\n      \"20\"\n    ]\n  },\n  \"150804\": {\n    \"name\": \"Lifethread - Jetstream\",\n    \"desc\": \"Chisa can hold up to {0} points of \u003Ccolor=Highlight>Lifethread - Jetstream\u003C/color>. \\nChisa continuously obtains \u003Ccolor=Highlight>Lifethread - Jetstream\u003C/color> over time.\\nChisa obtains {1} points of \u003Ccolor=Highlight>Lifethread - Jetstream\u003C/color> upon defeating a target. \\nExiting \u003Ccolor=Highlight>Chainsaw Mode\u003C/color> resets \u003Ccolor=Highlight>Lifethread - Jetstream\u003C/color> to the max limit.\\nChisa cannot obtain \u003Ccolor=Highlight>Lifethread - Jetstream\u003C/color> passively for a short period of time after casting  \u003Ccolor=Highlight>Lifethread - Glide\u003C/color>.\",\n    \"param\": [\n      \"100\",\n      \"100\"\n    ]\n  },\n  \"150805\": {\n    \"name\": \"Woven Myriad - Convergence\",\n    \"desc\": \"The DMG Multipliers of \u003Ccolor=Highlight>Sawring - Blitz\u003C/color>, \u003Ccolor=Highlight>Chainsaw Mode - Dodge Counter\u003C/color>, and \u003Ccolor=Highlight>Sawring - Eradication\u003C/color> are increased by {0}.\\n\u003Ccolor=Highlight>Ring of Chainsaw\u003C/color> consumed by \u003Ccolor=Highlight>Sawring- Blitz\u003C/color> and \u003Ccolor=Highlight>Chainsaw Mode - Dodge Counter\u003C/color> additionally increases the DMG Multiplier of \u003Ccolor=Highlight>Sawring - Eradication\u003C/color> by {1}.\\nCasting \u003Ccolor=Highlight>Sawring - Eradication\u003C/color> ends \u003Ccolor=Highlight>Woven Myriad - Convergence\u003C/color>.\",\n    \"param\": [\n      \"120%\",\n      \"120%\"\n    ]\n  },\n  \"150806\": {\n    \"name\": \"Electro Rage\",\n    \"desc\": \"Electro Rage increases the damage dealt by the next Electro Flare. This effect is removed once triggered.\",\n    \"param\": []\n  },\n  \"150811\": {\n    \"name\": \"Negative Status DMG\",\n    \"desc\": \"Includes Spectro Frazzle DMG, Havoc Bane DMG, Fusion Burst DMG, Glacio Chafe DMG, Electro Flare DMG, and Aero Erosion DMG.\",\n    \"param\": []\n  },\n  \"130701\": {\n    \"name\": \"Trigram\",\n    \"desc\": \"Buling can hold up to {0} Trigrams. When Trigrams reach the max number, gaining new Trigrams moves all Trigrams {1} slot to the left, and the original leftmost Trigram will be removed.\\n- Trigram - Mountain is obtained when \u003Ccolor=Highlight>Basic Attack Stage 2\u003C/color> deals damage.\\n- Trigram - Thunder is obtained when \u003Ccolor=Highlight>Basic Attack Stage 4\u003C/color> or \u003Ccolor=Highlight>Mid-air Attack\u003C/color> deals damage.\\n- Trigram - Thunder is obtained when casting \u003Ccolor=Highlight>Resonance Skill - In Shadow Thunder Stirs\u003C/color>.\",\n    \"param\": [\n      \"4\",\n      \"1\"\n    ]\n  },\n  \"130702\": {\n    \"name\": \"Yin-Yang Balance\",\n    \"desc\": \"When Buling obtains Minor Yin and Minor Yang, she enters the \u003Ccolor=Highlight>Yin-Yang Balance\u003C/color> state, replacing her \u003Ccolor=Highlight>Resonance Liberation - Flashing Thunder Spell\u003C/color> with \u003Ccolor=Highlight>Resonance Liberation - Flashing Thunder Spell: Harmony\u003C/color>.\",\n    \"param\": []\n  },\n  \"130703\": {\n    \"name\": \"Five Thunders Spell Array\",\n    \"desc\": \"When \u003Ccolor=Highlight>Five Thunders Spell Array\u003C/color> is active, all Resonators in the team enter the \u003Ccolor=Highlight>Thunder Spell - Primordial Qi\u003C/color> state.\\n- While in the \u003Ccolor=Highlight>Thunder Spell - Primordial Qi\u003C/color> state, when any Resonator in the team casts \u003Ccolor=Highlight>Intro Skill\u003C/color>,  \u003Ccolor=Highlight>Thunder Spell - Primordial Qi\u003C/color> becomes \u003Ccolor=Highlight>Thunder Spell - Yin and Yang\u003C/color>.\\n- \u003Ccolor=Highlight>Thunder Spell - Yin and Yang\u003C/color> grants {0} \u003Ccolor=Highlight>Resonance Skill\u003C/color> DMG Bonus to active Resonators in the team. When any Resonator in the team casts \u003Ccolor=Highlight>Intro Skill\u003C/color> during this state, \u003Ccolor=Highlight>Thunder Spell - Yin and Yang\u003C/color> becomes \u003Ccolor=Highlight>Thunder Spell - Heaven, Earth, Mind\u003C/color>.\\n- \u003Ccolor=Highlight>Thunder Spell - Heaven, Earth, Mind\u003C/color> grants {1} \u003Ccolor=Highlight>Resonance Skill\u003C/color> DMG Bonus to active Resonators in the team.\",\n    \"param\": [\n      \"10%\",\n      \"25%\"\n    ]\n  },\n  \"130704\": {\n    \"name\": \"Thunder Spell - Heaven, Earth, Mind\",\n    \"desc\": \"\u003Ccolor=Highlight>Thunder Spell - Heaven, Earth, Mind\u003C/color> grants {0} \u003Ccolor=Highlight>Resonance Skill\u003C/color> DMG Bonus to active Resonators in the team.\",\n    \"param\": [\n      \"25%\"\n    ]\n  },\n  \"851064\": {\n    \"name\": \"Neon Tower\",\n    \"desc\": \"A radio communication tower situated in the center of Honami City and the tallest building in the city. It was once Honami's most famous tourist attraction and landmark. It is said that the Lament that destroyed this city started from Neon Tower.\",\n    \"param\": []\n  },\n  \"851065\": {\n    \"name\": \"Left Behind\",\n    \"desc\": \"Citizens of Honami City who perished during the Lament and who now \\\"live\\\" inside the Sonoro Sphere in the form of Human Reverberations. Faint iridescent light flows around their bodies, and they don't seem to be aware of what really happened to them.\",\n    \"param\": []\n  },\n  \"851066\": {\n    \"name\": \"Irideglow\",\n    \"desc\": \"This pale rainbow-colored light surging in the Sonoro Sphere of Honami City is a Waveworn Phenomenon unique to this place. Traces of Irideglow's corruption can be found everywhere in Honami. During periodic Lament outbreaks, Irideglow condenses into a physical form that cuts through space, capturing and devouring everything it meets within the Sonoro. Resonators with long-term exposure to Irideglow have high risk of losing control of their Resonance power, and may even Overclock.\",\n    \"param\": []\n  },\n  \"851067\": {\n    \"name\": \"Longings\",\n    \"desc\": \"The unfulfilled, unresolved attachments of the Left Behind that are scattered throughout Honami City. They possess a special quality that can resonate with Neon Tower, helping their hosts locate the tower's location within the chaotic, overlapping spaces.\",\n    \"param\": []\n  },\n  \"851068\": {\n    \"name\": \"Irideglow Crystal\",\n    \"desc\": \"Traces of crystallization left on the surfaces of buildings and objects from Irideglow corruption. The mildly corrupted Irideglow Crystals—Light Irideglow Crystals, can be separated using certain methods.\",\n    \"param\": []\n  },\n  \"851069\": {\n    \"name\": \"Startorch Academy\",\n    \"desc\": \"Startorch Academy is a comprehensive research facility that doesn't belong to any country, built with the goal of collaborative scientific research. It is an academic metroplis driven solely by educational and research pursuits. Compared to its official title of \\\"Startorch Academy,\\\" the people of Solaris prefer to call it the \\\"Resonator Academy.\\\"\",\n    \"param\": []\n  },\n  \"851070\": {\n    \"name\": \"Void Storm\",\n    \"desc\": \"The regional Waveworn Phenomenon of Lahai-Roi that disrupts the frequencies of anything around it. It happens in a somewhat cyclical pattern.\",\n    \"param\": []\n  },\n  \"851071\": {\n    \"name\": \"Spacetrek Collective\",\n    \"desc\": \"An international scientific organization jointly established by various nations and organizations of Solaris. It oversees the research, development, and construction work in Lahai-Roi. It was the Spacetrek Collective that built the Research Institute and the Startorch Academy in the vast space beneath the frostlands.\",\n    \"param\": []\n  },\n  \"851072\": {\n    \"name\": \"Namipon\",\n    \"desc\": \"This Remnant Creature living inside the Sonoro Sphere of Honami City was said to have been the city's mascot before its destruction. The original \\\"Namipon\\\" was initially conceived as a municipal transit mascot that safeguard citizens' daily commutes, moving at supersonic speeds between urban railroad tracks. Later on, it gradually evolved into a mascot encompassing various aspects of the city.\",\n    \"param\": []\n  },\n  \"851073\": {\n    \"name\": \"Missing Namipons\",\n    \"desc\": \"After Namipon's frequency was torn apart by the the Lament, individual creatures possessing fragments of its frequency were born in the form of various professions of Honami City citizens. Having temporarily lost connection with their original form, they now wander through various parts of the Sonoro Sphere of Honami.\",\n    \"param\": []\n  },\n  \"851100\": {\n    \"name\": \"Combo - Rice Dango Missile\",\n    \"desc\": \"Deals DMG equal to \u003Ccolor=Highlight>{0}\u003C/color> of the Resonator's ATK.\",\n    \"param\": [\n      \"100%\"\n    ]\n  },\n  \"851101\": {\n    \"name\": \"Combo - Rice Dango Missile: Enhanced\",\n    \"desc\": \"Deals DMG equal to \u003Ccolor=Highlight>{0}\u003C/color> of the Resonator's ATK.\",\n    \"param\": [\n      \"120%\"\n    ]\n  },\n  \"851102\": {\n    \"name\": \"Burst - Blazing Pillar\",\n    \"desc\": \"Deals DMG equal to \u003Ccolor=Highlight>{0}\u003C/color> of the Resonator's ATK.\",\n    \"param\": [\n      \"800%\"\n    ]\n  },\n  \"851103\": {\n    \"name\": \"Burst - Scorching Impact\",\n    \"desc\": \"Deals DMG equal to \u003Ccolor=Highlight>{0}\u003C/color> of the Resonator's ATK.\",\n    \"param\": [\n      \"1000%\"\n    ]\n  },\n  \"851104\": {\n    \"name\": \"Boost - Namipon Aid\",\n    \"desc\": \"All Resonators in the team restore HP equal to \u003Ccolor=Highlight>{0}\u003C/color> of the caster's Max HP per second for \u003Ccolor=Highlight>{1}s\u003C/color>.\",\n    \"param\": [\n      \"3%\",\n      \"10\"\n    ]\n  },\n  \"851105\": {\n    \"name\": \"Boost - Sprint\",\n    \"desc\": \"Greatly increases Movement Speed.\",\n    \"param\": []\n  },\n  \"851106\": {\n    \"name\": \"Combo - Support Missile: Enhanced\",\n    \"desc\": \"Deals DMG equal to \u003Ccolor=Highlight>{0}\u003C/color> of the Resonator's ATK.\",\n    \"param\": [\n      \"180%\"\n    ]\n  },\n  \"851107\": {\n    \"name\": \"Combo - Support Missile\",\n    \"desc\": \"Deals DMG equal to \u003Ccolor=Highlight>{0}\u003C/color> of the Resonator's ATK.\",\n    \"param\": [\n      \"100%\"\n    ]\n  },\n  \"851108\": {\n    \"name\": \"Status - Waveworn Bane\",\n    \"desc\": \"Deals DMG equal to \u003Ccolor=Highlight>{0}\u003C/color> of the Resonator's ATK, stacking up to \u003Ccolor=Highlight>{1}\u003C/color> times. This effect can be triggered once per second, lasting for \u003Ccolor=Highlight>{2}s\u003C/color>.\",\n    \"param\": [\n      \"10%\",\n      \"30\",\n      \"10\"\n    ]\n  },\n  \"851109\": {\n    \"name\": \"Boost - Dessert Prep\",\n    \"desc\": \"When Boost - Dessert Prep reaches \u003Ccolor=Highlight>{0}\u003C/color> stacks, remove all stacks to launch Combo - Dessert Strike \u003Ccolor=Highlight>\u003CSapTag=1>{1}\u003C/SapTag>\u003C/color> {Cus:Sap,S=time P=times SapTag=1}.\",\n    \"param\": [\n      \"6\",\n      \"3\"\n    ]\n  },\n  \"851110\": {\n    \"name\": \"Combo - Dessert Strike\",\n    \"desc\": \"Deals DMG equal to \u003Ccolor=Highlight>{0}\u003C/color> of the Resonator's ATK.\",\n    \"param\": [\n      \"75%\"\n    ]\n  },\n  \"851111\": {\n    \"name\": \"Combo - Dessert Strike: Enhanced\",\n    \"desc\": \"Deals DMG equal to \u003Ccolor=Highlight>{0}\u003C/color> of the Resonator's ATK.\",\n    \"param\": [\n      \"300%\"\n    ]\n  },\n  \"851112\": {\n    \"name\": \"Boost - Satisfaction\",\n    \"desc\": \"Gain \u003Ccolor=Highlight>{0}\u003C/color> All DMG Bonus for \u003Ccolor=Highlight>{1}s\u003C/color>, stacking up to \u003Ccolor=Highlight>{2}\u003C/color> times.\",\n    \"param\": [\n      \"25%\",\n      \"10\",\n      \"3\"\n    ]\n  },\n  \"851113\": {\n    \"name\": \"Burst - Coffee Impact\",\n    \"desc\": \"Deals DMG equal to \u003Ccolor=Highlight>{0}\u003C/color> of the current Shield.\",\n    \"param\": [\n      \"150%\"\n    ]\n  },\n  \"851114\": {\n    \"name\": \"Boost - Coffee's Shelter\",\n    \"desc\": \"Immune to Stability DMG.\",\n    \"param\": []\n  },\n  \"851115\": {\n    \"name\": \"Critical State\",\n    \"desc\": \"Stability is at or below \u003Ccolor=Highlight>{0}\u003C/color>.\",\n    \"param\": [\n      \"30%\"\n    ]\n  },\n  \"851074\": {\n    \"name\": \"Ashinohara\",\n    \"desc\": \"The nation encompassing Honami City. Despite the frequent Waveworn Phenomena, it maintains a prosperous, highly urbanized society, marked by its sprawling railroad network.\",\n    \"param\": []\n  },\n  \"851116\": {\n    \"name\": \"Burst - Shock Impact\",\n    \"desc\": \"Deals DMG to nearby targets equal to {0} of the caster's Max HP.\",\n    \"param\": [\n      \"54%\"\n    ]\n  },\n  \"100001\": {\n    \"name\": \"Tune Break\",\n    \"desc\": \"When the target's \u003Ccolor=Highlight>Off-Tune Level\u003C/color> is maxed, they enter the \u003Ccolor=Highlight>Mistune\u003C/color> state:\\nThe active Resonator in the team may perform \u003Ccolor=Highlight>Tune Break Skill\u003C/color> on the target, dealing DMG and causing the target to leave the \u003Ccolor=Highlight>Mistune\u003C/color> state.\\nIf the target is of the Common Class, Resonators in the team may directly deal \u003Ccolor=Highlight>Tune Break DMG\u003C/color> with some of their regular skills on hit. The target leaves the \u003Ccolor=Highlight>Mistune\u003C/color> state afterward.\",\n    \"param\": []\n  },\n  \"100002\": {\n    \"name\": \"Tune Rupture - Shifting\",\n    \"desc\": \"Certain Resonators can inflict \u003Ccolor=Highlight>Tune Rupture - Shifting\u003C/color> on the target. During this state, if the affected target is hit by \u003Ccolor=Highlight>Tune Break\u003C/color>, their \u003Ccolor=Highlight>Tune Rupture - Shifting\u003C/color> state is replaced with \u003Ccolor=Highlight>Tune Rupture - Interfered\u003C/color>.\",\n    \"param\": []\n  },\n  \"100003\": {\n    \"name\": \"Tune Strain - Shifting\",\n    \"desc\": \"Certain Resonators can inflict \u003Ccolor=Highlight>Tune Strain - Shifting\u003C/color> on the target. During this state, if the affected target is hit by \u003Ccolor=Highlight>Tune Break\u003C/color>, their \u003Ccolor=Highlight>Tune Strain - Shifting\u003C/color> state is replaced with \u003Ccolor=Highlight>Tune Strain - Interfered\u003C/color>.\",\n    \"param\": []\n  },\n  \"100004\": {\n    \"name\": \"Tune Rupture - Interfered\",\n    \"desc\": \"A target enters this state when they are hit by \u003Ccolor=Highlight>Tune Break\u003C/color> under the \u003Ccolor=Highlight>Tune Rupture - Shifting\u003C/color> state. Resonators who can respond to \u003Ccolor=Highlight>Tune Rupture- Interfered\u003C/color> cause additional effects when attacking targets in this state. \u003Ccolor=Highlight>Tune Rupture- Interfered\u003C/color> lasts for 8s.\",\n    \"param\": []\n  },\n  \"100005\": {\n    \"name\": \"Tune Strain - Interfered\",\n    \"desc\": \"A target enters this state when they are hit by \u003Ccolor=Highlight>Tune Break\u003C/color> under the \u003Ccolor=Highlight>Tune Strain - Shifting\u003C/color> state. Resonators who can respond to \u003Ccolor=Highlight>Tune Strain - Interfered\u003C/color> cause additional effects when attacking targets in this state. \u003Ccolor=Highlight>Tune Strain - Interfered\u003C/color> lasts for 30s.\",\n    \"param\": []\n  },\n  \"120901\": {\n    \"name\": \"Baseline Mode\",\n    \"desc\": \"While in her default \u003Ccolor=Highlight>Baseline Mode\u003C/color>, Mornye gains \u003Ccolor=Highlight>Rest Mass Energy\u003C/color>.\",\n    \"param\": [\n      \"100\",\n      \"25\",\n      \"3\",\n      \"50%\",\n      \"30\",\n      \"8\",\n      \"3\",\n      \"100%\",\n      \"1%\",\n      \"0.25%\",\n      \"40%\",\n      \"30\",\n      \"3\"\n    ]\n  },\n  \"120902\": {\n    \"name\": \"Wide Field Observation Mode\",\n    \"desc\": \"\u003Ccolor=Highlight>Wide Field Observation Mode\u003C/color> lasts for {11}s.\\n- Upon entering \u003Ccolor=Highlight>Wide Field Observation Mode\u003C/color>, Mornye generates a \u003Ccolor=Highlight>Syntony Field\u003C/color>.\\n- While in \u003Ccolor=Highlight>Wide Field Observation Mode\u003C/color>, Mornye gains \u003Ccolor=Highlight>Relative Momentum\u003C/color>.\\n- If \u003Ccolor=Highlight>Relative Momentum\u003C/color> is below {0} when holding \u003Ccolor=Highlight>Normal Attack\u003C/color>, perform \u003Ccolor=Highlight>Basic Attack - Wide Field Observation Mode Stage 1 to 3\u003C/color> in sequence. If \u003Ccolor=Highlight>Relative Momentum\u003C/color> reaches {0} during this time, cast \u003Ccolor=Highlight>Heavy Attack - Inversion\u003C/color> instead.\\n- While moving, Mornye continuously consumes STA. STA cannot be recovered while in \u003Ccolor=Highlight>Wide Field Observation Mode\u003C/color>.\\n- When Dodging with directional input, Mornye starts to fly at speed, which lasts for up to 10s or until STA is depleted or until the \u003Ccolor=Highlight>Wide Field Observation Mode\u003C/color> ends.\\n- When Mornye is hit or launched into mid-air, {Cus:Ipt,Touch=tap PC=press Gamepad=press} Dodge to immediately recover from the attack, which is considered a successful Dodge. This effect can be triggered up to {12} times, which resets when \u003Ccolor=Highlight>Wide Field Observation Mode\u003C/color> ends.\\n- {Cus:Ipt,Touch=Tap PC=Press Gamepad=Press} Jump and Mornye will slowly descend. Before she lands, \u003Ccolor=Highlight>Basic Attack - Wide Field Observation Mode\u003C/color>, \u003Ccolor=Highlight>Resonance Skill - Distributed Array\u003C/color>, and \u003Ccolor=Highlight>Heavy Attack - Inversion\u003C/color> are unavailable. If Jump is {Cus:Ipt,Touch=tapped PC=pressed Gamepad=pressed} when Mornye runs out of STA, she will exit the \u003Ccolor=Highlight>Wide Field Observation Mode\u003C/color>. She will leave the \u003Ccolor=Highlight>Wide Field Observation Mode\u003C/color> also when she \u003Ccolor=Highlight>Dodges\u003C/color>, Jumps, or performs Mid-air Attacks.\\nAdditionally, performing environmental interactions, using Utilities, or switching to another Resonator ends \u003Ccolor=Highlight>Wide Field Observation Mode\u003C/color>. The state also ends when Mornye is no longer airborne.\",\n    \"param\": [\n      \"100\",\n      \"25\",\n      \"3\",\n      \"50%\",\n      \"30\",\n      \"8\",\n      \"3\",\n      \"100%\",\n      \"1%\",\n      \"0.25%\",\n      \"40%\",\n      \"30\",\n      \"3\"\n    ]\n  },\n  \"120903\": {\n    \"name\": \"Rest Mass Energy\",\n    \"desc\": \"Mornye can hold up to {0} points of \u003Ccolor=Highlight>Rest Mass Energy\u003C/color>.\\nWhile in \u003Ccolor=Highlight>Baseline Mode\u003C/color>, she gains \u003Ccolor=Highlight>Rest Mass Energy\u003C/color> when performing \u003Ccolor=Highlight>Basic Attack\u003C/color>, \u003Ccolor=Highlight>Heavy Attack\u003C/color>, or \u003Ccolor=Highlight>Dodge Counter\u003C/color>, or when \u003Ccolor=Highlight>Resonance Skill - Optimal Solution\u003C/color> hits a target.\",\n    \"param\": [\n      \"100\",\n      \"25\",\n      \"3\",\n      \"50%\",\n      \"30\",\n      \"8\",\n      \"3\",\n      \"100%\",\n      \"1%\",\n      \"0.25%\",\n      \"40%\",\n      \"30\",\n      \"3\"\n    ]\n  },\n  \"120904\": {\n    \"name\": \"Relative Momentum\",\n    \"desc\": \"Mornye can hold up to {0} points of \u003Ccolor=Highlight>Relative Momentum\u003C/color>.\\nWhile in \u003Ccolor=Highlight>Wide Field Observation Mode\u003C/color>, she gains \u003Ccolor=Highlight>Relative Momentum\u003C/color> when \u003Ccolor=Highlight>Basic Attack - Wide Field Observation Mode\u003C/color>, \u003Ccolor=Highlight>Dodge Counter - Wide Field Observation Mode\u003C/color>, or \u003Ccolor=Highlight>Resonance Skill - Distributed Array\u003C/color> hits the target.\\nMornye cannot gain \u003Ccolor=Highlight>Relative Momentum\u003C/color> during \u003Ccolor=Highlight>Heavy Attack - Inversion\u003C/color>.\",\n    \"param\": [\n      \"100\",\n      \"25\",\n      \"3\",\n      \"50%\",\n      \"30\",\n      \"8\",\n      \"3\",\n      \"100%\",\n      \"1%\",\n      \"0.25%\",\n      \"40%\",\n      \"30\",\n      \"3\"\n    ]\n  },\n  \"120905\": {\n    \"name\": \"Observation Marker\",\n    \"desc\": \"When a Resonator in the team deals \u003Ccolor=Highlight>Tune Break\u003C/color> DMG to a target inflicted with \u003Ccolor=Highlight>Observation Marker\u003C/color>, Mornye inflicts an \u003Ccolor=Highlight>Interfered Marker\u003C/color> on the target for {5}s.\",\n    \"param\": [\n      \"100\",\n      \"25\",\n      \"3\",\n      \"50%\",\n      \"30\",\n      \"8\",\n      \"3\",\n      \"100%\",\n      \"1%\",\n      \"0.25%\",\n      \"40%\",\n      \"30\",\n      \"3\"\n    ]\n  },\n  \"120906\": {\n    \"name\": \"Interfered Marker\",\n    \"desc\": \"Targets affected by \u003Ccolor=Highlight>Tune Rupture - Interfered\u003C/color> or \u003Ccolor=Highlight>Tune Strain - Interfered\u003C/color> take increased DMG from all nearby Resonators in the team. For every {8} of Mornye's Energy Regen exceeding {7}, their DMG is increased by {9}, up to {10}.\",\n    \"param\": [\n      \"100\",\n      \"25\",\n      \"3\",\n      \"50%\",\n      \"30\",\n      \"8\",\n      \"3\",\n      \"100%\",\n      \"1%\",\n      \"0.25%\",\n      \"40%\",\n      \"30\",\n      \"3\"\n    ]\n  },\n  \"120907\": {\n    \"name\": \"Syntony Field\",\n    \"desc\": \"- \u003Ccolor=Highlight>Syntony Field\u003C/color> lasts for {1}s.\\n- When the \u003Ccolor=Highlight>Syntony Field\u003C/color> is generated, deal \u003Ccolor=Fire>Fusion DMG\u003C/color>, considered Resonance Liberation DMG.\\n- Continuously restores HP for all nearby Resonators in the team within the \u003Ccolor=Highlight>Syntony Field\u003C/color>, triggered once every {2}s.\\n- Increases the \u003Ccolor=Highlight>Off-Tune Buildup Rate\u003C/color> of all nearby Resonators in the team within the \u003Ccolor=Highlight>Syntony Field\u003C/color> by {3}.\\n- Enhances the resistance to interruption of all nearby Resonators in the team within the \u003Ccolor=Highlight>Syntony Field\u003C/color>.\",\n    \"param\": [\n      \"100\",\n      \"25\",\n      \"3\",\n      \"50%\",\n      \"30\",\n      \"8\",\n      \"3\",\n      \"100%\",\n      \"1%\",\n      \"0.26%\",\n      \"39%\",\n      \"30\",\n      \"3\"\n    ]\n  },\n  \"120908\": {\n    \"name\": \"High Syntony Field\",\n    \"desc\": \"- \u003Ccolor=Highlight>High Syntony Field\u003C/color> lasts for {6}s. \\n- Increases the DEF of all nearby Resonators in the team within the \u003Ccolor=Highlight>High Syntony Field\u003C/color> by {8}.\\n- Inherits the \u003Ccolor=Highlight>Syntony Field\u003C/color>'s boost to resistance to interruption and \u003Ccolor=Highlight>Off-Tune Buildup Rate\u003C/color>.\\n- Inherits the \u003Ccolor=Highlight>Syntony Field\u003C/color>'s healing effect and increases the Healing Multiplier by {7}.\",\n    \"param\": [\n      \"100%\",\n      \"1%\",\n      \"0.5%\",\n      \"80%\",\n      \"1%\",\n      \"160%\",\n      \"25\",\n      \"40%\",\n      \"20%\"\n    ]\n  },\n  \"700004\": {\n    \"name\": \"Voidworm\",\n    \"desc\": \"An amalgamated horror that often emerges alongside Void Storms. During lulls between Storms, it primarily inhabits the highly concentrated Voidmatter environment of the Mawburrow Desert. The Voidmatter Regulators on its head serve as both its power source and its weakness.\",\n    \"param\": []\n  },\n  \"700005\": {\n    \"name\": \"Infirmary\",\n    \"desc\": \"Officially the \\\"Resonator Nursing Unit,\\\" the infirmary is a clinical-research hybrid facility overseen by Rabelle College.\\nManaged by Academy physician Luuk Herssen, it utilizes Frequency Therapeutics to provide comprehensive healthcare for the students and faculty of Startorch Academy.\",\n    \"param\": []\n  },\n  \"700006\": {\n    \"name\": \"Rabelle Cassette\",\n    \"desc\": \"An identity authentication device issued by the Spacetrek Collective, serving as mandatory safety gear for navigating Lahai-Roi.\\nAll first-year students must complete the Cassette's burning and registration under faculty supervision at the Research Institute before venturing beyond the Academy's protected zones.\",\n    \"param\": []\n  },\n  \"700007\": {\n    \"name\": \"Frequency Cassette Recorder\",\n    \"desc\": \"A standardized Terminal for the Spacetrek Collective members, designed to hold the Rabelle Cassette.\\nIts casing is constructed from a special composite that mimics the Exostrider's engineering, granting partial resistance to Void Storms.\",\n    \"param\": []\n  },\n  \"700008\": {\n    \"name\": \"Exostrider\",\n    \"desc\": \"A colossal mech of alien origin, now dormant in the Roya Frostlands. Startorch Academy was founded to train Synchronists capable of establishing Augmented Resonance with it.\\nIn the Roya's Trine Myth, it is revered as Baldur, the earthly incarnation of the sun deity Sol. Legend claims it once held up the earth's collapsing crust with its greatsword, saving the Roya from annihilation. Predictions foretell it will awaken from its slumber to confront the ruinous Hvedrungr in a final, apocalyptic battle.\",\n    \"param\": []\n  },\n  \"700009\": {\n    \"name\": \"Synchronist\",\n    \"desc\": \"Candidates selected from across Solaris who can link their consciousness to the giant Exostrider mech via an external mechanical interface.\\nThese Synchronists can achieve a degree of control over the Exostrider through Augmented Resonance. To identify and train these rare pilots, Startorch Academy established Rabelle College.\",\n    \"param\": []\n  },\n  \"700010\": {\n    \"name\": \"Reactor Drive\",\n    \"desc\": \"The Exostrider's power core and Lahai-Roi's underground \\\"sun.\\\"\\nRoyan records say this energy entity was removed from the Exostrider and placed underground to sustain the haven. However, monitoring data confirms a gradual but steady decline in its energy output. Both the Roya and the Spacetrek Collective are now formulating emergency contingencies in response.\",\n    \"param\": []\n  },\n  \"700011\": {\n    \"name\": \"Starward Riseway\",\n    \"desc\": \"A colossal vertical transport system built along the Exostrider's greatsword, connecting Lahai-Roi and the Roya Frostlands.\\nIts structure resembles a spine piercing both heaven and earth. Powered by orbital-acceleration technology, it connects the deep cavern to the surface and serves as Lahai-Roi's most important transportation hubs.\",\n    \"param\": []\n  },\n  \"700012\": {\n    \"name\": \"Greatsword\",\n    \"desc\": \"The Exostrider's remaining weapon. The blade is buried deep within Sundermere, while its hilt supports the very ceiling of the cavern, forming a structural pillar through the heart of Lahai-Roi.\\nIn the Roya's Trine Myth, it is predicted that Baldur will draw this sword in the final battle against the ruinous entity Hvedrungr.\",\n    \"param\": []\n  },\n  \"700013\": {\n    \"name\": \"Hyvatia\",\n    \"desc\": \"A monitoring instrument installed on the surface of Sundermere by the Spacetrek Collective to oversee and maintain the Reactor Drive.\\nAt its core is a replica of the Exostrider's calibration module, enabling a dedicated data link with the Drive to transmit real-time correction parameters. Hyvatia plays a vital role in ensuring the Reactor Drive's continuous and stable operation.\",\n    \"param\": []\n  },\n  \"700014\": {\n    \"name\": \"Voidmatter Barrier\",\n    \"desc\": \"Specialized protective infrastructure developed by Startorch Academy, using reverse-engineered materials inspired by the Exostrider's surface fibers and coatings. It provides a degree of resistance against Voidmatter contamination.\\nIt is now deployed as a standard protective measure in Spacetrek Collective camps, research outposts, and transit hubs. The largest installation is the Antivoid Canopy surrounding Startorch Academy.\",\n    \"param\": []\n  },\n  \"700015\": {\n    \"name\": \"Roya Tribe\",\n    \"desc\": \"The indigenous inhabitants of Lahai-Roi. They have lived in the underground cavern long before the Spacetrek Collective's arrival. They now maintain a cooperative relationship with it.\\nBy observing the Reactor Drive's operational cycles, the Roya devised their own calendar. They guide the growth and migration of the Exoswarm, a sacred duty they regard as their tribe's calling.\",\n    \"param\": []\n  },\n  \"700016\": {\n    \"name\": \"New Solar Ceremony\",\n    \"desc\": \"A Spacetrek Collective project decades in the making to replace the Reactor Drive in the sky with Helios, an artificial sun engineered by the Research Institute.\\nIts ultimate goal is to retrieve the Drive as a power source to awaken the Exostrider slumbering in the frostlands, all while keeping Lahai-Roi's ecosystem stable.\",\n    \"param\": []\n  },\n  \"700017\": {\n    \"name\": \"Helios\",\n    \"desc\": \"The artificial sun crafted by the Spacetrek Collective: Research Institute to replace the Reactor Drive in the New Solar Ceremony.\\nFor successful operation, it requires environmental data from Hyvatia and raw observational data on the Reactor Drive provided by the Heliogyre.\",\n    \"param\": []\n  },\n  \"700018\": {\n    \"name\": \"Solisylum\",\n    \"desc\": \"The sacred ground of the Roya and the dwelling of the Heliodic Six. It safeguards Exostrider parts and serves as the central archive for all Royan records.\\nWith each operational cycle of the Reactor Drive, the Solisylum calculates its stability, tracks the birth and growth of the Exoswarm, and monitors their eventual return to the Exostrider.\",\n    \"param\": []\n  },\n  \"700019\": {\n    \"name\": \"Heliogyre\",\n    \"desc\": \"An artifact used exclusively by the Heliodic Six to observe the Reactor Drive.\\nDuring the New Solar Ceremony, it provides Helios with raw observational data on the Reactor Drive.\",\n    \"param\": []\n  },\n  \"700020\": {\n    \"name\": \"The Heliodic Six\",\n    \"desc\": \"Roya elders such as the Eye, the Binder, and the Shaper. Each pair in the Six is entrusted with the roles of observation, archival, and extrapolation.\\nThey reside within the Solisylum, tracing the Reactor Drive's trajectories and forecasting Void Storms.\",\n    \"param\": []\n  },\n  \"700021\": {\n    \"name\": \"Bjartr Woods\",\n    \"desc\": \"The forest where the Soliskin dwell. Bathed in the light of the Reactor Drive, the woods remain untouched by the ravages of Void Storms.\",\n    \"param\": []\n  },\n  \"700022\": {\n    \"name\": \"Exoswarm\",\n    \"desc\": \"Biomechanical creatures formed from the Exostrider's cellular remnants. By mimicking herds and other lifeforms, they helped rebuild Lahai-Roi's ecosystem.\",\n    \"param\": []\n  },\n  \"700023\": {\n    \"name\": \"Exoswarm Material\",\n    \"desc\": \"Materials harvested from Exoswarm. Though still essentially parts of the Exostrider, they are widely utilized in engineering Lahai-Roi's various constructs.\",\n    \"param\": []\n  },\n  \"700024\": {\n    \"name\": \"Shepherd\",\n    \"desc\": \"Roya chosen by the Soliskin for their pure nature become Shepherds. Their duty is to guide and care for the Soliskin. They lead the Soliskin to the best sunlit areas of Bjartr Woods and keep them safe.\",\n    \"param\": []\n  },\n  \"700025\": {\n    \"name\": \"Solsworn\",\n    \"desc\": \"Individuals gifted in calendrical calculation and a degree of resonance with the Exostrider and Soliskin are permitted into the Solisylum. There, they serve the Heliodic Six as aides and the tribe as healers and teachers, all while being groomed as the Six's eventual successors.\",\n    \"param\": []\n  },\n  \"700026\": {\n    \"name\": \"Soliskin\",\n    \"desc\": \"A type of Exoswarm originating from the Exostrider's neural structures. They are believed to embody fragments of its consciousness.\",\n    \"param\": []\n  },\n  \"700027\": {\n    \"name\": \"Solistrees\",\n    \"desc\": \"Towering constructs widespread in Bjartr Woods, forming a vast, floating forest. Their roots permeate Lahai-Roi, relaying information directly to the Heliogyre.\",\n    \"param\": []\n  },\n  \"700028\": {\n    \"name\": \"Rite of Return\",\n    \"desc\": \"A ceremony held by the Roya for the Soliskin. During the rite, the Soliskin transform into ethereal energy forms. Guided by Shepherds, they enter the Solistrees and disperse into luminescence as they rise.\\nThe Roya believe this marks the Soliskin's return to the Exostrider.\",\n    \"param\": []\n  },\n  \"150901\": {\n    \"name\": \"Optical Sampling Stage\",\n    \"desc\": \"Lynae is in \u003Ccolor=Highlight>Optical Sampling Stage\u003C/color> by default. In this state, \u003Ccolor=Highlight>Overflow\u003C/color> recovers during Basic Attack,  Lynae-Style Palettes, Mid-air Attack, and Dodge Counter, or when Intro Skill is cast.\",\n    \"param\": []\n  },\n  \"150902\": {\n    \"name\": \"Kaleidoscopic Parade\",\n    \"desc\": \"Casting \u003Ccolor=Highlight>Basic Attack - Spark Collision\u003C/color> sends Lynae into \u003Ccolor=Highlight>Kaleidoscopic Parade\u003C/color>. In this state, Lynae moves faster and continuously recovers \u003Ccolor=Highlight>Lumiflow\u003C/color> when she moves on the ground or casts \u003Ccolor=Highlight>Kaleidoscopic Parade - Basic Attack\u003C/color>, \u003Ccolor=Highlight>Kaleidoscopic Parade - Ground Heavy Attack\u003C/color>, \u003Ccolor=Highlight>Kaleidoscopic Parade - Mid-air Heavy Attack\u003C/color>, \u003Ccolor=Highlight>Kaleidoscopic Parade - Mid-air Attack\u003C/color>, \u003Ccolor=Highlight>Additive Color\u003C/color>, Dodge, Intro Skill, or \u003Ccolor=Highlight>Basic Attack - To a Vivid Tomorrow!\u003C/color>.\",\n    \"param\": []\n  },\n  \"150903\": {\n    \"name\": \"Photochromic Flux\",\n    \"desc\": \"Inflict \u003Ccolor=Highlight>Photochromic Flux\u003C/color> when hitting a target with \u003Ccolor=Highlight>Basic Attack - Polychrome Leap\u003C/color>, \u003Ccolor=Highlight>Basic Attack - Iridescent Splash\u003C/color>, \u003Ccolor=Highlight>Basic Attack - Visual Impact\u003C/color> and \u003Ccolor=Highlight>Intro Skill - Time to Show Some Colors!\u003C/color>. \u003Ccolor=Highlight>Photochromic Flux\u003C/color> inflicts \u003Ccolor=Highlight>Tune Rupture - Shifting\u003C/color>/\u003Ccolor=Highlight>Tune Strain - Shifting\u003C/color> on targets for 25s when Lynae is in \u003Ccolor=Highlight>Resonance Mode - Tune Rupture\u003C/color>/\u003Ccolor=Highlight>Resonance Mode - Tune Strain\u003C/color>.\",\n    \"param\": []\n  },\n  \"150904\": {\n    \"name\": \"Spray Paint\",\n    \"desc\": \"When Inherent Skill \u003Ccolor=Highlight>Colors Never Fade!\u003C/color> is activated, Lynae leaves \u003Ccolor=Highlight>Spray Paint\u003C/color> on the ground after casting \u003Ccolor=Highlight>Basic Attack - Visual Impact\u003C/color>, which continuously inflicts \u003Ccolor=Highlight>Photochromic Flux\u003C/color> on targets within the \u003Ccolor=Highlight>Spray Paint\u003C/color> area.\",\n    \"param\": []\n  },\n  \"150905\": {\n    \"name\": \"Overflow\",\n    \"desc\": \"Max 120 points.\\nWhile in \u003Ccolor=Highlight>Optical Sampling Stage\u003C/color>, \u003Ccolor=Highlight>Overflow\u003C/color> recovers during Basic Attack, Lynae-Style Palettes, Mid-air Attack, and Dodge Counter, or when Intro Skill is cast.\\nWhen \u003Ccolor=Highlight>Overflow\u003C/color> is full, \u003Ccolor=Highlight>Basic Attack - Spark Collision\u003C/color> becomes available.\\nCasting \u003Ccolor=Highlight>Basic Attack - Spark Collision\u003C/color> removes all \u003Ccolor=Highlight>Overflow\u003C/color>.\",\n    \"param\": []\n  },\n  \"150906\": {\n    \"name\": \"Lumiflow\",\n    \"desc\": \"Max 120 points.\\nDuring \u003Ccolor=Highlight>Kaleidoscopic Parade\u003C/color>:\\n- Restore 20% of \u003Ccolor=Highlight>Lumiflow\u003C/color> per second when Lynae is moving on the ground/climbing, or performs a successful Dodge on the ground, or within a certain time during \u003Ccolor=Highlight>Kaleidoscopic Parade - Basic Attack\u003C/color>, \u003Ccolor=Highlight>Kaleidoscopic Parade - Ground Heavy Attack\u003C/color>, \u003Ccolor=Highlight>Kaleidoscopic Parade - Mid-air Heavy Attack\u003C/color>, \u003Ccolor=Highlight>Kaleidoscopic Parade - Dodge Counter\u003C/color>, \u003Ccolor=Highlight>Additive Color\u003C/color>, ground Dodge, Intro Skill, or \u003Ccolor=Highlight>Basic Attack - To a Vivid Tomorrow!\u003C/color>.\\n- \u003Ccolor=Highlight>Lumiflow\u003C/color> starts to deplete by 20% per second while Lynae is staying still on the ground/climbing/swimming or off the field, or after a certain time following the use of the skills listed above.\\n- \u003Ccolor=Highlight>Lumiflow\u003C/color> does not change while Lynae is not in any of the states described above.\\nExiting \u003Ccolor=Highlight>Kaleidoscopic Parade\u003C/color> removes all \u003Ccolor=Highlight>Lumiflow\u003C/color>.\\nWith 120 points of \u003Ccolor=Highlight>\u003Cte href=150906>Lumiflow\u003C/te>\u003C/color>, Lynae's roller skating speed further increases. \u003Ccolor=Highlight>Speed Skating\u003C/color> consumes STA over time.\",\n    \"param\": []\n  },\n  \"150907\": {\n    \"name\": \"True Color\",\n    \"desc\": \"Max 3 points.\\nWhile in combat, \u003Ccolor=Highlight>Polychrome Leap\u003C/color> grants 1 point of \u003Ccolor=Highlight>True Color\u003C/color> each time it's cast. With 3 points of \u003Ccolor=Highlight>True Color\u003C/color>, \u003Ccolor=Highlight>Basic Attack - Iridescent Splash\u003C/color> and \u003Ccolor=Highlight>Basic Attack - Visual Impact\u003C/color> become available.\\nExiting \u003Ccolor=Highlight>Kaleidoscopic Parade\u003C/color> removes all \u003Ccolor=Highlight>True Color\u003C/color>.\",\n    \"param\": []\n  },\n  \"700029\": {\n    \"name\": \"Void Storm\",\n    \"desc\": \"A Waveworn Phenomenon unique to Lahai-Roi, erupting when Voidmatter concentrations reach a critical threshold. It indiscriminately dissolves all matter and existence within its range, causing widespread devastation. Before it strikes, an atmospheric light known as the Shimmer typically appears, serving as an early warning.\",\n    \"param\": []\n  },\n  \"700030\": {\n    \"name\": \"Lahai-Roi\",\n    \"desc\": \"A warm, humid underground haven deep beneath the Roya Frostlands. Following an ancient polar shift that made Lahai-Roi Solaris's new pole, the changing climate drove the surface-dwelling Roya to migrate below. Long isolated, it became a refuge for extinct prehistoric life, which has since evolved into a unique and remarkably independent ecosystem.\",\n    \"param\": []\n  },\n  \"700031\": {\n    \"name\": \"Startorch Academy\",\n    \"desc\": \"Officially titled the Spacetrek Collective: Startorch Academy, this borderless academic metropolis trains Synchronists and spearheads research into the giant mech known as the Exostrider. Its name embodies its core ethos: \\\"to carry the flame of inquiry and ignite the torch of civilization.\\\" Here, seekers of knowledge from across the world gather, knowledge flows freely, and cultures meet in harmony.\",\n    \"param\": []\n  },\n  \"750035\": {\n    \"name\": \"Etheric Sea\",\n    \"desc\": \"A planet-wide phenomenon born from an anomalous Lament event. It now blankets Solaris's sky. Research suggests it is composed of extremely high-density Remnant Energy. Since its appearance, all of Solaris's space exploration has been brought to a complete standstill.\",\n    \"param\": []\n  },\n  \"750036\": {\n    \"name\": \"Stridergate\",\n    \"desc\": \"The entry point formed when the Exostrider and the Threnodian Aleph-1 entered Solaris. Researchers in Lahai-Roi widely believe it leads to outer space. The overlying Soliskin root network holds Aleph-1's power at bay, the \\\"sealed doors\\\" of the Stridergate.\",\n    \"param\": []\n  },\n  \"750037\": {\n    \"name\": \"Fluctuating Voidmatter Levels\",\n    \"desc\": \"A phenomenon unique to the surface of the Roya Frostlands. Scholars theorize that this anomaly emerged when the Threnodian's power there attempted to devour the Exostrider, triggering abnormal Voidmatter transformations. Affected objects enter a state of unstable \\\"existence,\\\" becoming impossible to observe directly.\",\n    \"param\": []\n  },\n  \"750038\": {\n    \"name\": \"Module Adapter\",\n    \"desc\": \"A specialized device developed by the Spacetrek Collective for research operations in the Roya Frostlands. It forces entities with fluctuating Voidmatter levels back into the observable state for practical use. In areas with stable signal coverage, the device can be deployed directly to the user's location.\",\n    \"param\": []\n  },\n  \"750039\": {\n    \"name\": \"SkyArk Space Station\",\n    \"desc\": \"A Court of Savantae space station launched into near-Solaris orbit before the Etheric Sea fully enveloped the planet. Its primary mission was the study of Etheric Sea Droplets, research intended to pave the way for further space exploration.\",\n    \"param\": []\n  },\n  \"750040\": {\n    \"name\": \"Voidspace\",\n    \"desc\": \"A high-dimensional domain embedded deep within high-density Voidmatter, existing \\\"inside\\\" Aleph-1. The fundamental laws of time and space descend into total chaos here. Any living entity entering this domain suffers a rapid loss of frequency, eventually leading to the total dissolution of their existence.\",\n    \"param\": []\n  },\n  \"750041\": {\n    \"name\": \"Snowfluff Seal\",\n    \"desc\": \"A species of seal native to the Roya Frostlands, named for its snowball-like, round, white body. Docile in nature, Snowfluff Seals show little reaction to people or their surroundings, spending most of their time either eating or lying still. Only when facing extreme danger will they rear up and bare their fangs as a deterrent. If intimidation fails, they will promptly retreat to a safer area.\",\n    \"param\": []\n  },\n  \"750042\": {\n    \"name\": \"Ichor\",\n    \"desc\": \"A special pharmaceutical substance developed for extremely rare diseases. However, its severe side effects make it intolerable for most, keeping it under ongoing research and validation. In its natural form, Ichor is a volatile golden liquid that radiates intense heat at room temperature. In rare cases, it can be controlled and stabilized into a solid form.\",\n    \"param\": []\n  },\n  \"750043\": {\n    \"name\": \"Novialle Regenerative Group\",\n    \"desc\": \"A pharmaceutical corporation based in the New Federation. Its core technology originates from the development of Ichor, a groundbreaking medical advancement shadowed by perpetual controversy.\",\n    \"param\": []\n  },\n  \"121001\": {\n    \"name\": \"Instant Response\",\n    \"desc\": \"While in \u003Ccolor=Highlight>Instant Response\u003C/color>, \u003Ccolor=Highlight>Heavy Attack - Aemeath\u003C/color> and \u003Ccolor=Highlight>Heavy Attack - Mech\u003C/color> take less time to charge up fully.\\n- When in \u003Ccolor=Highlight>Instant Response\u003C/color> and \u003Ccolor=Highlight>Heavenfall Edict: Unbound\u003C/color> at the same time, casting \u003Ccolor=Highlight>Heavy Attack - Aemeath Charged II\u003C/color> or \u003Ccolor=Highlight>Heavy Attack - Mech Charged II\u003C/color> restores {0} points of \u003Ccolor=Highlight>Synchronization Rate\u003C/color>.\\n- If Inherent Skill \u003Ccolor=Highlight>Before All Sounds\u003C/color> is activated, while in \u003Ccolor=Highlight>Instant Response\u003C/color>, \u003Ccolor=Highlight>Heavy Attack - Aemeath\u003C/color> and \u003Ccolor=Highlight>Heavy Attack - Mech\u003C/color> gain {2} DMG Amplification.\",\n    \"param\": [\n      \"200\",\n      \"100\",\n      \"200%\"\n    ]\n  },\n  \"121002\": {\n    \"name\": \"Stardust Resonance\",\n    \"desc\": \"\u003Ccolor=Highlight>Stardust Resonance\u003C/color> enhances the effect of Resonance Skill \u003Ccolor=Highlight>Seraphic Duet\u003C/color> based on Aemeath's current \u003Ccolor=Highlight>Resonance Mode\u003C/color>:\\n- While in \u003Ccolor=Highlight>Resonance Mode - Tune Rupture\u003C/color>, now up to {0} instances of \u003Ccolor=Highlight>Tune Rupture DMG\u003C/color> can be triggered during Resonance Skill \u003Ccolor=Highlight>Seraphic Duet\u003C/color>.\\n- While in \u003Ccolor=Highlight>Resonance Mode - Fusion Burst\u003C/color>, the DMG Multiplier of \u003Ccolor=Highlight>Fusion Burst\u003C/color> that is actively triggered during Resonance Skill \u003Ccolor=Highlight>Seraphic Duet\u003C/color> against the main target of \u003Ccolor=Highlight>Fusion Burst\u003C/color> is increased by {1}. This DMG Multiplier increase effect is stackable with that provided by \u003Ccolor=Highlight>Fusion Trail\u003C/color>.\",\n    \"param\": [\n      \"10\",\n      \"200%\"\n    ]\n  },\n  \"121003\": {\n    \"name\": \"Heavenfall Edict: Unbound\",\n    \"desc\": \"\u003Ccolor=Highlight>Heavenfall Edict: Overdrive\u003C/color> is replaced with \u003Ccolor=Highlight>Heavenfall Edict: Finale\u003C/color>.\\nWhen in \u003Ccolor=Highlight>Heavenfall Edict: Unbound\u003C/color> and \u003Ccolor=Highlight>Resonance Rate\u003C/color> reaches the limit, enter \u003Ccolor=Highlight>Instant Response\u003C/color>. \u003Ccolor=Highlight>Instant Response\u003C/color> is removed when the \u003Ccolor=Highlight>Heavenfall Edict: Unbound\u003C/color> state ends.\",\n    \"param\": []\n  },\n  \"121004\": {\n    \"name\": \"Synchronization Rate\",\n    \"desc\": \"\u003Ccolor=Highlight>Synchronization Rate\u003C/color> is capped at {0} points.\\n- Dealing damage with \u003Ccolor=Highlight>Basic Attack - Aemeath\u003C/color>, \u003Ccolor=Highlight>Mid-air Attack - Aemeath\u003C/color>, \u003Ccolor=Highlight>Dodge Counter - Aemeath\u003C/color>, \u003Ccolor=Highlight>Basic Attack - Mech\u003C/color>, \u003Ccolor=Highlight>Mid-air Attack - Mech\u003C/color>, \u003Ccolor=Highlight>Dodge Counter - Mech\u003C/color>, Resonance Skill \u003Ccolor=Highlight>Sync Strike: Armament Merge\u003C/color>, and Resonance Skill \u003Ccolor=Highlight>Sync Strike: Call of Dawn\u003C/color> recovers \u003Ccolor=Highlight>Synchronization Rate\u003C/color>.\\n- Casting Intro Skill \u003Ccolor=Highlight>Songs Across the Universe\u003C/color> or \u003Ccolor=Highlight>Debut of Meteoric Radiance\u003C/color> recovers {1} points of \u003Ccolor=Highlight>Synchronization Rate\u003C/color>.\\n- Casting Resonance Liberation \u003Ccolor=Highlight>Heavenfall Edict: Overdrive\u003C/color> recovers {2} points of \u003Ccolor=Highlight>Synchronization Rate\u003C/color>.\\n- When in \u003Ccolor=Highlight>Instant Response\u003C/color> and \u003Ccolor=Highlight>Heavenfall Edict: Unbound\u003C/color> at the same time, casting \u003Ccolor=Highlight>Heavy Attack - Aemeath Charged II\u003C/color> or \u003Ccolor=Highlight>Heavy Attack - Mech Charged II\u003C/color> recovers {3} points of \u003Ccolor=Highlight>Synchronization Rate\u003C/color>.\",\n    \"param\": [\n      \"200\",\n      \"40\",\n      \"30\",\n      \"200\",\n      \"100\"\n    ]\n  },\n  \"121005\": {\n    \"name\": \"Resonance Rate\",\n    \"desc\": \"\u003Ccolor=Highlight>Resonance Rate\u003C/color> is capped at {0} points.\\n- Casting Resonance Skill \u003Ccolor=Highlight>Seraphic Duet\u003C/color> recovers {1} point of \u003Ccolor=Highlight>Resonance Rate\u003C/color>.\\n- Casting Resonance Liberation \u003Ccolor=Highlight>Heavenfall Edict: Overdrive\u003C/color> recovers {2} point of \u003Ccolor=Highlight>Resonance Rate\u003C/color>.\\n- When in \u003Ccolor=Highlight>Starlume Acceleration\u003C/color>, casting Resonance Liberation \u003Ccolor=Highlight>Heavenfall Edict: Overdrive\u003C/color> additionally recovers {3} point of \u003Ccolor=Highlight>Resonance Rate\u003C/color>.\",\n    \"param\": [\n      \"4\",\n      \"1\",\n      \"1\",\n      \"1\"\n    ]\n  },\n  \"121006\": {\n    \"name\": \"Starlume Acceleration\",\n    \"desc\": \"When in \u003Ccolor=Highlight>Starlume Acceleration\u003C/color>, casting Resonance Liberation \u003Ccolor=Highlight>Heavenfall Edict: Overdrive\u003C/color> additionally recovers \u003Ccolor=Highlight>Resonance Rate\u003C/color>.\",\n    \"param\": []\n  },\n  \"121007\": {\n    \"name\": \"Seraphic Duet\",\n    \"desc\": \"Includes \u003Ccolor=Highlight>Seraphic Duet: Overture\u003C/color> and \u003Ccolor=Highlight>Seraphic Duet: Encore\u003C/color>.\",\n    \"param\": []\n  },\n  \"121008\": {\n    \"name\": \"Sync Strike\",\n    \"desc\": \"Includes \u003Ccolor=Highlight>Sync Strike: Armament Merge\u003C/color> and \u003Ccolor=Highlight>Sync Strike: Call of Dawn\u003C/color>.\",\n    \"param\": []\n  },\n  \"121009\": {\n    \"name\": \"Starflux\",\n    \"desc\": \"\u003Ccolor=Highlight>Starflux\u003C/color> is capped at {0} points.\\n\u003Ccolor=Highlight>Starflux\u003C/color> recovers naturally over time.\",\n    \"param\": [\n      \"600\"\n    ]\n  },\n  \"121012\": {\n    \"name\": \"Rupturous Trail\",\n    \"desc\": \"- When in \u003Ccolor=Highlight>Resonance Mode - Tune Rupture\u003C/color>, Resonance Skill \u003Ccolor=Highlight>Seraphic Duet\u003C/color> removes \u003Ccolor=Highlight>Rupturous Trail\u003C/color> stacks on nearby targets and additionally deals {2} instances of \u003Ccolor=Highlight>Tune Rupture DMG\u003C/color>, each time to a random target within range. For each stack of \u003Ccolor=Highlight>Rupturous Trail\u003C/color> removed from a target, the DMG Multiplier of Tune Rupture triggered by \u003Ccolor=Highlight>Seraphic Duet\u003C/color> against the target is increased by {0}. This effect lasts for {1}s. The target's \u003Ccolor=Highlight>Off-Tune Level\u003C/color> does not affect the triggering of these instances of Tune Rupture DMG.\",\n    \"param\": [\n      \"4%\",\n      \"1\",\n      \"5\"\n    ]\n  },\n  \"121013\": {\n    \"name\": \"Fusion Trail\",\n    \"desc\": \"- When in \u003Ccolor=Highlight>Resonance Mode - Fusion Burst\u003C/color>, Resonance Skill \u003Ccolor=Highlight>Seraphic Duet\u003C/color> removes the \u003Ccolor=Highlight>Fusion Trail\u003C/color> stacks on targets if they are inflicted with \u003Ccolor=Highlight>Fusion Trail\u003C/color>, and trigger the \u003Ccolor=Highlight>Fusion Trail\u003C/color> on the target based on its max stack limit without removing its stacks. Each stack of \u003Ccolor=Highlight>Fusion Trail\u003C/color> removed from the target increases the DMG Multiplier of \u003Ccolor=Highlight>Fusion Trail\u003C/color> on the main target by {0}.\",\n    \"param\": [\n      \"10%\"\n    ]\n  },\n  \"151001\": {\n    \"name\": \"Endnotes on the Endgame\",\n    \"desc\": \"Casting any form of Resonance Skill \u003Ccolor=Highlight>Aureole of Execution\u003C/color> grants \u003CSapTag=0>{0}\u003C/SapTag> {Cus:Sap,S=stack P=stacks SapTag=0} of Endnotes on the Endgame, which increases the DMG Multiplier of Resonance Liberation \u003Ccolor=Highlight>Rewritten in Winter's Margins\u003C/color> by {2}, stacking up to {1} times. Casting Resonance Liberation \u003Ccolor=Highlight>Rewritten in Winter's Margins\u003C/color> or switching to another Resonator removes all stacks.\",\n    \"param\": [\n      \"1\",\n      \"3\",\n      \"25%\"\n    ]\n  },\n  \"151002\": {\n    \"name\": \"Ichor Flow\",\n    \"desc\": \"Max {0} points.\\nNormal Attacks, Resonance Skill \u003Ccolor=Highlight>Golden Reflux\u003C/color>, Resonance Skill \u003Ccolor=Highlight>Aureole of Execution\u003C/color>, \u003Ccolor=Highlight>Basic Attack - Golden Impale\u003C/color>, and \u003Ccolor=Highlight>Mid-air Attack - Gavel of Earthshaker\u003C/color> restores Ichor Flow on hit.\\nCasting Intro Skill \u003Ccolor=Highlight>Before Injection of Dawn\u003C/color> restores {1} points of Ichor Flow.\",\n    \"param\": [\n      \"300\",\n      \"100\"\n    ]\n  },\n  \"151003\": {\n    \"name\": \"Dawnlit Keep\",\n    \"desc\": \"Max {0} stack. When taking damage from the enemies, consume \u003CSapTag=1>{1}\u003C/SapTag> {Cus:Sap,S=stack P=stacks SapTag=1} to reduce the DMG taken by {2} and gain immunity to interruptions for {3}s. This effect can be triggered {4} time per second.\",\n    \"param\": [\n      \"1\",\n      \"1\",\n      \"60%\",\n      \"1\",\n      \"1\"\n    ]\n  },\n  \"151004\": {\n    \"name\": \"Ichor Blade\",\n    \"desc\": \"Deal fixed \u003Ccolor=Light>Spectro DMG\u003C/color>, considered Basic Attack DMG that is not affected by any DMG Bonus.\\nOnly one \u003Ccolor=Highlight>Ichor Blade\u003C/color> can exist at a time. It cannot trigger \u003Ccolor=Highlight>Counterattack\u003C/color>.\\n\u003Ccolor=Highlight>Ichor Blade\u003C/color> cannot be launched without a nearby target.\\n\u003Ccolor=Highlight>Ichor Blade\u003C/color> disappears when Luuk Herssen casts other skills that deal damage or leaves the field.\",\n    \"param\": []\n  },\n  \"151005\": {\n    \"name\": \"Ichor Deposit\",\n    \"desc\": \"\u003Ccolor=Highlight>Ichor Deposit\u003C/color> detonates automatically after {0}s, dealing \u003Ccolor=Light>Spectro DMG\u003C/color>, considered Basic Attack DMG.\",\n    \"param\": [\n      \"5\"\n    ]\n  },\n  \"141201\": {\n    \"name\": \"Rune\",\n    \"desc\": \"Sigrika holds up to \u003Ccolor=Highlight>\u003CSapTag=0>{0}\u003C/SapTag> {Cus:Sap,S=Rune P=Runes SapTag=0}\u003C/color>. Without \u003Ccolor=Highlight>Full Stop\u003C/color>, Sigrika can only hold up to \u003Ccolor=Highlight>\u003CSapTag=1>{1}\u003C/SapTag> {Cus:Sap,S=Rune P=Runes SapTag=1}\u003C/color>. When Sigrika gains a new \u003Ccolor=Highlight>Rune\u003C/color> at max capacity, the existing \u003Ccolor=Highlight>Runes\u003C/color> shift one slot to the left, removing the leftmost \u003Ccolor=Highlight>Rune\u003C/color>. With at least \u003CSapTag=2>{2}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=2} of \u003Ccolor=Highlight>Full Stop\u003C/color>, Sigrika can hold \u003CSapTag=3>{3}\u003C/SapTag> additional {Cus:Sap,S=Rune P=Runes SapTag=3}.\\nHitting a target directly with \u003Ccolor=Highlight>Basic Attack - Elucidated\u003C/color> or \u003Ccolor=Highlight>Dodge Counter - Decipher\u003C/color> in the duration of the moves grants one \u003Ccolor=Highlight>Rune: Trust\u003C/color>.\\nHitting a target directly with \u003Ccolor=Highlight>Resonance Skill - BIG BOOMY BOOM!\u003C/color> or \u003Ccolor=Highlight>Resonance Skill - Soliskin to the Aid\u003C/color> in the duration of the moves grants one \u003Ccolor=Highlight>Rune: Answer\u003C/color>.\",\n    \"param\": [\n      \"4\",\n      \"2\",\n      \"50\",\n      \"2\"\n    ]\n  },\n  \"141202\": {\n    \"name\": \"Full Stop\",\n    \"desc\": \"After casting \u003Ccolor=Highlight>Heavy Attack - Schemata of Runes\u003C/color>, gain {0} points of \u003Ccolor=Highlight>Full Stop\u003C/color>, up to 100 points.\",\n    \"param\": [\n      \"50\"\n    ]\n  },\n  \"141203\": {\n    \"name\": \"Innate Gift?\",\n    \"desc\": \"Sigrika can hold up to \u003CSapTag=0>{0}\u003C/SapTag> {Cus:Sap,S=stack P=stacks SapTag=0} of \u003Ccolor=Highlight>Innate Gift?\u003C/color>. Each stack grants \u003Ccolor=Highlight>Runic Outburst\u003C/color>, \u003Ccolor=Highlight>Runic Chain Whip\u003C/color>, \u003Ccolor=Highlight>Runic Soliskin\u003C/color> and \u003Ccolor=Highlight>Forte Circuit - Learn My True Name\u003C/color> {1} DMG Amplification.\\nThis effect ends after Sigrika casts \u003Ccolor=Highlight>Forte Circuit - Learn My True Name\u003C/color> or is switched off the field.\",\n    \"param\": [\n      \"2\",\n      \"30%\"\n    ]\n  },\n  \"141204\": {\n    \"name\": \"Divergent\",\n    \"desc\": \"The next time Sigrika obtains a \u003Ccolor=Highlight>Rune\u003C/color>, she additionally obtains a \u003Ccolor=Highlight>Rune\u003C/color> of the opposite type and removes \u003Ccolor=Highlight>Divergent\u003C/color>.\\nWhen Sigrika holds \u003Ccolor=Highlight>Divergent\u003C/color> and \u003Ccolor=Highlight>Convergent\u003C/color> at the same time, \u003Ccolor=Highlight>Convergent\u003C/color> takes priority.\\nWhen Sigrika holds \u003CSapTag=0>{0}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=0} of \u003Ccolor=Highlight>Full Stop\u003C/color>, \u003Ccolor=Highlight>Divergent\u003C/color> doesn't take effect.\",\n    \"param\": [\n      \"100\"\n    ]\n  },\n  \"141205\": {\n    \"name\": \"Convergent\",\n    \"desc\": \"The next time Sigrika obtains a \u003Ccolor=Highlight>Rune\u003C/color>, she additionally obtains a \u003Ccolor=Highlight>Rune\u003C/color> of the same type and removes \u003Ccolor=Highlight>Convergent\u003C/color>.\\nWhen Sigrika holds \u003Ccolor=Highlight>Divergent\u003C/color> and \u003Ccolor=Highlight>Convergent\u003C/color> at the same time, \u003Ccolor=Highlight>Convergent\u003C/color> takes priority.\\nWhen Sigrika holds \u003CSapTag=0>{0}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=0} of \u003Ccolor=Highlight>Full Stop\u003C/color>, \u003Ccolor=Highlight>Convergent\u003C/color> doesn't take effect.\",\n    \"param\": [\n      \"100\"\n    ]\n  },\n  \"141206\": {\n    \"name\": \"Soliskin Vitality\",\n    \"desc\": \"When any nearby Resonators in the team cast Echo Skill, Sigrika gains \u003CSapTag=0>{0}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=0} of \u003Ccolor=Highlight>Soliskin Vitality\u003C/color>, up to \u003CSapTag=1>{1}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=1}. Echoes with the same name can only trigger this effect once. Casting \u003Ccolor=Highlight>Outro Skill - In This Very Moment\u003C/color> resets the record of Echo triggering this effect.\",\n    \"param\": [\n      \"10\",\n      \"60\"\n    ]\n  },\n  \"800031\": {\n    \"name\": \"New Solar Celebration\",\n    \"desc\": \"The Exostrider poured forth light and heat from its Reactor Drive, sheltering life from the killing frost. Grateful for this gift, the Roya revered the Reactor Drive as their sun. They took it upon themselves to gather the Exostrider's \\\"cells,\\\" making this quiet labor the duty of their tribe.\\nNow, their ancient vow is complete. As the new sun rises, they hold the New Solar Celebration, both to mark the renewal and to remind their kin of the purpose that set them on this path.\",\n    \"param\": []\n  },\n  \"800032\": {\n    \"name\": \"Academy's Dark Side\",\n    \"desc\": \"A Sonoro born of nature. Now a shadowy reflection of the Academy, shifting with the collective psyche of its students and teachers.\",\n    \"param\": []\n  },\n  \"800033\": {\n    \"name\": \"Reflection\",\n    \"desc\": \"Shadows of students' emotions in the Dark Side, which mirror the hidden feelings within the students' hearts.\",\n    \"param\": []\n  },\n  \"800034\": {\n    \"name\": \"Minerva's Treasure\",\n    \"desc\": \"Each year, a treasure hunt organized by a mysterious host takes place at Startorch Academy. Participants take home a wide range of rewards, and a single wish is granted for the biggest winner. Though those wishes are always granted in delightfully peculiar ways, this eccentricity only fuels the students' rivalry as they strive to outwit their invisible mastermind.\",\n    \"param\": []\n  },\n  \"800035\": {\n    \"name\": \"Vortex's Eye\",\n    \"desc\": \"If the Dark Side is a vortex of anxiety and sorrow. At the heart of the raging storm is the force that sets it all in motion—the vortex's eye.\",\n    \"param\": []\n  },\n  \"141207\": {\n    \"name\": \"Decipher\",\n    \"desc\": \"Enter the \u003Ccolor=Highlight>Decipher\u003C/color> state after casting \u003Ccolor=Highlight>Basic Attack Stage 4\u003C/color> for {0}s. This effect ends early when Sigrika is switched off the field.\",\n    \"param\": [\n      \"5\"\n    ]\n  },\n  \"141208\": {\n    \"name\": \"Encapsulated\",\n    \"desc\": \"When any nearby Resonators in the team cast Echo Skills, Stagnate the target and consume \u003CSapTag=0>{0}\u003C/SapTag> {Cus:Sap,S=stack P=stacks SapTag=0} of \u003Ccolor=Highlight>Encapsulated\u003C/color>. \u003Ccolor=Highlight>Encapsulated\u003C/color> stacks up to {1} times.\\nAll stacks of \u003Ccolor=Highlight>Encapsulated\u003C/color> are removed when Sigrika is removed from the lineup.\",\n    \"param\": [\n      \"1\",\n      \"2\"\n    ]\n  },\n  \"121101\": {\n    \"name\": \"Dark Core\",\n    \"desc\": \"- When holding a \u003Ccolor=Highlight>Dark Core\u003C/color>, replace Resonance Skill \u003Ccolor=Highlight>Beckon - Breakdown Form\u003C/color> with \u003Ccolor=Highlight>Banish - Breakdown Form\u003C/color>.\\n- Denia can hold up to {0} \u003Ccolor=Highlight>Dark Cores\u003C/color>.\\n- While in the \u003Ccolor=Highlight>Entropy Shift \u003C/color> states, Denia obtains {2} \u003Ccolor=Highlight>Dark Core\u003C/color> every {1}s.\\n- Casting Intro Skill \u003Ccolor=Highlight>It's Been A While!\u003C/color> and Intro Skill \u003Ccolor=Highlight>Knock Knock\u003C/color> grants \u003CSapTag=3>{3}\u003C/SapTag> \u003Ccolor=Highlight>{Cus:Sap,S=Dark Core P=Dark Cores SapTag=3}\u003C/color>.\",\n    \"param\": [\n      \"3\",\n      \"12\",\n      \"1\",\n      \"1\"\n    ]\n  },\n  \"121102\": {\n    \"name\": \"Void Particle\",\n    \"desc\": \"When in \u003Ccolor=Highlight>Breakdown Form\u003C/color> while holding \u003Ccolor=Highlight>Void Particle\u003C/color>, \u003Ccolor=Highlight>Normal Attack\u003C/color> consumes \u003Ccolor=Highlight>Void Particle\u003C/color> on hit and grants the following effects:\\n- The skill DMG is considered \u003Ccolor=Highlight>Resonance Liberation DMG\u003C/color> and the DMG Multiplier is increased by {0}.\\n- \u003Ccolor=Highlight>Conformal Charge\u003C/color> regenerates {1} faster.\\nDenia can hold up to {2} points of \u003Ccolor=Highlight>Void Particle\u003C/color>.\\n- While in \u003Ccolor=Highlight>Stagecraft Form\u003C/color>, dealing damage through \u003Ccolor=Highlight>Normal Attack\u003C/color> grants \u003Ccolor=Highlight>Void Particle\u003C/color>.\\n- Casting Intro Skill \u003Ccolor=Highlight>It's Been A While!\u003C/color>, Intro Skill \u003Ccolor=Highlight>Knock Knock\u003C/color>, or Resonance Skill \u003Ccolor=Highlight>Phantom Bubble - Stagecraft Form\u003C/color> grants \u003CSapTag=D>{3}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=D} of \u003Ccolor=Highlight>Void Particle\u003C/color>.\",\n    \"param\": [\n      \"50%\",\n      \"100%\",\n      \"100\",\n      \"25\"\n    ]\n  },\n  \"121103\": {\n    \"name\": \"Entropy Shift: Breakdown Form\",\n    \"desc\": \"Increases ATK by {0}.\\nObtaining this effect removes the \u003Ccolor=Highlight>Entropy Shift: Stagecraft Form\u003C/color> effect.\",\n    \"param\": [\n      \"30%\"\n    ]\n  },\n  \"121104\": {\n    \"name\": \"Entropy Shift: Stagecraft Form\",\n    \"desc\": \"Grants {0} point of \u003Ccolor=Highlight>Void Particle\u003C/color> per second.\\nObtaining this effect removes the \u003Ccolor=Highlight>Entropy Shift: Breakdown Form \u003C/color> effect.\",\n    \"param\": [\n      \"1\"\n    ]\n  },\n  \"121105\": {\n    \"name\": \"Conformal Charge\",\n    \"desc\": \"- When \u003Ccolor=Highlight>Conformal Charge\u003C/color> is full, consume all \u003Ccolor=Highlight>Conformal Charge\u003C/color> and \u003Ccolor=Highlight>Void Particle\u003C/color> to perform Resonance Liberation \u003Ccolor=Highlight>Final Act - Breakdown Form\u003C/color>.\\n- Denia can hold up to {0} points of \u003Ccolor=Highlight>Conformal Charge\u003C/color>.\\n- While in \u003Ccolor=Highlight>Breakdown Form\u003C/color>, dealing damage through \u003Ccolor=Highlight>Normal Attack\u003C/color> or Resonance Skill \u003Ccolor=Highlight>Beckon - Breakdown Form\u003C/color> grants \u003Ccolor=Highlight>Conformal Charge\u003C/color>.\\n- Casting Resonance Skill \u003Ccolor=Highlight>Banish - Breakdown Form Stage 2\u003C/color> grants \u003CSapTag=F>{1}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=F} of \u003Ccolor=Highlight>Conformal Charge\u003C/color>.\",\n    \"param\": [\n      \"100\",\n      \"40\"\n    ]\n  },\n  \"110801\": {\n    \"name\": \"Dedication\",\n    \"desc\": \"Hiyuki holds up to 300 points of \u003Ccolor=Highlight>Dedication\u003C/color>.\\nWhile in \u003Ccolor=Highlight>Present Self\u003C/color>, \u003Ccolor=Highlight>Dedication\u003C/color> may be restored via the following ways:\\n- Casting \u003Ccolor=Highlight>Basic Attack - Present Self Stage 3\u003C/color> restores 100 points of \u003Ccolor=Highlight>Dedication\u003C/color>.\\n- Casting \u003Ccolor=Highlight>Intro Skill - Frostedge\u003C/color> restores 200 points of \u003Ccolor=Highlight>Dedication\u003C/color>.\\nCasting \u003Ccolor=Highlight>Resonance Skill - Present Self\u003C/color> enhances the next \u003Ccolor=Highlight>Basic Attack - Present Self Stage 3\u003C/color>, which now additionally restores 100 points of \u003Ccolor=Highlight>\u003Cte href=110801>Dedication\u003C/te>\u003C/color>. This effect ends when Hiyuki is switched out.\\nAt max \u003Ccolor=Highlight>Dedication\u003C/color>, \u003Ccolor=Highlight>Heavy Attack - Frost Splinter: Present Self\u003C/color> becomes available.\",\n    \"param\": []\n  },\n  \"110802\": {\n    \"name\": \"Frostheart\",\n    \"desc\": \"Hiyuki holds up to 300 points of \u003Ccolor=Highlight>Frostheart\u003C/color>.\\n\u003Ccolor=Highlight>Frostheart\u003C/color> is restored while casting \u003Ccolor=Highlight>Frostblight: Jade Cleave\u003C/color> and \u003Ccolor=Highlight>Frostblight: Petalfall\u003C/color>, or when \u003Ccolor=Highlight>Normal Attacks - Foreclaimed Self\u003C/color> other than \u003Ccolor=Highlight>Heavy Attack - Bitterfrost: Foreclaimed Self\u003C/color> hits the target.\\nIf Hiyuki has at least 100 points of \u003Ccolor=Highlight>Frostheart\u003C/color>, Hiyuki may enter \u003Ccolor=Highlight>Iai Stance\u003C/color>. While in \u003Ccolor=Highlight>Iai Stance\u003C/color>, {Cus:Ipt,Touch=tap PC=press Gamepad=press} \u003Ccolor=Highlight>Normal Attack\u003C/color> and consume 100 points of \u003Ccolor=Highlight>Frostheart\u003C/color> to cast \u003Ccolor=Highlight>Basic Attack - Iai\u003C/color>.\",\n    \"param\": []\n  },\n  \"110803\": {\n    \"name\": \"Frostharden Iai\",\n    \"desc\": \"\u003Ccolor=Highlight>Frostharden Iai\u003C/color> has a maximum of 3 points.\\nCasting \u003Ccolor=Highlight>Foreclaiming: Inward Vision\u003C/color> grants 3 points of \u003Ccolor=Highlight>Frostharden Iai\u003C/color>.\\nEach time \u003Ccolor=Highlight>Basic Attack - Iai\u003C/color> is cast, if Hiyuki has \u003Ccolor=Highlight>Frostharden Iai\u003C/color>, consume 1 point of \u003Ccolor=Highlight>Frostharden Iai\u003C/color> to apply 3 stacks of \u003Ccolor=Highlight>Glacio Chafe\u003C/color> on hit, and gain 1 stack of \u003Ccolor=Highlight>Whiteout Bitterfrost\u003C/color>.\",\n    \"param\": []\n  },\n  \"110804\": {\n    \"name\": \"Whiteout Bitterfrost\",\n    \"desc\": \"\u003Ccolor=Highlight>Whiteout Bitterfrost\u003C/color> stacks up to 3 times.\\nEach time \u003Ccolor=Highlight>Frostharden Iai\u003C/color> is consumed through \u003Ccolor=Highlight>Basic Attack - Iai\u003C/color>, gain 1 stack of \u003Ccolor=Highlight>Whiteout Bitterfrost\u003C/color>.\\nWhen \u003Ccolor=Highlight>Whiteout Bitterfrost\u003C/color> is full, \u003Ccolor=Highlight>Heavy Attack - Foreclaimed Self\u003C/color> is replaced with \u003Ccolor=Highlight>Heavy Attack - Bitterfrost: Foreclaimed Self\u003C/color>.\\nCasting \u003Ccolor=Highlight>Heavy Attack - Bitterfrost: Foreclaimed Self\u003C/color> consumes 3 stacks of \u003Ccolor=Highlight>Whiteout Bitterfrost\u003C/color>.\",\n    \"param\": []\n  },\n  \"110805\": {\n    \"name\": \"Snowforged Blade\",\n    \"desc\": \"\u003Ccolor=Highlight>Snowforged Blade\u003C/color> stacks up to 3 times.\\nEach time \u003Ccolor=Highlight>Heavy Attack - Bitterfrost: Foreclaimed Self\u003C/color> is cast, gain 1 stack of \u003Ccolor=Highlight>Snowforged Blade\u003C/color>.\\nWhile in \u003Ccolor=Highlight>Foreclaimed Self\u003C/color>, hold \u003Ccolor=Highlight>Resonance Liberation\u003C/color> to enter a charging state by continuously consuming \u003Ccolor=Highlight>Snowforged Blade\u003C/color>. Release \u003Ccolor=Highlight>Resonance Liberation\u003C/color> to deal \u003Ccolor=Ice>Glacio DMG\u003C/color>. The attack's DMG Multiplier is increased for each point of \u003Ccolor=Highlight>Snowforged Blade\u003C/color> consumed while charging the attack.\",\n    \"param\": []\n  },\n  \"110806\": {\n    \"name\": \"Present Self\",\n    \"desc\": \"Hiyuki starts in \u003Ccolor=Highlight>Present Self\u003C/color>. While in \u003Ccolor=Highlight>Present Self\u003C/color>, casting \u003Ccolor=Highlight>Basic Attack - Present Self Stage 3\u003C/color> restores 100 points of \u003Ccolor=Highlight>Dedication\u003C/color>. Casting \u003Ccolor=Highlight>Resonance Skill - Present Self\u003C/color> enhances the next \u003Ccolor=Highlight>Basic Attack - Present Self Stage 3\u003C/color>, which now additionally restore 100 points of \u003Ccolor=Highlight>Dedication\u003C/color>. Switching to another Resonator ends this effect.\",\n    \"param\": []\n  },\n  \"110807\": {\n    \"name\": \"Foreclaimed Self\",\n    \"desc\": \"Casting \u003Ccolor=Highlight>Foreclaiming: Inward Vision\u003C/color> causes Hiyuki to enter \u003Ccolor=Highlight>Foreclaimed Self\u003C/color>. While in \u003Ccolor=Highlight>Foreclaimed Self\u003C/color>, Hiyuki unlocks new moves and restores \u003Ccolor=Highlight>Frostheart\u003C/color> through certain attacks.\",\n    \"param\": []\n  },\n  \"110808\": {\n    \"name\": \"Frostbind\",\n    \"desc\": \"Targets in this state cannot perform any actions within the duration. The effect lasts for 2s.\",\n    \"param\": []\n  },\n  \"851075\": {\n    \"name\": \"Dimmr Plains\",\n    \"desc\": \"Located deep beneath Lahai-Roi, guarded by the Roya for generations. Its unusually high Voidmatter levels make it off-limits to most.\\nThe Spacetrek Collective has been permitted to conduct limited expeditions, but intense Voidmatter interference has so far yielded little meaningful intelligence.\",\n    \"param\": []\n  },\n  \"851076\": {\n    \"name\": \"Keystone\",\n    \"desc\": \"An \\\"anchor\\\" left behind when the Exostrider first came to the lands that would one day be called Lahai-Roi.\\nThe Spacetrek Collective mounted expeditions to its location, but returned with nothing worth recording.\",\n    \"param\": []\n  },\n  \"851077\": {\n    \"name\": \"Stridergate\",\n    \"desc\": \"The entry point formed when the Exostrider and the Threnodian Aleph-1 entered Solaris. The overlying Soliskin root network holds Aleph-1's power at bay, the \\\"sealed doors\\\" of the Stridergate.\\nThe Keystone is the \\\"lock\\\" that keeps the Stridergate closed.\\nBeyond it may lie the \\\"universe\\\" that Solaris has always longed to explore.\",\n    \"param\": []\n  },\n  \"851078\": {\n    \"name\": \"Seal of Flaming Sakura\",\n    \"desc\": \"Ashinohara has long relied on the \\\"miko system\\\" to resist the Threnodian, with each miko organization assigned to a specific territory. The Miko of Flaming Sakura is unique, her responsibility spanning all of Ashinohara.\\nThe Seal of Flaming Sakura is one of her line's secret arts, said to have been created by the very first Miko of Flaming Sakura . It is the only secret art passed down in written form. The seal draws power from the miko herself: the more power she channels into it, the longer it lasts.\\nThe seal's form changes with its caster.\\nIt is said that Hiyuki sealed away part of \\\"her own future\\\" within it—including, some say, a future that cannot be named.\",\n    \"param\": []\n  },\n  \"121106\": {\n    \"name\": \"Entropy Shift\",\n    \"desc\": \"\u003Csize=40>\u003Ccolor=Title>Entropy Shift: Stagecraft Form\u003C/color>\u003C/size>\\nGrants {0} points of \u003Ccolor=Highlight>Void Particle\u003C/color> per second.\\nObtaining this effect removes the \u003Ccolor=Highlight>Entropy Shift: Breakdown Form\u003C/color> effect.\\n\u003Csize=10>\u003C/size>\\n\u003Csize=40>\u003Ccolor=Title>Entropy Shift: Breakdown Form\u003C/color>\u003C/size>\\nIncreases ATK by {1}.\\nObtaining this effect removes the \u003Ccolor=Highlight>Entropy Shift: Stagecraft Form\u003C/color> effect.\",\n    \"param\": [\n      \"1\",\n      \"30%\"\n    ]\n  },\n  \"110809\": {\n    \"name\": \"Glacio Bite\",\n    \"desc\": \"When \u003Ccolor=Highlight>Glacio Bite\u003C/color> is inflicted, the target's \u003Ccolor=Highlight>Glacio Bite\u003C/color> will be triggered based on its current max stack limit. \u003Ccolor=Highlight>Glacio Bite\u003C/color> can be inflicted on \u003Ccolor=Highlight>frozen\u003C/color> targets. \u003Ccolor=Highlight>Glacio Bite\u003C/color> is also considered \u003Ccolor=Highlight>Glacio Chafe\u003C/color> and \u003Ccolor=Highlight>Glacio Bite DMG\u003C/color> is also considered \u003Ccolor=Highlight>Glacio Chafe DMG\u003C/color>.\",\n    \"param\": []\n  },\n  \"110901\": {\n    \"name\": \"Trace\",\n    \"desc\": \"Lucilla can hold up to {12} points of \u003Ccolor=Highlight>Trace\u003C/color>.\\nRestore \u003CSapTag=A>{13}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=A} of \u003Ccolor=Highlight>Trace\u003C/color> while casting \u003Ccolor=Highlight>Intro Skill - Clip It\u003C/color>.\\nRestore \u003CSapTag=B>{14}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=B} of \u003Ccolor=Highlight>Trace\u003C/color> while casting \u003Ccolor=Highlight>Resonance Skill - Spotlight\u003C/color>.\\nRestore \u003CSapTag=B>{14}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=B} of \u003Ccolor=Highlight>Trace\u003C/color> while casting \u003Ccolor=Highlight>Basic Attack Stage 3 - Commendable\u003C/color>.\\nRestore \u003CSapTag=C>{15}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=C} of \u003Ccolor=Highlight>Trace\u003C/color> while casting \u003Ccolor=Highlight>Resonance Skill - Compensate\u003C/color> or \u003Ccolor=Highlight>Basic Attack Stage 3 - Unremarkable\u003C/color>.\",\n    \"param\": [\n      \"4\",\n      \"30\",\n      \"4\",\n      \"1\",\n      \"2\",\n      \"0.5\",\n      \"1\",\n      \"30\",\n      \"1\",\n      \"10%\",\n      \"5\",\n      \"1\",\n      \"150\",\n      \"100\",\n      \"50\",\n      \"25\",\n      \"3\",\n      \"50\"\n    ]\n  },\n  \"110902\": {\n    \"name\": \"Photo\",\n    \"desc\": \"Lucilla can hold up to {16} \u003Ccolor=Highlight>Photos\u003C/color>.\\nEvery \u003CSapTag=F>{17}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=F} of \u003Ccolor=Highlight>Trace\u003C/color> restored generates 1 \u003Ccolor=Highlight>Photo\u003C/color>.\",\n    \"param\": [\n      \"4\",\n      \"30\",\n      \"4\",\n      \"1\",\n      \"2\",\n      \"0.5\",\n      \"1\",\n      \"30\",\n      \"1\",\n      \"10%\",\n      \"5\",\n      \"1\",\n      \"150\",\n      \"100\",\n      \"50\",\n      \"25\",\n      \"3\",\n      \"50\"\n    ]\n  },\n  \"110903\": {\n    \"name\": \"Film Roll\",\n    \"desc\": \"When an active Resonator in the team other than Lucilla inflicts \u003Ccolor=Highlight>Glacio Chafe\u003C/color>, Lucilla consumes \u003CSapTag=3>{3}\u003C/SapTag> {Cus:Sap,S=stack P=stacks SapTag=3} of \u003Ccolor=Highlight>Film Roll\u003C/color> to inflict \u003Ccolor=Highlight>Glacio Chafe\u003C/color> on nearby targets \u003CSapTag=4>{4}\u003C/SapTag> {Cus:Sap,S=time P=times SapTag=4}. This effect can be triggered once every {5}s.\",\n    \"param\": [\n      \"4\",\n      \"30\",\n      \"4\",\n      \"1\",\n      \"2\",\n      \"0.5\",\n      \"1\",\n      \"30\",\n      \"1\",\n      \"10%\",\n      \"5\",\n      \"1\",\n      \"150\",\n      \"100\",\n      \"50\",\n      \"25\",\n      \"3\",\n      \"50\"\n    ]\n  },\n  \"110904\": {\n    \"name\": \"Zoom\",\n    \"desc\": \"Each stack of \u003Ccolor=Highlight>Zoom\u003C/color> increases the Crit. DMG of the active Resonator's Echo Skill by {9}.\",\n    \"param\": [\n      \"4\",\n      \"30\",\n      \"4\",\n      \"1\",\n      \"2\",\n      \"0.5\",\n      \"1\",\n      \"30\",\n      \"1\",\n      \"10%\",\n      \"5\",\n      \"1\",\n      \"150\",\n      \"100\",\n      \"50\",\n      \"25\",\n      \"3\",\n      \"50\"\n    ]\n  },\n  \"110905\": {\n    \"name\": \"Reminiscence\",\n    \"desc\": \"When in \u003Ccolor=Highlight>Reminiscence\u003C/color>, Lucilla's resistance to interruption is increased, and she cannot cast \u003Ccolor=Highlight>Resonance Skill\u003C/color> and \u003Ccolor=Highlight>Resonance Liberation\u003C/color>. Her \u003Ccolor=Highlight>Basic Attack\u003C/color>, \u003Ccolor=Highlight>Dodge Counter\u003C/color>, \u003Ccolor=Highlight>Mid-air Attack\u003C/color>, and \u003Ccolor=Highlight>Intro Skill - Clip It\u003C/color> are replaced with \u003Ccolor=Highlight>Basic Attack - Tracing Forms\u003C/color>, \u003Ccolor=Highlight>Dodge Counter - Reminiscence\u003C/color>, \u003Ccolor=Highlight>Mid-air Attack - Reminiscence\u003C/color>, and \u003Ccolor=Highlight>Intro Skill - Clip It: Hard Cut\u003C/color> respectively.\",\n    \"param\": [\n      \"30%\",\n      \"10\"\n    ]\n  },\n  \"852000\": {\n    \"name\": \"Upgrade\",\n    \"desc\": \"Relic items will automatically level up and grow more powerful after meeting certain conditions. Relic Level starts at 1 by default.\",\n    \"param\": []\n  },\n  \"852001\": {\n    \"name\": \"Roly-Poly\",\n    \"desc\": \"When an on-field Echo is removed, obtain Frequency Crystals equal to a portion of the Daily Coupon yield of the removed Echo. The proportion is increased as the Relic levels up.\\nUpgrade: The Relic will automatically level up for every certain amount of Echoes removed.\",\n    \"param\": []\n  },\n  \"130801\": {\n    \"name\": \"Huntress\",\n    \"desc\": \"While in the \u003Ccolor=Highlight>Huntress\u003C/color> mode, Rebecca's Crit. DMG increases by {0}.\",\n    \"param\": [\n      \"30%\",\n      \"15%\",\n      \"120\",\n      \"120\",\n      \"120\",\n      \"120\",\n      \"50\",\n      \"120\",\n      \"5\",\n      \"50\",\n      \"120\",\n      \"12\"\n    ]\n  },\n  \"130802\": {\n    \"name\": \"Guts\",\n    \"desc\": \"While in the \u003Ccolor=Highlight>Guts\u003C/color> mode, Rebecca ignores {1} of the target's DEF.\",\n    \"param\": [\n      \"30%\",\n      \"15%\",\n      \"120\",\n      \"120\",\n      \"120\",\n      \"120\",\n      \"50\",\n      \"120\",\n      \"5\",\n      \"50\",\n      \"120\",\n      \"12\"\n    ]\n  },\n  \"130803\": {\n    \"name\": \"Overload\",\n    \"desc\": \"Rebecca can hold up to {6} points of \u003Ccolor=Highlight>Overload\u003C/color>.\\nHitting targets with the standard firepower \u003Ccolor=Highlight>Mk. {7} HMG\u003C/color> grants {8} points.\\nHitting targets with the enhanced firepower \u003Ccolor=Highlight>Mk. {9} HMG\u003C/color> grants {10} points.\\nHitting targets with the twice-enhanced firepower \u003Ccolor=Highlight>Mk. {11} HMG\u003C/color> grants {12} points.\",\n    \"param\": [\n      \"31\",\n      \"9\",\n      \"31\",\n      \"31\",\n      \"31\",\n      \"50%\",\n      \"90\",\n      \"31\",\n      \"2\",\n      \"31\",\n      \"4\",\n      \"31\",\n      \"6\",\n      \"31\",\n      \"31\"\n    ]\n  },\n  \"130804\": {\n    \"name\": \"A Girl Gets What She Wants!\",\n    \"desc\": \"At {10} points of \u003Ccolor=Highlight>Hot Hand\u003C/color>, casting \u003Ccolor=Highlight>Intro Skill - Yo, It's Big Boomin' Time!\u003C/color>, \u003Ccolor=Highlight>Intro Skill - Hey, Leadhead, Come 'n' Get Me!\u003C/color>, \u003Ccolor=Highlight>Resonance Skill -  It's Big Boomin' Time!\u003C/color>, or \u003Ccolor=Highlight>Resonance Skill - Come 'n' Get Me!\u003C/color> grants the following effects for {11}s:\\nRebecca simultaneously gains the Stat Bonuses of both the \u003Ccolor=Highlight>Huntress\u003C/color> and \u003Ccolor=Highlight>Guts\u003C/color> modes, regardless of which mode she's currently in.\\n\u003Ccolor=Highlight>Hot Hand\u003C/color> cannot be restored during this period and consumes \u003CSapTag=A>{13}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=A} of \u003Ccolor=Highlight>Hot Hand\u003C/color> per second.\",\n    \"param\": [\n      \"30%\",\n      \"15%\",\n      \"120\",\n      \"120\",\n      \"120\",\n      \"120\",\n      \"50\",\n      \"120\",\n      \"5\",\n      \"50\",\n      \"120\",\n      \"12\",\n      \"10\",\n      \"10\"\n    ]\n  },\n  \"130805\": {\n    \"name\": \"Fervor\",\n    \"desc\": \"Rebecca can hold up to {5} points of \u003Ccolor=Highlight>Fervor\u003C/color>.\\n\u003Ccolor=Highlight>Normal Attacks\u003C/color> restore \u003Ccolor=Highlight>Fervor\u003C/color> upon damaging the target.\\n\u003Ccolor=Highlight>Resonance Skill\u003C/color> restores \u003Ccolor=Highlight>Fervor\u003C/color> upon damaging the target.\\nWhen \u003Ccolor=Highlight>A Girl Gets What She Wants!\u003C/color> is gained by casting \u003Ccolor=Highlight>Intro Skill - Yo, It's Big Boomin' Time!\u003C/color> or \u003Ccolor=Highlight>Intro Skill - Hey, Leadhead, Come 'n' Get Me!\u003C/color>, Rebecca restores \u003CSapTag=6>{6}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=6} of Fervor.\",\n    \"param\": [\n      \"30%\",\n      \"15%\",\n      \"120\",\n      \"120\",\n      \"120\",\n      \"120\",\n      \"50\",\n      \"120\",\n      \"5\",\n      \"50\",\n      \"120\",\n      \"12\"\n    ]\n  },\n  \"130806\": {\n    \"name\": \"Hot Hand\",\n    \"desc\": \"Rebecca can hold up to {7} points of \u003Ccolor=Highlight>Hot Hand\u003C/color>.\\nRegenerates over time at a rate of \u003CSapTag=8>{8}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=8} per second.\\nCasting \u003Ccolor=Highlight>Heavy Attack- Rat-tat-tat!: Huntress\u003C/color> or \u003Ccolor=Highlight>Heavy Attack- Bang-bang-bang!: Guts\u003C/color> restores \u003CSapTag=9>{9}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=9}.\",\n    \"param\": [\n      \"30%\",\n      \"15%\",\n      \"120\",\n      \"120\",\n      \"120\",\n      \"120\",\n      \"50\",\n      \"120\",\n      \"10\",\n      \"40\",\n      \"120\",\n      \"12\"\n    ]\n  },\n  \"151101\": {\n    \"name\": \"Hack - Shifting\",\n    \"desc\": \"Certain Resonators can inflict \u003Ccolor=Highlight>Hack - Shifting\u003C/color> on the target. During this state, if the affected target is hit by \u003Ccolor=Highlight>Tune Break\u003C/color>, their \u003Ccolor=Highlight>Hack - Shifting\u003C/color> state is replaced with \u003Ccolor=Highlight>Hack - Interfered\u003C/color>.\",\n    \"param\": []\n  },\n  \"151102\": {\n    \"name\": \"Algorithm Compaction\",\n    \"desc\": \"After casting \u003Ccolor=Highlight>Resonance Skill - Deadlock\u003C/color>, Lucy enters \u003Ccolor=Highlight>Algorithm Compaction\u003C/color> and gains \u003CSapTag=0>{0}\u003C/SapTag> {Cus:Sap,S=stack P=stacks SapTag=0} of \u003Ccolor=Highlight>SQL\u003C/color>. Her \u003Ccolor=Highlight>Basic Attack\u003C/color> is replaced with \u003Ccolor=Highlight>Basic Attack - Thread Shredding\u003C/color>, and \u003Ccolor=Highlight>Heavy Attack\u003C/color> is replaced with \u003Ccolor=Highlight>Heavy Attack - Single Threading\u003C/color>. Lucy's Spectro DMG Bonus is increased by {1}% for {2}s.\\nWhen in \u003Ccolor=Highlight>Algorithm Compaction\u003C/color>, Lucy gains \u003Ccolor=Highlight>Root Access\u003C/color> upon hitting a target with \u003Ccolor=Highlight>Basic Attack - Thread Shredding\u003C/color> or \u003Ccolor=Highlight>Heavy Attack - Single Threading\u003C/color>. Reaching {3} points of \u003Ccolor=Highlight>Root Access\u003C/color> replaces \u003Ccolor=Highlight>Heavy Attack - Single Threading\u003C/color> with \u003Ccolor=Highlight>Heavy Attack - Dual Threading\u003C/color>. {Cus:Ipt,Touch=Tap PC=Press Gamepad=Press} or hold \u003Ccolor=Highlight>Normal Attack\u003C/color> shortly after casting \u003Ccolor=Highlight>Heavy Attack - Dual Threading\u003C/color> to cast \u003Ccolor=Highlight>Heavy Attack - Multi-threading\u003C/color>.\\nAfter casting \u003Ccolor=Highlight>Heavy Attack - Multi-threading\u003C/color>, \u003Ccolor=Highlight>Resonance Liberation - Netrunner\u003C/color> is replaced with \u003Ccolor=Highlight>Resonance Liberation - Old Net Deep Dive\u003C/color>.\\nAfter casting \u003Ccolor=Highlight>Resonance Liberation - Netrunner\u003C/color> or \u003Ccolor=Highlight>Resonance Liberation - Old Net Deep Dive\u003C/color>, Lucy exits the \u003Ccolor=Highlight>Algorithm Compaction\u003C/color> state.\",\n    \"param\": [\n      \"1\",\n      \"65\",\n      \"8\",\n      \"100\"\n    ]\n  },\n  \"151103\": {\n    \"name\": \"TCP\",\n    \"desc\": \"\u003Ccolor=Highlight>TCP\u003C/color>\\nLucy holds up to {0} points of \u003Ccolor=Highlight>TCP\u003C/color>.\\nLucy gains \u003Ccolor=Highlight>TCP\u003C/color> when she deals damage through \u003Ccolor=Highlight>Basic Attack\u003C/color>, \u003Ccolor=Highlight>Heavy Attack\u003C/color>, \u003Ccolor=Highlight>Mid-air Attack\u003C/color>, or \u003Ccolor=Highlight>Dodge Counter\u003C/color>.\\nLucy gains \u003Ccolor=Highlight>TCP\u003C/color> when she deals damage through \u003Ccolor=Highlight>Resonance Skill - Payload\u003C/color> and \u003Ccolor=Highlight>Resonance Skill - Pulse Interference\u003C/color>.\\nAfter casting \u003Ccolor=Highlight>Intro Skill - Outdated Hallucination\u003C/color>, casting the next \u003Ccolor=Highlight>Resonance Skill - Pulse Interference\u003C/color> additionally grants \u003CSapTag=A>{1}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=A} of \u003Ccolor=Highlight>TCP\u003C/color>.\\nWhen \u003Ccolor=Highlight>TCP\u003C/color> reaches {2} points, \u003Ccolor=Highlight>Resonance Skill - Payload\u003C/color> and \u003Ccolor=Highlight>Resonance Skill - Pulse Interference\u003C/color> are replaced with \u003Ccolor=Highlight>Resonance Skill - Deadlock\u003C/color>.\",\n    \"param\": [\n      \"100\",\n      \"20\",\n      \"100\"\n    ]\n  },\n  \"151104\": {\n    \"name\": \"Hack - Interfered\",\n    \"desc\": \"A target enters this state when they are hit by \u003Ccolor=Highlight>Tune Break\u003C/color> under the \u003Ccolor=Highlight>Hack - Shifting\u003C/color> state. Resonators who can respond to \u003Ccolor=Highlight>Hack- Interfered\u003C/color> cause additional effects when attacking targets in this state. \u003Ccolor=Highlight>Hack- Interfered\u003C/color> lasts for {0}s.\",\n    \"param\": [\n      \"8\"\n    ]\n  },\n  \"151105\": {\n    \"name\": \"Root Access\",\n    \"desc\": \"\u003Ccolor=Highlight>Root Access\u003C/color>\\nLucy holds up to {0} points of \u003Ccolor=Highlight>Root Access\u003C/color>. \\nLucy gains \u003Ccolor=Highlight>Root Access\u003C/color> when she deals damage through \u003Ccolor=Highlight>Basic Attack - Thread Shredding\u003C/color>, \u003Ccolor=Highlight>Heavy Attack - Single Threading\u003C/color>, \u003Ccolor=Highlight>Mid-air Attack - Algorithm Compaction\u003C/color>, and \u003Ccolor=Highlight>Dodge Counter - Algorithm Compaction\u003C/color>.\\nReaching {1} points of \u003Ccolor=Highlight>Root Access\u003C/color> replaces \u003Ccolor=Highlight>Heavy Attack - Single Threading\u003C/color> with \u003Ccolor=Highlight>Heavy Attack - Dual Threading\u003C/color>. {Cus:Ipt,Touch=Tap PC=Press Gamepad=Press} or hold \u003Ccolor=Highlight>Normal Attack\u003C/color> shortly after casting \u003Ccolor=Highlight>Heavy Attack - Dual Threading\u003C/color> to cast \u003Ccolor=Highlight>Heavy Attack - Multi-threading\u003C/color>.\",\n    \"param\": [\n      \"100\",\n      \"100\"\n    ]\n  },\n  \"852002\": {\n    \"name\": \"Weak Measurement Clock\",\n    \"desc\": \"Every \u003CSapTag=0>{0}\u003C/SapTag> {Cus:Sap,S=day P=days SapTag=0}, the Daily Coupon yield of all Echoes on the field is increased based on the Relic Level.\\nUpgrade: The Relic will automatically level up for every certain amount of Echoes obtained. This does not include Echoes obtained from Echo Recruitment, Dreamland Shop, or Phantasma Blessing.\",\n    \"param\": [\n      \"5\"\n    ]\n  },\n  \"852003\": {\n    \"name\": \"The Chronicles of A\",\n    \"desc\": \"Every \u003CSapTag=0>{0}\u003C/SapTag> {Cus:Sap,S=day P=days SapTag=0}, the Daily Coupon yield of all Echoes on the field is increased based on the Relic Level.\\nUpgrade: The Relic will automatically level up for every certain amount of Echoes removed.\",\n    \"param\": [\n      \"4\"\n    ]\n  },\n  \"852004\": {\n    \"name\": \"Autopuppet Warband\",\n    \"desc\": \"Before the Daily Coupon settlement, if any Echo obtains a certain number of Dreamland Coupons in a single instance, the Daily Coupon yield of all on-field Echoes is increased based on the Relic Level.\\nUpgrade: The Relic will automatically level up every time any Echo obtains a certain number of Dreamland Coupons in a single instance before the Daily Coupon settlement.\",\n    \"param\": []\n  },\n  \"151106\": {\n    \"name\": \"SQL\",\n    \"desc\": \"After casting \u003Ccolor=Highlight>Resonance Skill - Deadlock\u003C/color>, Lucy enters \u003Ccolor=Highlight>Algorithm Compaction\u003C/color> and gains \u003CSapTag=0>{0}\u003C/SapTag> {Cus:Sap,S=stack P=stacks SapTag=0} of \u003Ccolor=Highlight>SQL\u003C/color>.\\nWhile in \u003Ccolor=Highlight>Algorithm Compaction\u003C/color>, casting \u003Ccolor=Highlight>Resonance Skill - Deadlock\u003C/color> will not grant \u003Ccolor=Highlight>SQL\u003C/color> again.\\nWhen casting \u003Ccolor=Highlight>Heavy Attack - Multi-threading\u003C/color>, if Lucy has \u003Ccolor=Highlight>SQL\u003C/color>, increase this attack's DMG Multiplier by {1}% and remove \u003Ccolor=Highlight>SQL\u003C/color>.\\nWhen casting \u003Ccolor=Highlight>Heavy Attack - Multi-threading\u003C/color>, if Lucy does not have \u003Ccolor=Highlight>SQL\u003C/color>, she loses {2}% of current HP. If Lucy's HP is below {3}%, no HP is consumed.\",\n    \"param\": [\n      \"1\",\n      \"270\",\n      \"20\",\n      \"1\"\n    ]\n  },\n  \"852005\": {\n    \"name\": \"Braindance\",\n    \"desc\": \"A technology that allows to record and play back someone's experience, including their physical sensations, emotions, and thoughts. While initially pioneered as a new psychological treatment method in penal reform, braindances quickly became one of the most popular forms of immersive media entertainment in the world.\",\n    \"param\": []\n  },\n  \"852006\": {\n    \"name\": \"Night City\",\n    \"desc\": \"The city where Lucy and her gang lived. It was once the largest metropolis of the Cyberpunk world. Now it's been reduced to the den of corporations, corruptions, organized crimes and violence.\",\n    \"param\": []\n  },\n  \"852007\": {\n    \"name\": \"Kiroshi\",\n    \"desc\": \"Kiroshi Opticals, also known as Matsushima-Kiroshi Optics, is an industrial leader in the R&D and production of optical cyberware. In this script, it is used to refer to Lucy's and Rebecca's cyberoptics.\",\n    \"param\": []\n  },\n  \"151107\": {\n    \"name\": \"Spoofing Program\",\n    \"desc\": \"When Lucy casts \u003Ccolor=Highlight>Resonance Liberation - Netrunner\u003C/color> or \u003Ccolor=Highlight>Resonance Liberation - Old Net Deep Dive\u003C/color>, she pulls up a Protocol Interface. She can choose up to {0} different \u003Ccolor=Highlight>Spoofing Program\u003C/color> effects from the following list, each requiring different RAM costs. Lucy starts with \u003CSapTag=1>{1}\u003C/SapTag> {Cus:Sap,S=point P=points SapTag=1} of RAM:\\n\u003Ccolor=Highlight>Spoofing Program: Ping\u003C/color>, \\n\u003Ccolor=Highlight>Spoofing Program: Cyberware Malfunction\u003C/color>, \\n\u003Ccolor=Highlight>Spoofing Program: Breach Protocol\u003C/color>, \u003Ccolor=Highlight>Spoofing Program: Synapse Burnout\u003C/color>, \u003Ccolor=Highlight>Spoofing Program: Cripple Movement\u003C/color>, \u003Ccolor=Highlight>Spoofing Program: Weapon Glitch\u003C/color>, and \u003Ccolor=Highlight>Spoofing Program: Cyberpsychosis\u003C/color>.\",\n    \"param\": [\n      \"7\",\n      \"24\"\n    ]\n  },\n  \"111001\": {\n    \"name\": \"Enrichment\",\n    \"desc\": \"Casting \u003Ccolor=Highlight>Resonance Skill - Awakening Spring\u003C/color> and \u003Ccolor=Highlight>Intro Skill - Tinkling Jade\u003C/color> grants all nearby Resonators in the team 1 stack of \u003Ccolor=Highlight>Enrichment\u003C/color>. This effect can be triggered once every 25s. Incoming Resonators receive healing from Suisui at the cost of \u003Ccolor=Highlight>Enrichment\u003C/color>.\",\n    \"param\": []\n  },\n  \"111002\": {\n    \"name\": \"Spring’s Birth\",\n    \"desc\": \"After unlocking Inherent Skill - 近水纳天光, consuming \u003Ccolor=Highlight>Enrichment\u003C/color> grants the Resonator \u003CSapTag=0>{0}\u003C/SapTag> {Cus:Sap,S=stack P=stacks SapTag=2} of \u003Ccolor=Highlight>Spring’s Birth\u003C/color>, up to {1} stacks. When the Resonator with \u003Ccolor=Highlight>Spring’s Birth\u003C/color> is on the field and not at full HP, restore their HP by {3} + {4} of Suisui's Max HP at the cost of 1 stack of \u003Ccolor=Highlight>Spring’s Birth\u003C/color> every {2}s.\",\n    \"param\": [\n      \"10\",\n      \"10\",\n      \"2\",\n      \"62\",\n      \"0.0034%\"\n    ]\n  },\n  \"111003\": {\n    \"name\": \"Ceaseless Landscape\",\n    \"desc\": \"Upon casting \u003Ccolor=Highlight>Resonance Liberation - Song of Thoroughfare\u003C/color>, Suisui deploys \u003Ccolor=Highlight>Ceaseless Landscape\u003C/color> that lasts for 25s. During \u003Ccolor=Highlight>Ceaseless Landscape\u003C/color>, Suisui enters \u003Ccolor=Highlight>Heaven's Roam\u003C/color> when casting \u003Ccolor=Highlight>Outro Skill - Rippling Waters\u003C/color>.\\n\u003Ccolor=Highlight>Ceaseless Landscape\u003C/color> grants all nearby Resonators in the team the following enhancements:\\n- Inflicting a target with \u003Ccolor=Highlight>\u003Cte href=850008>Spectro Frazzle\u003C/te>\u003C/color>, \u003Ccolor=Highlight>\u003Cte href=850011>Fusion Burst\u003C/te>\u003C/color>, \u003Ccolor=Highlight>\u003Cte href=850010>Glacio Chafe\u003C/te>\u003C/color>, and \u003Ccolor=Highlight>\u003Cte href=850009>Aero Erosion\u003C/te>\u003C/color> increases the max stack limit of \u003Ccolor=Highlight>\u003Cte href=850180>Negative Status\u003C/te>\u003C/color> the target can receive by 3 for 15s.\\n- Inflicting a target with \u003Ccolor=Highlight>\u003Cte href=850013>Electro Flare\u003C/te>\u003C/color> increases the max stack limits of \u003Ccolor=Highlight>\u003Cte href=850013>Electro Flare\u003C/te>\u003C/color> and \u003Ccolor=Highlight>\u003Cte href=150806>Electro Rage\u003C/te>\u003C/color> the target can receive by 3 for 15s.\\n- Inflicting a target with \u003Ccolor=Highlight>\u003Cte href=850012>Havoc Bane\u003C/te>\u003C/color> allows the Resonator's Havoc DMG to ignore the target's DEF and Havoc RES by {0} and {1} respectively for 15s.\",\n    \"param\": [\n      \"6%\",\n      \"12%\"\n    ]\n  },\n  \"111004\": {\n    \"name\": \"Heaven's Roam\",\n    \"desc\": \"If there is \u003Ccolor=Highlight>Ceaseless Landscape\u003C/color> left on the field, Suisui enters \u003Ccolor=Highlight>Heaven's Roam\u003C/color> upon casting \u003Ccolor=Highlight>Outro Skill - Rippling Waters\u003C/color>. During this time, Suisui dances between \u003Ccolor=Highlight>Ceaseless Landscape\u003C/color>, and periodically applies certain effects to targets caught within \u003Ccolor=Highlight>Ceaseless Landscape\u003C/color>, based on the \u003Ccolor=Highlight>Floral Epistle\u003C/color> consumed from casting \u003Ccolor=Highlight>Outro Skill - Rippling Waters\u003C/color>.\",\n    \"param\": []\n  },\n  \"111005\": {\n    \"name\": \"Cleansing\",\n    \"desc\": \"When in \u003Ccolor=Highlight>Cleansing\u003C/color>, Suisui can obtain \u003Ccolor=Highlight>Stillness\u003C/color> through certain skills.\\nCasting \u003Ccolor=Highlight>Resonance Skill - Awakening Spring\u003C/color> and \u003Ccolor=Highlight>Intro Skill - Tinkling Jade\u003C/color> ends \u003Ccolor=Highlight>Cleansing\u003C/color> and Suisui enters \u003Ccolor=Highlight>Cleansing Rain\u003C/color>.\",\n    \"param\": []\n  },\n  \"111006\": {\n    \"name\": \"Cleansing Rain\",\n    \"desc\": \"Upon casting \u003Ccolor=Highlight>Resonance Skill - Awakening Spring\u003C/color> and \u003Ccolor=Highlight>Intro Skill - Tinkling Jade\u003C/color>, Suisui enters \u003Ccolor=Highlight>Cleansing Rain\u003C/color>.\\nEntering \u003Ccolor=Highlight>\u003Cte href=111006>Cleansing Rain\u003C/te>\u003C/color> clears all \u003Ccolor=Highlight>\u003Cte href=111008>Floral Epistle\u003C/te>\u003C/color>.\\n- When in \u003Ccolor=Highlight>Cleansing Rain\u003C/color>, Suisui unlocks new moves, and her certain skills can restore \u003Ccolor=Highlight>Floral Epistle\u003C/color>.\\n- When in \u003Ccolor=Highlight>Cleansing Rain\u003C/color>, Suisui's resistance to interruption level is increased by 1.\\nAfter entering \u003Ccolor=Highlight>Cleansing Rain\u003C/color> for 15s, or upon casting \u003Ccolor=Highlight>Outro Skill - Rippling Waters\u003C/color>, Suisui leaves \u003Ccolor=Highlight>Cleansing Rain\u003C/color> and enters \u003Ccolor=Highlight>Cleansing\u003C/color>.\",\n    \"param\": []\n  },\n  \"111007\": {\n    \"name\": \"Stillness\",\n    \"desc\": \"Max 120 points.\\nWhen in \u003Ccolor=Highlight>Cleansing\u003C/color>, hitting a target with \u003Ccolor=Highlight>Basic Attack - Cleansing\u003C/color> and \u003Ccolor=Highlight>Dodge Counter - Cleansing\u003C/color>, or casting \u003Ccolor=Highlight>Realization\u003C/color> to trigger a successful Dodge restores \u003Ccolor=Highlight>Stillness\u003C/color>.\\nLeaving \u003Ccolor=Highlight>Cleansing\u003C/color> removes all \u003Ccolor=Highlight>Stillness\u003C/color>.\",\n    \"param\": []\n  },\n  \"111008\": {\n    \"name\": \"Floral Epistle\",\n    \"desc\": \"Max 120 points.\\nWhen in \u003Ccolor=Highlight>Cleansing Rain\u003C/color>, hitting a target with \u003Ccolor=Highlight>Basic Attack - Cleansing Rain\u003C/color> and \u003Ccolor=Highlight>Heavy Attack - Cleansing Rain\u003C/color>, or casting \u003Ccolor=Highlight>Realization\u003C/color> to trigger a successful Dodge restores \u003Ccolor=Highlight>Floral Epistle\u003C/color>.\\nLeaving \u003Ccolor=Highlight>Cleansing Rain\u003C/color> removes all \u003Ccolor=Highlight>Floral Epistle\u003C/color>.\",\n    \"param\": []\n  },\n  \"111009\": {\n    \"name\": \"Reflecting Shadows\",\n    \"desc\": \"Upon casting \u003Ccolor=Highlight>Outro Skill - Rippling Waters\u003C/color> or when in \u003Ccolor=Highlight>Heaven's Roam\u003C/color>, Suisui grants all nearby Resonators in team bonus effects. While \u003Ccolor=Highlight>Heaven's Roam\u003C/color> is active, Resonators' resistance to interruption level is increased by 1, and receive additional bonus effects from Suisui.\",\n    \"param\": []\n  }\n}"}</script>
			<script type="application/json" data-sveltekit-fetched data-url="https://static.nanoka.cc/ww/3.5.3/en/item.json" data-ttl="105">{"status":200,"statusText":"OK","headers":{},"body":"{\n  \"2\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconA/T_IconA_hsb_UI.T_IconA_hsb_UI\",\n    \"rank\": 3,\n    \"tag\": [\n      \"Universal Currency\"\n    ],\n    \"tagnum\": [\n      2\n    ],\n    \"type\": 0,\n    \"name\": \"Shell Credit\"\n  },\n  \"3\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconA/T_IconA_zcpq_UI.T_IconA_zcpq_UI\",\n    \"rank\": 5,\n    \"tag\": [\n      \"Premium Currency\"\n    ],\n    \"tagnum\": [\n      3\n    ],\n    \"type\": 0,\n    \"name\": \"Astrite\"\n  },\n  \"4\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconA/T_IconA_cdtq_UI.T_IconA_cdtq_UI\",\n    \"rank\": 5,\n    \"tag\": [\n      \"Premium Currency\"\n    ],\n    \"tagnum\": [\n      3\n    ],\n    \"type\": 0,\n    \"name\": \"Lunite\"\n  },\n  \"5\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconA/T_IconA_yml_UI.T_IconA_yml_UI\",\n    \"rank\": 4,\n    \"tag\": [\n      \"Consumable\"\n    ],\n    \"tagnum\": [\n      10\n    ],\n    \"type\": 0,\n    \"name\": \"Waveplate\"\n  },\n  \"10800\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconA/T_IconA_mlf_UI.T_IconA_mlf_UI\",\n    \"rank\": 4,\n    \"tag\": [\n      \"Consumable\"\n    ],\n    \"tagnum\": [\n      10\n    ],\n    \"type\": 7,\n    \"name\": \"Crystal Solvent\"\n  },\n  \"41300005\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconMout/T_IconMout_L_002_1_UI.T_IconMout_L_002_1_UI\",\n    \"rank\": 5,\n    \"tag\": [\n      \"Resonator Ascension Material\"\n    ],\n    \"tagnum\": [\n      7\n    ],\n    \"type\": 4,\n    \"name\": \"Mysterious Code\"\n  },\n  \"41400014\": {\n    \"icon\": \"/Game/Aki/UI/UIResources/Common/Image/IconMout/T_IconMout_L_004_1_UI.T_IconMout_L_004_1_UI\",\n    \"rank\": 4,\n    \"tag\": [\n      \"Reson